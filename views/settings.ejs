            <button class="btn btn-primary" onclick="save(['invoice_prefix','default_due_day','auto_generate_day','late_tolerance_days','auto_billing_enabled','auto_isolate_enabled','reminder_days_before'])">💾 <%= t.save %></button>
        </div>



        <div id="tab-acs" class="tab-content card" style="display:none">
