            <div class="form-row">
                <div class="form-group"><label><%= t.auto_generate_invoice_day %></label><input type="number" id="auto_generate_day" class="form-control" value="<%=settings.auto_generate_day||1%>" min="1" max="28"></div>
                <div class="form-group"><label><%= t.late_tolerance %></label><input type="number" id="late_tolerance_days" class="form-control" value="<%=settings.late_tolerance_days||0%>" min="0"></div>
            </div>
