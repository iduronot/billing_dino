            <div class="form-row">
                <div class="form-group"><label><%= t.auto_billing_feature %></label>
                    <select id="auto_billing_enabled" class="form-control">
                        <option value="1" <%=settings.auto_billing_enabled==='1'?'selected':''%>><%= t.enabled_auto_invoice %></option>
                        <option value="0" <%=settings.auto_billing_enabled==='0'?'selected':''%>><%= t.disabled_manual %></option>
