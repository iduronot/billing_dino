            <button onclick="saveEditUser()" class="btn btn-primary"><i class="fas fa-save"></i> Simpan</button>
        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
// ── Mini Map untuk settings koordinat ──
let miniMap = null, miniMarker = null;

function initMiniMap() {
    if (miniMap) return;
    const lat  = parseFloat(document.getElementById('map_center_lat').value) || -7.5;
    const lng  = parseFloat(document.getElementById('map_center_lng').value) || 110.5;
    const zoom = parseInt(document.getElementById('map_default_zoom').value) || 13;

    miniMap = L.map('miniMap', { zoomControl: true, attributionControl: false });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom:19 }).addTo(miniMap);
    miniMap.setView([lat, lng], zoom);

    miniMarker = L.marker([lat, lng], { draggable: true }).addTo(miniMap);
    miniMarker.on('dragend', e => {
        const pos = e.target.getLatLng();
        document.getElementById('map_center_lat').value = pos.lat.toFixed(7);
        document.getElementById('map_center_lng').value = pos.lng.toFixed(7);
    });

    miniMap.on('click', e => {
        document.getElementById('map_center_lat').value = e.latlng.lat.toFixed(7);
        document.getElementById('map_center_lng').value = e.latlng.lng.toFixed(7);
        miniMarker.setLatLng(e.latlng);
    });
}

// Init mini map saat tab General aktif & elemen visible
const mapWrap = document.getElementById('miniMapWrap');
if (mapWrap) {
    const observer = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) { initMiniMap(); observer.disconnect(); }
    });
    observer.observe(mapWrap);
}

// Ambil lokasi GPS perangkat
function getMyLocation() {
    if (!navigator.geolocation) return alert('Geolocation tidak didukung browser ini');
    navigator.geolocation.getCurrentPosition(pos => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;
        document.getElementById('map_center_lat').value = lat.toFixed(7);
        document.getElementById('map_center_lng').value = lng.toFixed(7);
        if (miniMap) {
            miniMap.setView([lat, lng], 15);
            miniMarker.setLatLng([lat, lng]);
        } else {
            initMiniMap();
        }
    }, () => alert('Gagal mendapatkan lokasi GPS'));
}

// Update zoom saat input berubah
const zoomInput = document.getElementById('map_default_zoom');
if (zoomInput) {
    zoomInput.addEventListener('change', () => {
        if (miniMap) miniMap.setZoom(parseInt(zoomInput.value) || 13);
    });
}
</script>
</body>
