            <div class="form-group"><label><%= t.acs_api_url %></label><input type="text" id="acs_url" class="form-control" value="<%=settings.acs_url||''%>" placeholder="http://127.0.0.1:7557"></div>
            <div class="form-row">
                <div class="form-group"><label><%= t.api_username %></label><input type="text" id="acs_user" class="form-control" value="<%=settings.acs_user||''%>"></div>
                <div class="form-group"><label><%= t.api_password %></label><input type="password" id="acs_pass" class="form-control" value="<%=settings.acs_pass||''%>"></div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label><%= t.pppoe_user_path %></label>
                    <input type="text" id="acs_path_pppoe" class="form-control" value="<%=settings.acs_path_pppoe||''%>" placeholder="VirtualParameters.PPPoEUser">
                </div>
                <div class="form-group">
                    <label><%= t.ip_wan_path %></label>
                    <input type="text" id="acs_path_ip" class="form-control" value="<%=settings.acs_path_ip||''%>" placeholder="VirtualParameters.IPAddress">
                </div>
            </div>
            <div class="form-group">
                <label><%= t.additional_vparams %></label>
                <p class="setting-desc"><%= t.vparams_instruction %><br>Contoh: <code>VirtualParameters.OpticalPower</code>, <code>VirtualParameters.Uptime</code></p>
                <textarea id="acs_vparams" class="form-control" rows="4" placeholder="VirtualParameters.OpticalPower&#10;VirtualParameters.Uptime"><%=settings.acs_vparams||''%></textarea>
            </div>
            <div class="form-group" style="margin-top:4px;">
                <label>⏱️ Threshold Online (menit)</label>
