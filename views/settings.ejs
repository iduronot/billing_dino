<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
    <style>
        .tab-btn { padding:10px 18px; background:rgba(255,255,255,.05); border:1px solid var(--border); border-radius:10px; color:var(--muted); cursor:pointer; font-family:'Outfit',sans-serif; transition:all .2s; }
        .tab-btn:hover { background:rgba(255,255,255,.1); color:var(--text); }
        .tab-btn.active { background:var(--primary); border-color:var(--primary); color:white; }
        .settings-tab { display:none; }
        .settings-tab.active { display:block; animation: fadeIn 0.3s ease; }
        @keyframes fadeIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
        .setting-group { margin-bottom:24px; padding-bottom:24px; border-bottom:1px solid var(--border); }
        .setting-group:last-child { border-bottom:none; }
        .setting-label { display:block; font-weight:600; margin-bottom:8px; font-size:15px; }
        .setting-desc { font-size:13px; color:var(--muted); margin-bottom:12px; line-height:1.4; }
        .card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:26px;margin-bottom:20px;}
        .section-title{font-size:16px;font-weight:600;margin:0 0 20px;padding-bottom:12px;border-bottom:1px solid var(--border);}
        .form-group{margin-bottom:16px;}.form-group label{display:block;margin-bottom:7px;font-size:13px;color:var(--muted);}
        .form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
        .toast{position:fixed;bottom:24px;right:24px;background:var(--toast-bg);color:var(--text);border:1px solid var(--border);border-radius:12px;padding:14px 20px;z-index:9999;display:none;font-size:14px;}.toast.show{display:block;}
        .update-section{background:rgba(139,92,246,.08);border:1px solid rgba(139,92,246,.2);border-radius:12px;padding:20px;margin-top:8px;}
        @media(max-width:768px){.main{margin-left:0;}.form-row{grid-template-columns:1fr;}}

        /* Logo manager */
        .logo-manager { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-top:24px; padding-top:20px; border-top:1px solid var(--border); }
        .logo-box { background:var(--sub-bg); border:2px dashed var(--border); border-radius:16px; padding:24px; display:flex; flex-direction:column; align-items:center; gap:14px; text-align:center; transition:border-color .2s; }
        .logo-box:hover { border-color:var(--primary); }
        .logo-preview { width:100%; max-height:80px; object-fit:contain; border-radius:8px; display:none; }
        .logo-preview.visible { display:block; }
        .logo-placeholder { font-size:36px; opacity:.3; }
        .logo-label { font-size:13px; font-weight:700; color:var(--text); }
        .logo-hint  { font-size:11px; color:var(--muted); }
        .logo-actions { display:flex; gap:8px; flex-wrap:wrap; justify-content:center; }
        .btn-upload { background:var(--primary); color:white; border:none; border-radius:9px; padding:8px 16px; font-size:12px; font-weight:700; cursor:pointer; font-family:'Outfit',sans-serif; display:inline-flex; align-items:center; gap:6px; }
        .btn-remove { background:rgba(239,68,68,.1); color:#EF4444; border:1px solid rgba(239,68,68,.25); border-radius:9px; padding:8px 14px; font-size:12px; font-weight:700; cursor:pointer; font-family:'Outfit',sans-serif; display:none; }
        .btn-remove.visible { display:inline-flex; align-items:center; gap:6px; }
        @media(max-width:640px){ .logo-manager { grid-template-columns:1fr; } }
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: t.system_settings }) %>
    <div class="content">
        <div class="page-header">
            <h1 class="page-title"><%= t.settings %></h1>
        </div>

        <!-- Tabs -->
        <div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap">
            <button class="tab-btn active" onclick="showTab('company')">🏢 <%= t.company %></button>
            <button class="tab-btn" onclick="showTab('wa')">💬 <%= t.whatsapp %></button>
            <button class="tab-btn" onclick="showTab('telegram')">✈️ <%= t.telegram %></button>
            <button class="tab-btn" onclick="showTab('payment')">💳 <%= t.payment %></button>
            <button class="tab-btn" onclick="showTab('billing')">🗓 <%= t.billing %></button>

            <button class="tab-btn" onclick="showTab('acs')">🌐 <%= t.genieacs %></button>
            <button class="tab-btn" onclick="showTab('import')">📤 <%= t.import_export %></button>
            <button class="tab-btn" onclick="showTab('users')">👥 <%= t.manage_users %></button>
            <button class="tab-btn" onclick="showTab('wa_templates')">📝 <%= t.wa_templates %></button>
            <button class="tab-btn" onclick="showTab('system')">🔄 <%= t.system %></button>
        </div>

        <div id="tab-company" class="tab-content card">
            <h2 class="section-title">🏢 <%= t.company_profile %></h2>
            <div class="form-row">
                <div class="form-group"><label><%= t.company_name %></label><input type="text" id="company_name" class="form-control" value="<%= settings.company_name||'Dino-Bill ISP'%>"></div>
                <div class="form-group"><label><%= t.phone_wa %></label><input type="text" id="company_phone" class="form-control" value="<%= settings.company_phone||''%>" placeholder="08xxxxxxxxxx"></div>
            </div>
            <div class="form-group"><label><%= t.office_address %></label><input type="text" id="company_address" class="form-control" value="<%= settings.company_address||''%>"></div>
            <div class="form-row">
                <div class="form-group"><label><%= t.email_label %></label><input type="email" id="company_email" class="form-control" value="<%= settings.company_email||''%>"></div>
                <div class="form-group"><label><%= t.website %></label><input type="text" id="company_website" class="form-control" value="<%= settings.company_website||''%>" placeholder="https://"></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label><%= t.timezone %></label>
                    <select id="timezone" class="form-control">
                        <option value="Asia/Jakarta" <%=settings.timezone==='Asia/Jakarta'?'selected':''%>>WIB (Asia/Jakarta)</option>
                        <option value="Asia/Makassar" <%=settings.timezone==='Asia/Makassar'?'selected':''%>>WITA (Asia/Makassar)</option>
                        <option value="Asia/Jayapura" <%=settings.timezone==='Asia/Jayapura'?'selected':''%>>WIT (Asia/Jayapura)</option>
                    </select>
                </div>
                <div class="form-group"><label><%= t.currency %></label>
                    <select id="currency" class="form-control">
                        <option value="IDR" <%=settings.currency==='IDR'?'selected':''%>>IDR - Rupiah</option>
                        <option value="USD" <%=settings.currency==='USD'?'selected':''%>>USD - Dollar</option>
                    </select>
                </div>
            </div>
            <button class="btn btn-primary" onclick="save(['company_name','company_phone','company_address','company_email','company_website','timezone','currency'])">💾 <%= t.save %></button>

            <!-- Logo & Icon Manager -->
            <div class="logo-manager">
                <!-- Logo Perusahaan -->
                <div class="logo-box" id="logoBox" ondragover="event.preventDefault()" ondrop="handleDrop(event,'company_logo')">
                    <% if(settings.company_logo) { %>
                    <img src="<%= settings.company_logo %>" class="logo-preview visible" id="logoPreview" alt="Logo">
                    <% } else { %>
                    <img src="" class="logo-preview" id="logoPreview" alt="Logo">
                    <div class="logo-placeholder" id="logoPlaceholder">🏢</div>
                    <% } %>
                    <div>
                        <div class="logo-label">Logo Perusahaan</div>
                        <div class="logo-hint">Tampil di sidebar & invoice<br>PNG/SVG transparan, maks 2MB</div>
                    </div>
                    <div class="logo-actions">
                        <label class="btn-upload" for="logoInput">
                            <i class="fas fa-upload"></i> Upload Logo
                        </label>
                        <input type="file" id="logoInput" accept="image/*" style="display:none" onchange="uploadFile(this,'company_logo')">
                        <button class="btn-remove <%= settings.company_logo?'visible':'' %>" id="logoRemove" onclick="removeFile('company_logo')">
                            <i class="fas fa-trash"></i> Hapus
                        </button>
                    </div>
                </div>

                <!-- Icon / Favicon -->
                <div class="logo-box" id="iconBox" ondragover="event.preventDefault()" ondrop="handleDrop(event,'company_icon')">
                    <% if(settings.company_icon) { %>
                    <img src="<%= settings.company_icon %>" class="logo-preview visible" id="iconPreview" alt="Icon" style="max-height:64px;width:auto;">
                    <% } else { %>
                    <img src="" class="logo-preview" id="iconPreview" alt="Icon" style="max-height:64px;width:auto;">
                    <div class="logo-placeholder" id="iconPlaceholder">🦖</div>
                    <% } %>
                    <div>
                        <div class="logo-label">Icon / Favicon</div>
                        <div class="logo-hint">Tampil di browser tab & sidebar<br>PNG/ICO/SVG kotak, maks 2MB</div>
                    </div>
                    <div class="logo-actions">
                        <label class="btn-upload" for="iconInput">
                            <i class="fas fa-upload"></i> Upload Icon
                        </label>
                        <input type="file" id="iconInput" accept="image/*,.ico" style="display:none" onchange="uploadFile(this,'company_icon')">
                        <button class="btn-remove <%= settings.company_icon?'visible':'' %>" id="iconRemove" onclick="removeFile('company_icon')">
                            <i class="fas fa-trash"></i> Hapus
                        </button>
                    </div>
                </div>
            </div>

            <!-- Pusat Koordinat Peta -->
            <div style="margin-top:24px; padding-top:20px; border-top:1px solid var(--border);">
                <h2 class="section-title">🗺 Pusat Koordinat Peta</h2>
                <p style="font-size:13px; color:var(--muted); margin-bottom:16px;">
                    Titik tengah yang ditampilkan saat peta pertama kali dibuka. Klik tombol "Ambil Lokasi Saya" atau isi manual.
                </p>
                <div style="display:grid; grid-template-columns:1fr 1fr auto; gap:12px; align-items:end; margin-bottom:14px;">
                    <div class="form-group" style="margin:0;">
                        <label>Latitude</label>
                        <input type="text" id="map_center_lat" class="form-control" placeholder="-7.5766" value="<%= settings.map_center_lat||'' %>">
                    </div>
                    <div class="form-group" style="margin:0;">
                        <label>Longitude</label>
                        <input type="text" id="map_center_lng" class="form-control" placeholder="110.8165" value="<%= settings.map_center_lng||'' %>">
                    </div>
                    <button type="button" class="btn" style="background:rgba(59,130,246,.1); color:var(--primary); border:1px solid rgba(59,130,246,.2); white-space:nowrap;" onclick="getMyLocation()">
                        <i class="fas fa-crosshairs"></i> Ambil Lokasi
                    </button>
                </div>
                <div style="display:grid; grid-template-columns:120px 1fr; gap:12px; align-items:center; margin-bottom:16px;">
                    <div class="form-group" style="margin:0;">
                        <label>Zoom Default</label>
                        <input type="number" id="map_default_zoom" class="form-control" placeholder="13" min="5" max="20" value="<%= settings.map_default_zoom||13 %>">
                    </div>
                    <div style="font-size:12px; color:var(--muted);">5 = seluruh negara · 13 = level kota · 17 = detail jalan</div>
                </div>
                <!-- Mini preview map -->
                <div id="miniMapWrap" style="height:220px; border-radius:12px; overflow:hidden; border:1px solid var(--border); margin-bottom:14px; position:relative;">
                    <div id="miniMap" style="width:100%; height:100%;"></div>
                    <div style="position:absolute; top:8px; right:8px; background:var(--card-bg); border:1px solid var(--border); border-radius:8px; padding:5px 10px; font-size:11px; color:var(--muted); z-index:1000;">Klik peta untuk set koordinat</div>
                </div>
                <button class="btn btn-primary" onclick="save(['map_center_lat','map_center_lng','map_default_zoom'])">💾 Simpan Koordinat Peta</button>

            <!-- Setting Presensi -->
            <div style="margin-top:24px; padding-top:20px; border-top:1px solid var(--border);">
                <h2 class="section-title">📍 Pengaturan Presensi</h2>
                <p style="font-size:13px; color:var(--muted); margin-bottom:16px;">
                    Titik pusat presensi menggunakan koordinat peta di atas. Atur radius dan jam terlambat di sini.
                </p>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:14px;">
                    <div class="form-group" style="margin:0;">
                        <label>Radius Maksimal (meter)</label>
                        <input type="number" id="attendance_radius" class="form-control" placeholder="100" min="10" max="5000" value="<%= settings.attendance_radius||100 %>">
                        <p style="font-size:11px; color:var(--muted); margin-top:4px;">Presensi ditolak jika jarak melebihi nilai ini</p>
                    </div>
                    <div class="form-group" style="margin:0;">
                        <label>Batas Jam Tepat Waktu</label>
                        <input type="time" id="attendance_late_time" class="form-control" value="<%= settings.attendance_late_time||'08:30' %>">
                        <p style="font-size:11px; color:var(--muted); margin-top:4px;">Setelah jam ini dianggap terlambat</p>
                    </div>
                </div>
                <button class="btn btn-primary" onclick="save(['attendance_radius','attendance_late_time'])">💾 Simpan Pengaturan Presensi</button>
            </div>
            </div>
        </div>

        <!-- Tab: WhatsApp -->
        <div id="tab-wa" class="tab-content card" style="display:none">
            <h2 class="section-title">💬 <%= t.wa_gateway %></h2>
            <div class="form-group"><label><%= t.provider %></label>
                <select id="wa_provider" class="form-control" onchange="toggleWAFields()">
                    <option value="local" <%=settings.wa_provider==='local'?'selected':''%>><%= t.local_session_qr %></option>
                    <option value="fonnte" <%=settings.wa_provider==='fonnte'?'selected':''%>>Fonnte</option>
                    <option value="mpwa" <%=settings.wa_provider==='mpwa'?'selected':''%>>MPWA</option>
                    <option value="wablas" <%=settings.wa_provider==='wablas'?'selected':''%>>Wablas</option>
                </select>
            </div>

            <!-- Local WA Section -->
            <div id="wa_local_section" class="update-section" style="margin-bottom:20px; display:none">
                <h3 style="font-size:14px; margin-bottom:12px"><%= t.local_session_connection %></h3>
                <div style="display:flex; gap:20px; align-items:center">
                    <div id="wa_qr_container" style="background:white; padding:10px; border-radius:8px; width:150px; height:150px; display:flex; align-items:center; justify-content:center; border:1px solid var(--border)">
                        <span style="color:black; font-size:12px; text-align:center"><%= t.loading_qr %></span>
                    </div>
                    <div>
                        <div id="wa_status_badge" class="badge" style="margin-bottom:8px"><%= t.checking_status %></div>
                        <p style="font-size:12px; color:var(--muted); line-height:1.4">
                            <%= t.scan_qr_instruction %><br>
                            <%= t.powered_by %> <b>whatsapp-web.js</b>.
                        </p>
                        <button class="btn btn-sm" style="margin-top:8px; font-size:11px; background:rgba(239,68,68,.1); color:#EF4444; border:1px solid rgba(239,68,68,.2)" onclick="restartWA()">🔄 <%= t.restart_wa %></button>
                    </div>
                </div>
            </div>

            <div id="wa_api_fields">
                <div class="form-group"><label>API URL</label><input type="text" id="wa_api_url" class="form-control" value="<%=settings.wa_api_url||''%>" placeholder="https://api.fonnte.com/send"></div>
                <div class="form-group"><label>API Key / Token</label><input type="text" id="wa_api_key" class="form-control" value="<%=settings.wa_api_key||''%>"></div>
                <div class="form-group"><label><%= t.wa_sender %></label><input type="text" id="wa_sender" class="form-control" value="<%=settings.wa_sender||''%>" placeholder="6281xxxxxxxxxx"></div>
            </div>
            
            <div class="form-row" style="margin-bottom:16px">
                <div class="form-group"><label><%= t.message_delay %></label><input type="number" id="wa_delay" class="form-control" value="<%=settings.wa_delay||5%>" min="1" placeholder="Contoh: 5"></div>
                <div class="form-group"><label><%= t.batch_limit %></label><input type="number" id="wa_limit" class="form-control" value="<%=settings.wa_limit||50%>" min="1" placeholder="Contoh: 50"></div>
            </div>

            <!-- Toggle Notifikasi Otomatis WA -->
            <div style="background:var(--sub-bg);border:1px solid var(--border);border-radius:12px;padding:16px 18px;margin-bottom:16px;">
                <div style="font-weight:700;font-size:13px;margin-bottom:12px;display:flex;align-items:center;gap:7px;">
                    📬 Notifikasi Otomatis WhatsApp
                </div>
                <div style="display:flex;flex-direction:column;gap:10px;">

                    <!-- Toggle Invoice -->
                    <label style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;padding:10px 14px;background:var(--card-bg);border-radius:9px;border:1px solid var(--border);">
                        <div>
                            <div style="font-weight:600;font-size:13px;">📄 Tagihan Baru Dibuat</div>
                            <div style="font-size:11px;color:var(--muted);margin-top:2px;">Kirim WA ke pelanggan saat invoice bulanan dibuat otomatis (tgl 1)</div>
                        </div>
                        <div style="position:relative;width:44px;height:24px;flex-shrink:0;margin-left:12px;">
                            <input type="checkbox" id="wa_notif_invoice" style="opacity:0;width:0;height:0;position:absolute;"
                                <%=settings.wa_notif_invoice!=='0'?'checked':''%>
                                onchange="this.closest('label').querySelector('.tog-track').style.background=this.checked?'#10B981':'#475569';this.closest('label').querySelector('.tog-thumb').style.transform=this.checked?'translateX(20px)':'translateX(0)'">
                            <div class="tog-track" style="position:absolute;inset:0;border-radius:12px;background:<%=settings.wa_notif_invoice!=='0'?'#10B981':'#475569'%>;transition:background .2s;"></div>
                            <div class="tog-thumb" style="position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;transform:<%=settings.wa_notif_invoice!=='0'?'translateX(20px)':'translateX(0)'%>;"></div>
                        </div>
                    </label>

                    <!-- Toggle Isolir -->
                    <label style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;padding:10px 14px;background:var(--card-bg);border-radius:9px;border:1px solid var(--border);">
                        <div>
                            <div style="font-weight:600;font-size:13px;">🔒 Pemutusan Layanan (Isolir)</div>
                            <div style="font-size:11px;color:var(--muted);margin-top:2px;">Kirim WA ke pelanggan saat diisolir otomatis karena tagihan belum dibayar</div>
                        </div>
                        <div style="position:relative;width:44px;height:24px;flex-shrink:0;margin-left:12px;">
                            <input type="checkbox" id="wa_notif_isolir" style="opacity:0;width:0;height:0;position:absolute;"
                                <%=settings.wa_notif_isolir!=='0'?'checked':''%>
                                onchange="this.closest('label').querySelector('.tog-track').style.background=this.checked?'#10B981':'#475569';this.closest('label').querySelector('.tog-thumb').style.transform=this.checked?'translateX(20px)':'translateX(0)'">
                            <div class="tog-track" style="position:absolute;inset:0;border-radius:12px;background:<%=settings.wa_notif_isolir!=='0'?'#10B981':'#475569'%>;transition:background .2s;"></div>
                            <div class="tog-thumb" style="position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;transform:<%=settings.wa_notif_isolir!=='0'?'translateX(20px)':'translateX(0)'%>;"></div>
                        </div>
                    </label>

                    <!-- Toggle Reminder -->
                    <label style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;padding:10px 14px;background:var(--card-bg);border-radius:9px;border:1px solid var(--border);">
                        <div>
                            <div style="font-weight:600;font-size:13px;">⏰ Pengingat Jatuh Tempo (H-3)</div>
                            <div style="font-size:11px;color:var(--muted);margin-top:2px;">Kirim WA pengingat 3 hari sebelum tagihan jatuh tempo</div>
                        </div>
                        <div style="position:relative;width:44px;height:24px;flex-shrink:0;margin-left:12px;">
                            <input type="checkbox" id="wa_notif_reminder" style="opacity:0;width:0;height:0;position:absolute;"
                                <%=settings.wa_notif_reminder!=='0'?'checked':''%>
                                onchange="this.closest('label').querySelector('.tog-track').style.background=this.checked?'#10B981':'#475569';this.closest('label').querySelector('.tog-thumb').style.transform=this.checked?'translateX(20px)':'translateX(0)'">
                            <div class="tog-track" style="position:absolute;inset:0;border-radius:12px;background:<%=settings.wa_notif_reminder!=='0'?'#10B981':'#475569'%>;transition:background .2s;"></div>
                            <div class="tog-thumb" style="position:absolute;top:3px;left:3px;width:18px;height:18px;border-radius:50%;background:#fff;transition:transform .2s;transform:<%=settings.wa_notif_reminder!=='0'?'translateX(20px)':'translateX(0)'%>;"></div>
                        </div>
                    </label>

                </div>
            </div>

            <div class="form-group"><label><%= t.admin_phone %></label><input type="text" id="wa_admin" class="form-control" value="<%=settings.wa_admin||''%>" placeholder="6281xxxxxxxxxx"></div>
            <div style="display:flex;gap:10px;flex-wrap:wrap">
                <button class="btn btn-primary" onclick="save(['wa_provider','wa_api_url','wa_api_key','wa_sender','wa_delay','wa_limit','wa_admin','wa_notif_invoice','wa_notif_isolir','wa_notif_reminder'])">💾 <%= t.save %></button>
                <button class="btn" style="background:rgba(37,211,102,.15);color:#25D366;border:1px solid rgba(37,211,102,.3)" onclick="testWA()">📤 <%= t.test_send_wa %></button>
            </div>
        </div>

        <div id="tab-telegram" class="tab-content card" style="display:none">
            <h2 class="section-title">✈️ <%= t.telegram %> Bot</h2>
            <div class="form-group"><label>Bot Token</label><input type="text" id="telegram_bot_token" class="form-control" value="<%=settings.telegram_bot_token||''%>" placeholder="123456:ABC..."></div>
            <div class="form-group"><label>Admin Chat ID</label><input type="text" id="telegram_chat_id" class="form-control" value="<%=settings.telegram_chat_id||''%>" placeholder="-100xxxxxxxxxx"></div>
            <div style="display:flex;gap:10px;flex-wrap:wrap">
                <button class="btn btn-primary" onclick="save(['telegram_bot_token','telegram_chat_id'])">💾 <%= t.save %></button>
                <button class="btn" style="background:rgba(0,136,204,.15);color:#0088cc;border:1px solid rgba(0,136,204,.3)" onclick="testTelegram()">✈️ Test Kirim Telegram</button>
            </div>
        </div>

        <!-- Tab: Payment -->
        <div id="tab-payment" class="tab-content card" style="display:none">
            <h2 class="section-title">💳 <%= t.payment %> Gateway</h2>
            <div class="form-group"><label>Default Gateway</label>
                <select id="payment_gateway" class="form-control">
                    <option value="manual" <%=settings.payment_gateway==='manual'?'selected':''%>>Manual (Transfer/Cash)</option>
                    <option value="xendit" <%=settings.payment_gateway==='xendit'?'selected':''%>>Xendit QRIS</option>
                    <option value="tripay" <%=settings.payment_gateway==='tripay'?'selected':''%>>Tripay</option>
                </select>
            </div>
            <hr style="border-color:var(--border);margin:16px 0">
            <h3 style="font-size:14px;color:var(--muted);margin:0 0 12px">Transfer Manual</h3>
            <div class="form-row">
                <div class="form-group"><label><%= t.bank_name %></label><input type="text" id="bank_name" class="form-control" value="<%=settings.bank_name||'BANK BCA'%>" placeholder="Contoh: BANK BCA"></div>
                <div class="form-group"><label><%= t.account_number %></label><input type="text" id="bank_account" class="form-control" value="<%=settings.bank_account||'1234567890'%>" placeholder="1234567890"></div>
            </div>
            <div class="form-group"><label><%= t.account_holder %></label><input type="text" id="bank_holder" class="form-control" value="<%=settings.bank_holder||''%>" placeholder="Contoh: ITO SOLUTION"></div>
            <div style="margin-bottom:20px"><button class="btn btn-primary" onclick="save(['bank_name','bank_account','bank_holder'])">💾 <%= t.save_bank_data %></button></div>
            <hr style="border-color:var(--border);margin:16px 0">
            <h3 style="font-size:14px;color:var(--muted);margin:0 0 8px">🔲 QRIS Statis</h3>
            <p style="font-size:12px;color:var(--muted);margin:0 0 14px">Upload gambar QRIS statis yang akan ditampilkan di portal pelanggan sebagai alternatif pembayaran transfer bank.</p>
            <div style="display:flex;align-items:flex-start;gap:16px;flex-wrap:wrap;margin-bottom:16px">
                <div id="qris-preview-wrap" style="display:<%= settings.qris_image ? 'block' : 'none' %>">
                    <img id="qris-preview" src="<%= settings.qris_image || '' %>" alt="QRIS" style="width:160px;height:160px;object-fit:contain;border:1px solid var(--border);border-radius:12px;background:#fff;padding:8px">
                    <div style="margin-top:6px;text-align:center">
                        <button onclick="deleteUpload('qris_image')" style="font-size:11px;background:rgba(239,68,68,.1);color:#EF4444;border:1px solid rgba(239,68,68,.3);border-radius:6px;padding:4px 10px;cursor:pointer">Hapus</button>
                    </div>
                </div>
                <div style="flex:1;min-width:200px">
                    <label class="btn btn-primary" for="qris-upload-input" style="display:inline-flex;align-items:center;gap:8px;cursor:pointer;width:auto;padding:10px 18px">
                        <i class="fas fa-upload"></i> Upload Gambar QRIS
                    </label>
                    <input type="file" id="qris-upload-input" accept="image/*" style="display:none" onchange="uploadQrisImage(this)">
                    <p style="font-size:11px;color:var(--muted);margin:8px 0 0">Format: JPG, PNG. Maks 2MB.</p>
                </div>
            </div>
            <hr style="border-color:var(--border);margin:16px 0">
            <h3 style="font-size:14px;color:var(--muted);margin:0 0 12px">Tripay</h3>
            <div class="form-row">
                <div class="form-group"><label>API Key</label><input type="text" id="tripay_api_key" class="form-control" value="<%=settings.tripay_api_key||''%>"></div>
                <div class="form-group"><label>Private Key</label><input type="text" id="tripay_private_key" class="form-control" value="<%=settings.tripay_private_key||''%>"></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label><%= t.merchant_code %></label><input type="text" id="tripay_merchant_code" class="form-control" value="<%=settings.tripay_merchant_code||''%>"></div>
                <div class="form-group"><label><%= t.mode %></label>
                    <select id="tripay_mode" class="form-control">
                        <option value="sandbox" <%=settings.tripay_mode==='sandbox'?'selected':''%>>Sandbox</option>
                        <option value="production" <%=settings.tripay_mode==='production'?'selected':''%>>Production</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label>Pilih Channel Pembayaran</label>
                <div id="tripay_channel_list" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap:10px; margin-top:10px; padding:15px; background:var(--sub-bg); border:1px solid var(--border); border-radius:12px; max-height:300px; overflow-y:auto;">
                    <div style="color:var(--muted); font-size:12px; grid-column:1/-1; text-align:center;">Tekan tombol "Test & Muat Channel" di bawah untuk memuat daftar channel.</div>
                </div>
                <input type="hidden" id="tripay_channels" value="<%=settings.tripay_channels||''%>">
                <p class="setting-desc" style="margin-top:8px">Pilih channel mana saja yang ingin Anda tampilkan di portal pelanggan.</p>
            </div>
            <div class="form-group">
                <label><%= t.callback_url %></label>
                <div style="display:flex;gap:10px">
                    <input type="text" id="tripay_callback_url" class="form-control" readonly style="background:rgba(0,0,0,0.2);cursor:default" value="">
                    <button class="btn btn-sm btn-info" onclick="copyCallback()"><%= t.copy %></button>
                </div>
                <p class="setting-desc" style="margin-top:8px"><%= t.callback_instruction %></p>
            </div>
            <div style="display:flex;gap:10px;flex-wrap:wrap">
                <button class="btn btn-primary" onclick="save(['payment_gateway','tripay_api_key','tripay_private_key','tripay_merchant_code','tripay_mode','tripay_channels'])">💾 <%= t.save %></button>
                <button class="btn" style="background:rgba(99,102,241,.15);color:#818CF8;border:1px solid rgba(99,102,241,.3)" onclick="testTripay()">💳 Test & Muat Channel</button>
            </div>
            <hr style="border-color:var(--border);margin:20px 0">
            <h3 style="font-size:14px;color:var(--muted);margin:0 0 12px">⚡ Xendit QRIS</h3>
            <div class="form-group">
                <label>API Key (Secret Key)</label>
                <input type="password" id="xendit_api_key" class="form-control" value="<%=settings.xendit_api_key||''%>" placeholder="xnd_production_...">
                <p class="setting-desc" style="margin-top:6px">Dapatkan dari <b>Xendit Dashboard → Settings → API Keys</b>. Gunakan Secret Key (bukan Public Key).</p>
            </div>
            <div class="form-group">
                <label>Webhook Token (Callback Token)</label>
                <input type="password" id="xendit_webhook_token" class="form-control" value="<%=settings.xendit_webhook_token||''%>" placeholder="Token verifikasi webhook Xendit">
                <p class="setting-desc" style="margin-top:6px">Dapatkan dari <b>Xendit Dashboard → Settings → Webhooks → Callback Token</b>.</p>
            </div>
            <div class="form-group">
                <label>Callback URL (daftarkan ke Xendit)</label>
                <div style="display:flex;gap:10px">
                    <input type="text" id="xendit_callback_url" class="form-control" readonly style="background:rgba(0,0,0,0.2);cursor:default;font-family:monospace;font-size:12px" value="">
                    <button class="btn btn-sm btn-info" onclick="copyXenditCallback()">Salin</button>
                </div>
                <p class="setting-desc" style="margin-top:6px">Daftarkan URL di atas ke <b>Xendit Dashboard → Settings → Webhooks → QR Code</b> agar pembayaran otomatis terdeteksi.</p>
            </div>
            <div style="display:flex;gap:10px;flex-wrap:wrap">
                <button class="btn btn-primary" onclick="save(['payment_gateway','xendit_api_key','xendit_webhook_token'])">💾 Simpan Xendit</button>
                <button class="btn" style="background:rgba(16,185,129,.15);color:#10B981;border:1px solid rgba(16,185,129,.3)" onclick="testXendit()">⚡ Test Koneksi Xendit</button>
            </div>
        </div>

