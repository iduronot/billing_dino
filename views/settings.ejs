<div class="toast" id="toast"></div>
<style>
.tab-btn{padding:8px 16px;border-radius:8px;border:1px solid var(--border);background:rgba(255,255,255,.04);color:var(--muted);cursor:pointer;font-family:'Outfit',sans-serif;font-size:13px;transition:all .2s}
.tab-btn.active{background:rgba(59,130,246,.15);color:var(--primary);border-color:rgba(59,130,246,.4)}
.tab-btn:hover{color:var(--text)}
</style>
<script>
function showTab(name){
    document.querySelectorAll('.tab-content').forEach(t=>t.style.display='none');
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    document.getElementById('tab-'+name).style.display='block';
    event.target.classList.add('active');
}

// ── Logo / Icon Upload ──
async function uploadFile(input, type) {
    const file = input.files[0];
    if (!file) return;
    if (file.size > 2 * 1024 * 1024) return showToast('File terlalu besar (maks 2MB)', 'error');

    const isLogo = type === 'company_logo';
    const previewId = isLogo ? 'logoPreview' : 'iconPreview';
    const phId     = isLogo ? 'logoPlaceholder' : 'iconPlaceholder';
    const removeId = isLogo ? 'logoRemove' : 'iconRemove';

    // Preview lokal dulu
    const reader = new FileReader();
    reader.onload = e => {
        const img = document.getElementById(previewId);
        img.src = e.target.result;
        img.classList.add('visible');
        const ph = document.getElementById(phId);
        if (ph) ph.style.display = 'none';
        document.getElementById(removeId).classList.add('visible');
    };
    reader.readAsDataURL(file);

    // Upload ke server
    const form = new FormData();
    form.append('file', file);
    try {
        const res = await fetch(`/settings/api/upload/${type}`, { method: 'POST', body: form });
        const d = await res.json();
        if (d.success) {
            showToast('Berhasil diupload', 'success');
            // Update favicon jika icon
            if (type === 'company_icon') {
                let link = document.querySelector("link[rel*='icon']");
                if (!link) { link = document.createElement('link'); link.rel = 'icon'; document.head.appendChild(link); }
                link.href = d.path + '?t=' + Date.now();
            }
        } else {
            showToast(d.message || 'Gagal upload', 'error');
        }
    } catch(e) {
        showToast('Gagal upload: ' + e.message, 'error');
    }
    input.value = '';
}

async function removeFile(type) {
    if (!confirm('Hapus ' + (type === 'company_logo' ? 'logo' : 'icon') + ' perusahaan?')) return;
    const isLogo = type === 'company_logo';
    try {
        const res = await fetch(`/settings/api/upload/${type}`, { method: 'DELETE' });
        const d = await res.json();
        if (d.success) {
            const previewId = isLogo ? 'logoPreview' : 'iconPreview';
            const phId      = isLogo ? 'logoPlaceholder' : 'iconPlaceholder';
            const removeId  = isLogo ? 'logoRemove' : 'iconRemove';
            const img = document.getElementById(previewId);
            img.src = ''; img.classList.remove('visible');
            const ph = document.getElementById(phId);
            if (ph) ph.style.display = '';
            document.getElementById(removeId).classList.remove('visible');
            showToast('Berhasil dihapus', 'success');
        } else {
            showToast(d.message, 'error');
        }
    } catch(e) {
        showToast('Gagal hapus', 'error');
    }
}

// ── QRIS Image Upload ──
async function uploadQrisImage(input) {
    const file = input.files[0];
    if (!file) return;
    if (file.size > 2 * 1024 * 1024) return showToast('File terlalu besar (maks 2MB)', 'error');
    const fd = new FormData();
    fd.append('file', file);
    try {
        const res = await fetch('/settings/api/upload/qris_image', { method: 'POST', body: fd });
        const d = await res.json();
        if (d.success) {
            document.getElementById('qris-preview').src = d.path + '?t=' + Date.now();
            document.getElementById('qris-preview-wrap').style.display = 'block';
            showToast('✅ Gambar QRIS berhasil diupload', 'success');
        } else {
            showToast(d.message || 'Gagal upload', 'error');
        }
    } catch(e) {
        showToast('Gagal upload: ' + e.message, 'error');
    }
    input.value = '';
}

async function deleteUpload(type) {
    if (!confirm('Hapus gambar QRIS?')) return;
    try {
        const res = await fetch(`/settings/api/upload/${type}`, { method: 'DELETE' });
        const d = await res.json();
        if (d.success) {
            document.getElementById('qris-preview').src = '';
            document.getElementById('qris-preview-wrap').style.display = 'none';
            showToast('Berhasil dihapus', 'success');
        } else {
            showToast(d.message, 'error');
        }
    } catch(e) {
        showToast('Gagal hapus', 'error');
    }
}

function handleDrop(event, type) {
    event.preventDefault();
    const file = event.dataTransfer.files[0];
    if (!file) return;
    const inputId = type === 'company_logo' ? 'logoInput' : 'iconInput';
    const dt = new DataTransfer();
    dt.items.add(file);
    document.getElementById(inputId).files = dt.files;
    uploadFile(document.getElementById(inputId), type);
}
async function save(keys){
    const body={};
    keys.forEach(k=>{
        const el=document.getElementById(k);
        if(!el) return;
        // checkbox → simpan '1' atau '0'
        body[k] = el.type==='checkbox' ? (el.checked?'1':'0') : el.value;
    });
    const res=await fetch('/settings/api/save',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    const d=await res.json();showToast(d.message,d.success?'success':'error');
}
async function testWA(){
    const phone=prompt('Masukkan nomor HP tujuan test (format 628xxx):');
    if(!phone)return;
    const res=await fetch('/settings/api/test-wa',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone,message:'Test from Dino-Bill ✅'})});
    const d=await res.json();showToast(d.message,d.success?'success':'error');
}
async function importCSV(){
    const csv=document.getElementById('csv_import').value;
    if(!csv.trim()){return showToast('<%= t.paste_csv_placeholder %>','error');}
    if(!confirm('<%= t.import_customers %>?'))return;
    const res=await fetch('/import/customers',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({csv_data:csv})});
    const d=await res.json();showToast(d.message,d.success?'success':'error');
    if(d.success)document.getElementById('csv_import').value='';
}
async function testACS(){
    const url=document.getElementById('acs_url').value;
    if(!url)return alert('Masukkan URL ACS dulu');
    showToast('⏳ Testing ACS connection...','success');
    const res=await fetch('/settings/api/test-acs',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({url})});
    const d=await res.json();showToast(d.message,d.success?'success':'error');
}

async function testTelegram(){
    showToast('⏳ Sending test Telegram...','success');
    const res=await fetch('/settings/api/test-telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:'✅ Test Telegram from Dino-Bill'})});
    const d=await res.json();showToast(d.message,d.success?'success':'error');
}
async function testXendit(){
    showToast('⏳ Testing Xendit connection...','success');
    const res=await fetch('/settings/api/test-xendit',{method:'POST',headers:{'Content-Type':'application/json'}});
    const d=await res.json();showToast(d.message,d.success?'success':'error');
}
function copyXenditCallback(){
    const el=document.getElementById('xendit_callback_url');
    el.select();document.execCommand('copy');
    showToast('Callback URL Xendit disalin','success');
}
async function testTripay(silent = false){
    if(!silent) showToast('⏳ Testing Tripay connection...','success');
    const res=await fetch('/settings/api/test-tripay',{method:'POST',headers:{'Content-Type':'application/json'}});
    const d=await res.json();
    if(!silent) showToast(d.message,d.success?'success':'error');
    if (d.success && d.channels) {
        renderTripayChannels(d.channels);
    }
}

function renderTripayChannels(channels) {
    const container = document.getElementById('tripay_channel_list');
    const hidden = document.getElementById('tripay_channels');
    // If hidden is empty, it means "Select All"
    const selected = hidden.value ? hidden.value.split(',').map(s => s.trim().toUpperCase()) : [];
    
    container.innerHTML = '';
    if (channels.length === 0) {
        container.innerHTML = '<div style="color:var(--muted); font-size:12px; grid-column:1/-1; text-align:center;">Tidak ada channel aktif di Tripay.</div>';
        return;
    }

    channels.forEach(ch => {
        // If nothing is selected yet (first time), check all. Otherwise check only selected.
        const isChecked = selected.length === 0 || selected.includes(ch.code.toUpperCase());
        container.innerHTML += `
            <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-size:12px; padding:10px; background:var(--card-bg); border:1px solid var(--border); border-radius:10px; transition: all 0.2s;" class="ch-label">
                <input type="checkbox" class="tripay-ch-checkbox" value="${ch.code}" ${isChecked ? 'checked' : ''} onchange="updateSelectedChannels()">
                <div style="display:flex; flex-direction:column; gap:2px">
                    <span style="font-weight:600">${ch.code}</span>
                    <span style="font-size:10px; color:var(--muted)">${ch.name}</span>
                </div>
            </label>
        `;
    });
    updateSelectedChannels();
}

function updateSelectedChannels() {
    const checkboxes = document.querySelectorAll('.tripay-ch-checkbox');
    const selected = [];
    checkboxes.forEach(cb => {
        if (cb.checked) selected.push(cb.value);
    });
    document.getElementById('tripay_channels').value = selected.join(',');
}
async function saveGitSettings() {
    const url    = document.getElementById('gitRepoUrl').value.trim();
    const branch = document.getElementById('gitBranch').value.trim() || 'main';
    const status = document.getElementById('gitSaveStatus');
    status.textContent = 'Menyimpan...';
    try {
        const res = await fetch('/settings/api/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ git_repo_url: url, git_branch: branch })
        });
        const d = await res.json();
        status.textContent = d.success ? '✅ Tersimpan' : '❌ ' + d.message;
        status.style.color = d.success ? '#10B981' : '#EF4444';
        setTimeout(() => status.textContent = '', 3000);
    } catch(e) {
        status.textContent = '❌ Error: ' + e.message;
        status.style.color = '#EF4444';
    }
}

async function runUpdate(){
    const el=document.getElementById('updateStatus');
    el.style.display='block';el.textContent='<%= t.fetching_update %>';
    try{const res=await fetch('/api/system/update',{method:'POST'});const d=await res.json();el.textContent=d.success?'✅ '+d.message:'❌ '+d.message;}
    catch(e){el.textContent='❌ Connection failed: '+e.message;}
}

async function loadUsers() {
    const res = await fetch('/settings/api/users');
    const d = await res.json();
    if (d.success) {
        const body = document.getElementById('userTableBody');
        body.innerHTML = '';
        const roleColors = {admin:'#EF4444',technician:'#3B82F6',sales:'#10B981'};
        d.data.forEach(u => {
            const rc = roleColors[u.role]||'#94A3B8';
            body.innerHTML += `
                <tr style="border-bottom:1px solid var(--border)">
                    <td style="padding:10px;font-weight:600;">${u.username}</td>
                    <td style="padding:10px"><span style="background:${rc}22;color:${rc};border:1px solid ${rc}44;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:700;">${u.role.toUpperCase()}</span></td>
                    <td style="padding:10px;font-size:12px;color:var(--muted);">${u.phone || '-'}</td>
                    <td style="padding:10px;font-size:11px;color:var(--muted);">${u.telegram_id || '-'}</td>
                    <td style="padding:10px">
                        <div style="display:flex;gap:5px;">
                            <button onclick='openEditUser(${JSON.stringify(u)})' style="width:30px;height:30px;border-radius:7px;border:1px solid var(--border);background:var(--sub-bg);color:var(--muted);cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;">✏️</button>
                            <button onclick="deleteUser(${u.id})" style="width:30px;height:30px;border-radius:7px;border:1px solid rgba(239,68,68,.3);background:rgba(239,68,68,.08);color:#EF4444;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;">🗑</button>
                        </div>
                    </td>
                </tr>`;
        });
    }
}

async function addUser() {
    const username    = document.getElementById('u_user').value;
    const password    = document.getElementById('u_pass').value;
    const role        = document.getElementById('u_role').value;
    const telegram_id = document.getElementById('u_telegram').value;
    const phone       = document.getElementById('u_phone').value;
    if (!username || !password) return showToast('Lengkapi username dan password!','error');
    const res = await fetch('/settings/api/users', {
        method: 'POST', headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ username, password, role, telegram_id, phone })
    });
    const d = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) {
        ['u_user','u_pass','u_telegram','u_phone'].forEach(id => document.getElementById(id).value='');
        loadUsers();
    }
}

function openEditUser(u) {
    document.getElementById('eu_id').value         = u.id;
    document.getElementById('eu_user').value       = u.username;
    document.getElementById('eu_role').value       = u.role;
    document.getElementById('eu_phone').value      = u.phone || '';
    document.getElementById('eu_telegram').value   = u.telegram_id || '';
    document.getElementById('eu_pass').value       = '';
    document.getElementById('editUserModal').style.display = 'flex';
}

async function saveEditUser() {
    const id = document.getElementById('eu_id').value;
    const body = {
        username:    document.getElementById('eu_user').value,
        role:        document.getElementById('eu_role').value,
        phone:       document.getElementById('eu_phone').value,
        telegram_id: document.getElementById('eu_telegram').value,
        password:    document.getElementById('eu_pass').value,
    };
    const res = await fetch(`/settings/api/users/${id}`, {
        method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body)
    });
    const d = await res.json();
    showToast(d.message, d.success?'success':'error');
    if (d.success) { document.getElementById('editUserModal').style.display='none'; loadUsers(); }
}

async function deleteUser(id) {
    if (!confirm('<%= t.confirm_delete_item %>')) return;
    const res = await fetch(`/settings/api/users/${id}`, { method: 'DELETE' });
    const d = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) loadUsers();
}

document.addEventListener('DOMContentLoaded', () => {
    loadUsers();
    const cbInput = document.getElementById('tripay_callback_url');
    if (cbInput) cbInput.value = window.location.origin + '/api/tripay/callback';
    const xenditCbInput = document.getElementById('xendit_callback_url');
    if (xenditCbInput) xenditCbInput.value = window.location.origin + '/api/xendit/callback';
    
    toggleWAFields();
    setInterval(checkWAStatus, 5000);
    checkWAStatus();
    if(document.getElementById('tripay_api_key').value) testTripay(true);
});

function toggleWAFields() {
    const provider = document.getElementById('wa_provider').value;
    const apiFields = document.getElementById('wa_api_fields');
    const localSection = document.getElementById('wa_local_section');
    
    if (provider === 'local') {
        apiFields.style.display = 'none';
        localSection.style.display = 'block';
    } else {
        apiFields.style.display = 'block';
        localSection.style.display = 'none';
    }
}
async function restartWA() {
    if(!confirm('<%= t.restart_wa %>?')) return;
    showToast('⏳ <%= t.restart_wa %>...', 'success');
    try {
        const res = await fetch('/settings/whatsapp-restart', { method: 'POST' });
        const d = await res.json();
        showToast(d.message, 'success');
    } catch (e) {
        showToast('Error: ' + e.message, 'error');
    }
}

async function checkWAStatus() {
    const provider = document.getElementById('wa_provider').value;
    if (provider !== 'local') return;

    try {
        const res = await fetch('/settings/whatsapp-status');
        const d = await res.json();
        
        const badge = document.getElementById('wa_status_badge');
        const qrContainer = document.getElementById('wa_qr_container');
        
        badge.textContent = d.status;
        if (d.status === 'READY' || d.status === 'AUTHENTICATED') {
            badge.style.background = 'rgba(16,185,129,.15)';
            badge.style.color = '#10B981';
            qrContainer.innerHTML = '✅ Connected';
        } else if (d.status === 'INITIALIZING') {
            badge.style.background = 'rgba(245,158,11,.15)';
            badge.style.color = '#F59E0B';
            qrContainer.innerHTML = '⏳ Booting...';
        } else {
            badge.style.background = 'rgba(239,68,68,.15)';
            badge.style.color = '#EF4444';
            if (d.qr) {
                qrContainer.innerHTML = `<img src="${d.qr}" style="width:100%; height:100%; object-fit:contain">`;
            } else {
                qrContainer.innerHTML = 'Memuat QR...';
            }
        }
    } catch (e) {
        console.error('Failed to fetch WA status:', e);
    }
}

function copyCallback() {
    const el = document.getElementById('tripay_callback_url');
    el.select();
    document.execCommand('copy');
    showToast('URL Callback copied', 'success');
}

function showToast(msg,type){const t=document.getElementById('toast');t.textContent=msg;t.style.borderColor=type==='success'?'rgba(16,185,129,.4)':'rgba(239,68,68,.4)';t.style.color=type==='success'?'#10B981':'#EF4444';t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3500);}
</script>
<!-- Modal Edit User -->
