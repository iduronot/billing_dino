<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* ── Tab Navigation ── */
        .dash-tabs { display:flex; gap:4px; background:var(--sub-bg); border:1px solid var(--border); border-radius:14px; padding:5px; margin-bottom:22px; flex-wrap:wrap; }
        .dash-tab  { flex:1; min-width:140px; display:flex; align-items:center; justify-content:center; gap:8px; padding:10px 16px; border-radius:10px; font-size:13px; font-weight:600; color:var(--muted); cursor:pointer; border:none; background:none; font-family:'Outfit',sans-serif; transition:all .2s; white-space:nowrap; }
        .dash-tab:hover { color:var(--text); background:var(--card-bg); }
        .dash-tab.active { background:var(--card-bg); color:var(--text); box-shadow:0 2px 8px rgba(0,0,0,.15); border:1px solid var(--border); }
        .dash-tab .tab-badge { background:rgba(239,68,68,.15); color:#EF4444; border-radius:20px; padding:1px 7px; font-size:11px; font-weight:800; }
        .tab-pane { display:none; }
        .tab-pane.active { display:block; }

        /* ── Date Banner ── */
        .date-banner { background:linear-gradient(135deg,rgba(59,130,246,0.12),rgba(139,92,246,0.12)); border:1px solid rgba(59,130,246,0.2); border-radius:18px; padding:20px 28px; margin-bottom:22px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px; }
        .date-clock { font-size:38px; font-weight:800; font-variant-numeric:tabular-nums; background:linear-gradient(135deg,#60A5FA,#A78BFA); -webkit-background-clip:text; -webkit-text-fill-color:transparent; line-height:1; }
        .date-detail { display:flex; flex-direction:column; gap:3px; }
        .date-day  { font-size:20px; font-weight:700; }
        .date-full { font-size:13px; color:var(--muted); }
        .date-filter { display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
        .date-filter label { font-size:12px; color:var(--muted); font-weight:600; }
        .date-filter input[type=date] { background:var(--sub-bg); border:1px solid var(--border); color:var(--text); border-radius:10px; padding:8px 12px; font-size:13px; font-family:'Outfit',sans-serif; outline:none; }
        .date-filter .btn-filter { background:var(--primary); color:white; border:none; border-radius:10px; padding:8px 18px; font-size:13px; font-weight:600; cursor:pointer; font-family:'Outfit',sans-serif; }
        .date-filter .btn-reset  { background:var(--sub-bg); border:1px solid var(--border); color:var(--muted); border-radius:10px; padding:8px 14px; font-size:12px; cursor:pointer; font-family:'Outfit',sans-serif; text-decoration:none; display:inline-flex; align-items:center; gap:5px; }

        /* ── Stats Grid ── */
        .stats-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:14px; margin-bottom:22px; }
        .stat-card { background:var(--card-bg); border:1px solid var(--border); border-radius:16px; padding:20px; position:relative; overflow:hidden; transition:transform .2s; }
        .stat-card:hover { transform:translateY(-3px); }
        .stat-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
        .stat-card.blue::before   { background:linear-gradient(90deg,#3B82F6,#6366F1); }
        .stat-card.green::before  { background:linear-gradient(90deg,#10B981,#34D399); }
        .stat-card.orange::before { background:linear-gradient(90deg,#F59E0B,#FCD34D); }
        .stat-card.red::before    { background:linear-gradient(90deg,#EF4444,#F87171); }
        .stat-card.purple::before { background:linear-gradient(90deg,#8B5CF6,#A78BFA); }
        .stat-card.teal::before   { background:linear-gradient(90deg,#06B6D4,#22D3EE); }
        .stat-label { font-size:12px; color:var(--muted); margin-bottom:8px; font-weight:500; }
        .stat-value { font-size:28px; font-weight:800; line-height:1; }
        .stat-sub   { font-size:11px; color:var(--muted); margin-top:7px; }

        /* ── Cards / Charts ── */
        .charts-grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:18px; margin-bottom:18px; }
        .charts-grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:18px; margin-bottom:18px; }
        .card { background:var(--card-bg); border:1px solid var(--border); border-radius:16px; padding:22px; margin-bottom:18px; }
        .card:last-child { margin-bottom:0; }
        .card-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; }
        .card-title  { font-size:15px; font-weight:700; margin:0; }

        /* ── OLT ── */
        .olt-section { background:var(--card-bg); border:1px solid var(--border); border-radius:18px; padding:24px; margin-bottom:18px; }
        .olt-charts-row { display:grid; grid-template-columns:200px 1fr 1fr; gap:24px; align-items:start; }
        .signal-legend { display:flex; flex-direction:column; gap:8px; margin-top:16px; }
        .sig-item { display:flex; align-items:center; justify-content:space-between; gap:8px; font-size:12px; }
        .sig-dot   { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
        .sig-label { color:var(--muted); flex:1; }
        .sig-val   { font-weight:700; }
        .olt-progress { margin-bottom:14px; }
        .olt-progress-label { display:flex; justify-content:space-between; font-size:12px; margin-bottom:5px; }
        .olt-progress-label span:first-child { font-weight:600; max-width:150px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .olt-progress-label span:last-child  { color:var(--muted); }
        .prog-bar  { height:7px; background:var(--sub-bg); border-radius:4px; overflow:hidden; }
        .prog-fill { height:100%; border-radius:4px; background:linear-gradient(90deg,#10B981,#34D399); transition:width .6s; }
        .prog-fill.warn { background:linear-gradient(90deg,#F59E0B,#FCD34D); }
        .prog-fill.bad  { background:linear-gradient(90deg,#EF4444,#F87171); }

        /* ── ACS device list ── */
        .acs-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:10px; }
        .acs-card { background:var(--sub-bg); border:1px solid var(--border); border-radius:12px; padding:12px 14px; display:flex; align-items:center; gap:12px; }
        .acs-dot  { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
        .acs-dot.online  { background:#10B981; box-shadow:0 0 6px #10B981; }
        .acs-dot.offline { background:#EF4444; }

        /* ── Tables ── */
        .table-wrap { overflow-x:auto; }
        table { width:100%; border-collapse:collapse; }
        th { color:var(--muted); font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.6px; padding:11px 14px; text-align:left; background:var(--sub-bg); }
        td { padding:11px 14px; border-bottom:1px solid var(--border); font-size:13px; }
        tr:last-child td { border-bottom:none; }
        tr:hover td { background:var(--hover-bg); }

        /* ── Ticket cards (Tab 4) ── */
        .tech-row { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:12px; margin-bottom:18px; }
        .tech-card { background:var(--card-bg); border:1px solid var(--border); border-radius:14px; padding:16px; }
        .tech-avatar { width:40px; height:40px; border-radius:50%; background:rgba(99,102,241,.15); color:#818CF8; display:flex; align-items:center; justify-content:center; font-size:16px; font-weight:800; margin-bottom:10px; }
        .tech-name { font-size:13px; font-weight:700; margin-bottom:8px; }
        .tech-stats { display:flex; gap:8px; font-size:12px; }
        .tstat { text-align:center; flex:1; }
        .tstat-val { font-size:18px; font-weight:800; line-height:1; }
        .tstat-lbl { color:var(--muted); font-size:10px; margin-top:2px; }

        /* ── Status badges ── */
        .badge { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; }
        .badge-paid      { background:rgba(16,185,129,.12); color:#10B981; border:1px solid rgba(16,185,129,.25); }
        .badge-unpaid    { background:rgba(245,158,11,.12);  color:#F59E0B; border:1px solid rgba(245,158,11,.25); }
        .badge-active    { background:rgba(16,185,129,.12); color:#10B981; border:1px solid rgba(16,185,129,.25); }
        .badge-isolated  { background:rgba(239,68,68,.12);  color:#EF4444; border:1px solid rgba(239,68,68,.25); }
        .badge-open      { background:rgba(239,68,68,.12);  color:#EF4444; border:1px solid rgba(239,68,68,.25); }
        .badge-in_progress { background:rgba(245,158,11,.12); color:#F59E0B; border:1px solid rgba(245,158,11,.25); }
        .badge-resolved  { background:rgba(16,185,129,.12); color:#10B981; border:1px solid rgba(16,185,129,.25); }
        .badge-closed    { background:var(--sub-bg); color:var(--muted); border:1px solid var(--border); }

        /* ── Misc ── */
        .alert-overdue { background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.25); color:#EF4444; padding:13px 18px; border-radius:12px; margin-bottom:18px; font-size:14px; display:flex; align-items:center; gap:10px; }
        .alert-overdue a { color:var(--primary); font-weight:600; margin-left:auto; text-decoration:none; }
        .empty-hint { text-align:center; padding:40px; color:var(--muted); font-size:13px; }

        /* ── Due date urgency color ── */
        .due-today   { color:#EF4444; font-weight:700; }
        .due-soon    { color:#F59E0B; font-weight:600; }
        .due-normal  { color:var(--muted); }

        @media(max-width:1100px) { .charts-grid-2, .olt-charts-row { grid-template-columns:1fr; } .charts-grid-3 { grid-template-columns:1fr 1fr; } }
        @media(max-width:768px)  { .stats-grid { grid-template-columns:repeat(2,1fr); } .charts-grid-3 { grid-template-columns:1fr; } .date-banner { flex-direction:column; align-items:flex-start; } .dash-tab { font-size:12px; padding:8px 10px; } }
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: 'Dashboard' }) %>
    <div class="content">

        <!-- ══ TAB NAVIGATION ══ -->
        <%
            const fmtRp = n => 'Rp ' + Math.floor(Number(n)||0).toLocaleString('id-ID');
            const n = v => Number(v) || 0;
            const overdueCount  = n(stats.overdueInvoices);
            const dueWeekCount  = (dueThisWeek||[]).length;
            const openTickCount = n(ticketStats.open);
        %>
        <div class="dash-tabs">
            <button class="dash-tab active" data-tab="overview" onclick="switchTab('overview',this)">
                <i class="fas fa-chart-line"></i> Overview
            </button>
            <button class="dash-tab" data-tab="olt" onclick="switchTab('olt',this)">
                <i class="fas fa-satellite-dish"></i> OLT & GenieACS
            </button>
            <button class="dash-tab" data-tab="billing" onclick="switchTab('billing',this)">
                <i class="fas fa-file-invoice-dollar"></i> Tagihan & Isolir
                <% if (dueWeekCount + overdueCount > 0) { %>
                <span class="tab-badge"><%= dueWeekCount + overdueCount %></span>
                <% } %>
            </button>
            <button class="dash-tab" data-tab="tickets" onclick="switchTab('tickets',this)">
                <i class="fas fa-ticket-alt"></i> Tiket Teknisi
                <% if (openTickCount > 0) { %>
                <span class="tab-badge"><%= openTickCount %></span>
                <% } %>
            </button>
        </div>

        <!-- ════════════════════════════════════════
             TAB 1 — OVERVIEW
        ════════════════════════════════════════ -->
        <div class="tab-pane active" id="tab-overview">

            <!-- Date Banner -->
            <div class="date-banner">
                <div style="display:flex; align-items:center; gap:20px;">
                    <div class="date-clock" id="liveClock">--:--</div>
                    <div class="date-detail">
                        <div class="date-day" id="liveDay">--</div>
                        <div class="date-full" id="liveDate">--</div>
                    </div>
                </div>
                <form method="GET" action="/" class="date-filter">
                    <label>Dari</label>
                    <input type="date" name="dateFrom" value="<%= dateFrom %>" max="<%= dateTo %>">
                    <label>Sampai</label>
                    <input type="date" name="dateTo"   value="<%= dateTo %>"   min="<%= dateFrom %>">
                    <button type="submit" class="btn-filter"><i class="fas fa-filter"></i> Terapkan</button>
                    <a href="/" class="btn-reset"><i class="fas fa-rotate-left"></i> Reset</a>
                </form>
            </div>

            <!-- Stats Cards -->
            <div class="stats-grid">
                <div class="stat-card blue">
                    <div class="stat-label">Total Pelanggan</div>
                    <div class="stat-value"><%= n(stats.totalCustomers) %></div>
                    <div class="stat-sub"><%= n(stats.activeCustomers) %> aktif · <%= n(stats.isolatedCustomers) %> isolir</div>
                </div>
                <div class="stat-card green">
                    <div class="stat-label">Pendapatan <span style="font-size:10px;opacity:.7;">(filter)</span></div>
                    <div class="stat-value" style="font-size:18px;"><%= fmtRp(stats.totalRevenue) %></div>
                    <div class="stat-sub"><%= dateFrom %> s/d <%= dateTo %></div>
                </div>
                <div class="stat-card teal">
                    <div class="stat-label">Pelanggan Baru <span style="font-size:10px;opacity:.7;">(filter)</span></div>
                    <div class="stat-value"><%= n(stats.newCustomers) %></div>
                    <div class="stat-sub">dalam rentang tanggal</div>
                </div>
                <div class="stat-card orange">
                    <div class="stat-label">Tagihan Belum Bayar</div>
                    <div class="stat-value"><%= n(stats.unpaidInvoices) %></div>
                    <div class="stat-sub"><%= n(stats.overdueInvoices) %> sudah jatuh tempo</div>
                </div>
                <div class="stat-card red">
                    <div class="stat-label">Tiket Terbuka</div>
                    <div class="stat-value"><%= n(stats.openTickets) %></div>
                    <div class="stat-sub">perlu ditangani</div>
                </div>
                <div class="stat-card purple">
                    <div class="stat-label">ONU Online</div>
                    <div class="stat-value"><%= n(oltStats.online) %></div>
                    <div class="stat-sub">dari <%= n(oltStats.total) %> total ONU</div>
                </div>
                <div class="stat-card" style="border-top:3px solid #06B6D4;">
                    <div class="stat-label">ONT Online <span style="font-size:10px;opacity:.7;">(GenieACS)</span></div>
                    <div class="stat-value"><%= n(acsStats&&acsStats.online) %></div>
                    <div class="stat-sub"><%= n(acsStats&&acsStats.linked) %> terhubung ke pelanggan</div>
                </div>
                <a class="stat-card" href="/expenses" style="border-top:3px solid #EF4444; text-decoration:none;">
                    <div class="stat-label">Pengeluaran Bulan Ini</div>
                    <div class="stat-value" style="font-size:16px;"><%= fmtRp(expenseStats&&expenseStats.totalExpense) %></div>
                    <div class="stat-sub"><%= n(expenseStats&&expenseStats.totalCount) %> transaksi</div>
                </a>
            </div>

            <!-- Alert overdue -->
            <% if (overdueCount > 0) { %>
            <div class="alert-overdue">
                <i class="fas fa-triangle-exclamation"></i>
                <strong><%= overdueCount %></strong> tagihan melewati jatuh tempo
                <a href="#" onclick="switchTab('billing', document.querySelector('[data-tab=billing]'));return false;">Lihat Detail →</a>
            </div>
            <% } %>

            <!-- Grafik Revenue & Pelanggan -->
            <div class="charts-grid-2">
                <div class="card" style="margin:0;">
                    <div class="card-header"><h2 class="card-title">📈 Pendapatan 6 Bulan</h2></div>
                    <canvas id="revenueChart" height="190"></canvas>
                </div>
                <div class="card" style="margin:0;">
                    <div class="card-header"><h2 class="card-title">👥 Pelanggan Baru 6 Bulan</h2></div>
                    <canvas id="customerChart" height="190"></canvas>
                </div>
            </div>

            <!-- Traffic -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">🚀 Traffic Jaringan Real-time</h2>
                    <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
                        <select id="interfaceSelector" style="background:var(--sub-bg); color:var(--text); border:1px solid var(--border); border-radius:8px; padding:6px 10px; font-size:12px; outline:none; font-family:'Outfit',sans-serif;">
                            <option value="ether1">ether1</option>
                            <option value="ether2">ether2</option>
                            <option value="ether3">ether3</option>
                            <option value="sfp-sfpplus1">sfp-sfpplus1</option>
                            <option value="combo1">combo1</option>
                            <option value="bridge">bridge</option>
                        </select>
                        <span style="color:#10B981; font-size:13px; font-weight:600;"><i class="fas fa-arrow-down"></i> DL: <span id="totalRx">0 Mbps</span></span>
                        <span style="color:#3B82F6; font-size:13px; font-weight:600;"><i class="fas fa-arrow-up"></i> UL: <span id="totalTx">0 Mbps</span></span>
                    </div>
                </div>
                <canvas id="trafficChart" height="90"></canvas>
            </div>

            <!-- Invoice & Pelanggan terbaru -->
            <div class="charts-grid-2">
                <div class="card" style="margin:0;">
                    <div class="card-header">
                        <h2 class="card-title">🧾 Invoice Terbaru</h2>
                        <a href="/billing" class="btn btn-primary" style="font-size:12px;padding:6px 14px;">Lihat Semua</a>
                    </div>
                    <div class="table-wrap">
                        <table>
                            <thead><tr><th>Pelanggan</th><th>Jumlah</th><th>Status</th></tr></thead>
                            <tbody>
                            <% if (recentInvoices&&recentInvoices.length>0) { %>
                                <% recentInvoices.forEach(i => { %>
                                <tr>
                                    <td style="font-weight:500;"><%= i.customer_name||'-' %></td>
                                    <td><%= fmtRp(i.amount) %></td>
                                    <td><span class="badge badge-<%= i.status %>"><%= i.status==='paid'?'Lunas':'Belum' %></span></td>
                                </tr>
                                <% }) %>
                            <% } else { %><tr><td colspan="3" class="empty-hint">Tidak ada data</td></tr><% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card" style="margin:0;">
                    <div class="card-header">
                        <h2 class="card-title">👤 Pelanggan Terbaru</h2>
                        <a href="/customers" class="btn btn-primary" style="font-size:12px;padding:6px 14px;">Lihat Semua</a>
                    </div>
                    <div class="table-wrap">
                        <table>
                            <thead><tr><th>Nama</th><th>Paket</th><th>Status</th></tr></thead>
                            <tbody>
                            <% if (recentCustomers&&recentCustomers.length>0) { %>
                                <% recentCustomers.forEach(c => { %>
                                <tr>
                                    <td style="font-weight:500;"><%= c.name %></td>
                                    <td style="font-size:12px;color:var(--muted);"><%= c.package_name||'-' %></td>
                                    <td><span class="badge badge-<%= c.status %>"><%= c.status==='active'?'Aktif':'Isolir' %></span></td>
                                </tr>
                                <% }) %>
                            <% } else { %><tr><td colspan="3" class="empty-hint">Tidak ada data</td></tr><% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Distribusi Paket -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">📦 Distribusi Paket Internet</h2>
                    <a href="/packages" class="btn btn-primary" style="font-size:12px;padding:6px 14px;">Kelola Paket</a>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; align-items:start;">
                    <div style="display:flex; flex-direction:column; align-items:center;">
                        <canvas id="packageDonut" width="220" height="220"></canvas>
                        <div id="packageLegend" style="display:flex;flex-direction:column;gap:6px;margin-top:14px;width:100%;max-width:260px;"></div>
                    </div>
                    <div class="table-wrap">
                        <table>
                            <thead><tr><th>Paket</th><th>Harga</th><th>Pelanggan</th><th>Aktif</th><th>Isolir</th></tr></thead>
                            <tbody>
                            <% if (packageDist&&packageDist.length>0) { %>
                                <% packageDist.forEach(p => { const pct = p.total_customers>0?Math.round((p.active/p.total_customers)*100):0; %>
                                <tr>
                                    <td>
                                        <div style="font-weight:600;font-size:13px;"><%= p.package_name %></div>
                                        <% if(p.speed_limit){%><div style="font-size:11px;color:var(--muted);"><%= p.speed_limit %></div><%}%>
                                    </td>
                                    <td style="font-size:12px;"><%= fmtRp(p.price) %></td>
                                    <td>
                                        <span style="font-weight:700;font-size:14px;"><%= p.total_customers %></span>
                                        <div style="height:4px;background:var(--sub-bg);border-radius:2px;margin-top:5px;"><div style="height:100%;width:<%= pct %>%;background:var(--primary);border-radius:2px;"></div></div>
                                    </td>
                                    <td><span style="color:#10B981;font-weight:600;"><%= p.active||0 %></span></td>
                                    <td><span style="color:#EF4444;font-weight:600;"><%= p.isolated||0 %></span></td>
                                </tr>
                                <% }) %>
                            <% } else { %><tr><td colspan="5" class="empty-hint">Belum ada data paket</td></tr><% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Pengeluaran vs Pemasukan -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">💸 Pengeluaran vs Pemasukan</h2>
                    <a href="/expenses" class="btn btn-primary" style="font-size:12px;padding:6px 14px;">Kelola</a>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:20px; align-items:start;">
                    <div style="grid-column:1/3;"><canvas id="expenseCompChart" height="100"></canvas></div>
                    <div style="display:flex; flex-direction:column; gap:10px;">
                        <% const estProfit = (stats.totalRevenue||0) - ((expenseStats&&expenseStats.totalExpense)||0); const isProfit = estProfit>=0; %>
                        <div style="background:var(--sub-bg);border-radius:12px;padding:14px;">
                            <div style="font-size:11px;color:var(--muted);font-weight:600;margin-bottom:6px;text-transform:uppercase;">Pemasukan Bulan Ini</div>
                            <div style="font-size:18px;font-weight:800;color:#10B981;"><%= fmtRp(stats.totalRevenue) %></div>
                        </div>
                        <div style="background:var(--sub-bg);border-radius:12px;padding:14px;">
                            <div style="font-size:11px;color:var(--muted);font-weight:600;margin-bottom:6px;text-transform:uppercase;">Pengeluaran Bulan Ini</div>
                            <div style="font-size:18px;font-weight:800;color:#EF4444;"><%= fmtRp((expenseStats&&expenseStats.totalExpense)||0) %></div>
                        </div>
                        <div style="background:<%= isProfit?'rgba(16,185,129,.1)':'rgba(239,68,68,.1)' %>;border:1px solid <%= isProfit?'rgba(16,185,129,.2)':'rgba(239,68,68,.2)' %>;border-radius:12px;padding:14px;">
                            <div style="font-size:11px;color:var(--muted);font-weight:600;margin-bottom:6px;text-transform:uppercase;">Estimasi Laba Bersih</div>
                            <div style="font-size:20px;font-weight:800;color:<%= isProfit?'#10B981':'#EF4444' %>;"><%= isProfit?'+':'-' %> <%= fmtRp(Math.abs(estProfit)) %></div>
                            <div style="font-size:11px;color:var(--muted);margin-top:4px;"><%= isProfit?'✅ Untung':'❌ Defisit' %> bulan ini</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Router -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">🔌 Router</h2>
                    <a href="/mikrotik" class="btn btn-primary" style="font-size:12px;padding:6px 14px;">Kelola</a>
                </div>
                <div style="display:flex; align-items:center; gap:16px;">
                    <span style="color:var(--muted);font-size:13px;">Router aktif:</span>
                    <span style="font-weight:700;font-size:15px;"><%= routerStats.online||0 %> / <%= routerStats.total||0 %></span>
                    <div style="flex:1;height:8px;background:var(--sub-bg);border-radius:4px;overflow:hidden;max-width:300px;">
                        <div style="height:100%;width:<%= routerStats.total>0?Math.round((routerStats.online/routerStats.total)*100):0 %>%;background:var(--primary);border-radius:4px;transition:width .5s;"></div>
                    </div>
                </div>
            </div>

        </div><!-- /tab-overview -->


        <!-- ════════════════════════════════════════
             TAB 2 — OLT & GENIEACS
        ════════════════════════════════════════ -->
        <div class="tab-pane" id="tab-olt">

            <!-- Stats row OLT -->
            <%
                const oltTotal   = n(oltStats.total);
                const oltOnline  = n(oltStats.online);
                const oltOffline = oltTotal - oltOnline;
                const oltPct     = oltTotal > 0 ? Math.round((oltOnline/oltTotal)*100) : 0;
                const acsOnlineCnt  = n(acsStats&&acsStats.online);
                const acsLinkedCnt  = n(acsStats&&acsStats.linked);
                const pppoeActive   = n(pppoeStats&&pppoeStats.active);
                const pppoeIsolated = n(pppoeStats&&pppoeStats.isolated);
                const pppoeTotal    = n(pppoeStats&&pppoeStats.with_pppoe);
            %>
            <div class="stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(150px,1fr));">
                <div class="stat-card purple">
                    <div class="stat-label">Total ONU</div>
                    <div class="stat-value"><%= oltTotal %></div>
                    <div class="stat-sub">terdaftar di OLT</div>
                </div>
                <div class="stat-card green">
                    <div class="stat-label">ONU Online</div>
                    <div class="stat-value"><%= oltOnline %></div>
                    <div class="stat-sub"><%= oltPct %>% uptime</div>
                </div>
                <div class="stat-card red">
                    <div class="stat-label">ONU Offline</div>
                    <div class="stat-value"><%= oltOffline %></div>
                    <div class="stat-sub">perlu pemeriksaan</div>
                </div>
                <div class="stat-card blue">
                    <div class="stat-label">ONT GenieACS Online</div>
                    <div class="stat-value"><%= acsOnlineCnt %></div>
                    <div class="stat-sub"><%= acsLinkedCnt %> terhubung pelanggan</div>
                </div>
                <div class="stat-card green">
                    <div class="stat-label">PPPoE Aktif</div>
                    <div class="stat-value"><%= pppoeActive %></div>
                    <div class="stat-sub">dari <%= pppoeTotal %> akun PPPoE</div>
                </div>
                <div class="stat-card red">
                    <div class="stat-label">PPPoE Diisolir</div>
                    <div class="stat-value"><%= pppoeIsolated %></div>
                    <div class="stat-sub">koneksi diputus</div>
                </div>
            </div>

            <!-- ONU Status Donut + Per OLT + Sinyal -->
            <div class="olt-section">
                <div style="font-size:16px;font-weight:700;margin:0 0 20px;display:flex;align-items:center;gap:10px;">
                    <i class="fas fa-satellite-dish" style="color:var(--primary);"></i>
                    Monitoring OLT & ONU
                    <a href="/olt" class="btn" style="margin-left:auto;background:var(--sub-bg);border:1px solid var(--border);color:var(--text);font-size:12px;padding:6px 14px;border-radius:8px;text-decoration:none;">Detail OLT →</a>
                </div>
                <div class="olt-charts-row">
                    <div>
                        <p style="font-size:12px;color:var(--muted);font-weight:600;text-align:center;margin:0 0 10px;">Status ONU</p>
                        <canvas id="onuDonut" width="180" height="180"></canvas>
                        <div style="display:flex;gap:12px;justify-content:center;margin-top:12px;font-size:12px;">
                            <span><span style="color:#10B981;">●</span> Online: <b><%= oltStats.online||0 %></b></span>
                            <span><span style="color:#EF4444;">●</span> Offline: <b><%= (oltStats.total||0)-(oltStats.online||0) %></b></span>
                        </div>
                    </div>
                    <div>
                        <p style="font-size:12px;color:var(--muted);font-weight:600;margin:0 0 12px;">ONU per Perangkat OLT</p>
                        <% if (oltPerDevice&&oltPerDevice.length>0) { %>
                            <% oltPerDevice.forEach(o => { const pct=o.total>0?Math.round((o.online/o.total)*100):0; const cls=pct>=80?'':(pct>=50?'warn':'bad'); %>
                            <div class="olt-progress">
                                <div class="olt-progress-label">
                                    <span title="<%= o.olt_name %>"><%= o.olt_name %></span>
                                    <span><%= o.online %>/<%= o.total %> (<%= pct %>%)</span>
                                </div>
                                <div class="prog-bar"><div class="prog-fill <%= cls %>" style="width:<%= pct %>%;"></div></div>
                            </div>
                            <% }) %>
                        <% } else { %><p style="color:var(--muted);font-size:13px;">Belum ada data OLT.</p><% } %>
                    </div>
                    <div>
                        <p style="font-size:12px;color:var(--muted);font-weight:600;margin:0 0 10px;">Kualitas Sinyal RX</p>
                        <canvas id="signalChart" height="160"></canvas>
                        <div class="signal-legend">
                            <div class="sig-item"><span class="sig-dot" style="background:#10B981;"></span><span class="sig-label">Excellent (&gt; -20 dBm)</span><span class="sig-val"><%= signalDist.excellent||0 %></span></div>
                            <div class="sig-item"><span class="sig-dot" style="background:#34D399;"></span><span class="sig-label">Good (-20 ~ -25 dBm)</span><span class="sig-val"><%= signalDist.good||0 %></span></div>
                            <div class="sig-item"><span class="sig-dot" style="background:#F59E0B;"></span><span class="sig-label">Fair (-25 ~ -27 dBm)</span><span class="sig-val"><%= signalDist.fair||0 %></span></div>
                            <div class="sig-item"><span class="sig-dot" style="background:#F97316;"></span><span class="sig-label">Weak (-27 ~ -30 dBm)</span><span class="sig-val"><%= signalDist.weak||0 %></span></div>
                            <div class="sig-item"><span class="sig-dot" style="background:#EF4444;"></span><span class="sig-label">Bad (≤ -30 dBm)</span><span class="sig-val"><%= signalDist.bad||0 %></span></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- GenieACS detail -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">📡 Perangkat GenieACS (ONT/CPE)</h2>
                    <a href="/acs" class="btn btn-primary" style="font-size:12px;padding:6px 14px;">Detail GenieACS →</a>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; align-items:center;">
                    <div>
                        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px;">
                            <div style="background:var(--sub-bg);border-radius:12px;padding:14px;text-align:center;">
                                <div style="font-size:26px;font-weight:800;color:#10B981;"><%= acsOnlineCnt %></div>
                                <div style="font-size:11px;color:var(--muted);margin-top:4px;">Online</div>
                            </div>
                            <div style="background:var(--sub-bg);border-radius:12px;padding:14px;text-align:center;">
                                <div style="font-size:26px;font-weight:800;color:#EF4444;"><%= n(acsStats&&acsStats.total) - acsOnlineCnt %></div>
                                <div style="font-size:11px;color:var(--muted);margin-top:4px;">Offline</div>
                            </div>
                            <div style="background:var(--sub-bg);border-radius:12px;padding:14px;text-align:center;">
                                <div style="font-size:26px;font-weight:800;color:#818CF8;"><%= acsLinkedCnt %></div>
                                <div style="font-size:11px;color:var(--muted);margin-top:4px;">Terhubung</div>
                            </div>
                        </div>
                        <div style="height:8px;background:var(--sub-bg);border-radius:4px;overflow:hidden;">
                            <div style="height:100%;width:<%= n(acsStats&&acsStats.total)>0?Math.round((acsOnlineCnt/n(acsStats&&acsStats.total))*100):0 %>%;background:linear-gradient(90deg,#10B981,#34D399);border-radius:4px;"></div>
                        </div>
                        <div style="font-size:11px;color:var(--muted);margin-top:6px;">
                            <%= n(acsStats&&acsStats.total)>0?Math.round((acsOnlineCnt/n(acsStats&&acsStats.total))*100):0 %>% perangkat online
                        </div>
                    </div>
                    <canvas id="acsDonut" width="160" height="160" style="display:block;margin:0 auto;"></canvas>
                </div>
            </div>

            <!-- PPPoE per Router -->
            <div class="card">
                <div class="card-header">
                    <div>
                        <h2 class="card-title">🔌 PPPoE per Router MikroTik</h2>
                        <div id="pppoe-last-update" style="font-size:11px;color:var(--muted);margin-top:2px;"></div>
                    </div>
                    <div style="display:flex;gap:8px;align-items:center;">
                        <button onclick="loadPPPoELive()" class="btn btn-secondary" id="btnRefreshPPPoE" style="font-size:12px;padding:6px 14px;">
                            <i class="fas fa-sync-alt"></i> Refresh Live
                        </button>
                        <a href="/mikrotik" class="btn btn-primary" style="font-size:12px;padding:6px 14px;">Kelola Router</a>
                    </div>
                </div>

                <% if ((pppoePerRouter||[]).length > 0) { %>
                <div id="pppoe-router-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px;padding:4px 0 6px;">
                <% pppoePerRouter.forEach(r => {
                    const total    = n(r.total_users);
                    const active   = n(r.active_users);
                    const isolated = n(r.isolated_users);
                    const pct      = total > 0 ? Math.round((active/total)*100) : 0;
                    const isUp     = r.status === 'active';
                    const barColor = pct >= 80 ? '#10B981' : pct >= 50 ? '#F59E0B' : '#EF4444';
                %>
                <div class="pppoe-router-card" data-router-id="<%= r.id %>"
                     data-total="<%= total %>" data-active="<%= active %>" data-isolated="<%= isolated %>"
                     style="background:var(--sub-bg);border:1px solid var(--border);border-radius:14px;padding:16px 18px;display:flex;flex-direction:column;gap:13px;position:relative;overflow:hidden;">

                    <!-- Accent bar top -->
                    <div class="pppoe-accent" style="position:absolute;top:0;left:0;right:0;height:3px;background:<%= isUp?'linear-gradient(90deg,#10B981,#34D399)':'linear-gradient(90deg,#EF4444,#F87171)' %>;border-radius:14px 14px 0 0;"></div>

                    <!-- Header: nama + status -->
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:4px;">
                        <div style="display:flex;align-items:center;gap:9px;">
                            <div style="width:36px;height:36px;border-radius:10px;background:<%= isUp?'rgba(16,185,129,.15)':'rgba(239,68,68,.12)' %>;display:flex;align-items:center;justify-content:center;font-size:18px;">🖥️</div>
                            <div>
                                <div style="font-weight:700;font-size:14px;line-height:1.2;"><%= r.router_name %></div>
                                <div style="font-size:11px;color:var(--muted);font-family:monospace;margin-top:1px;"><%= r.ip_address||'-' %></div>
                            </div>
                        </div>
                        <span style="font-size:11px;font-weight:600;padding:3px 9px;border-radius:20px;background:<%= isUp?'rgba(16,185,129,.15)':'rgba(239,68,68,.12)' %>;color:<%= isUp?'#10B981':'#EF4444' %>;">
                            <span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:<%= isUp?'#10B981':'#EF4444' %>;margin-right:4px;vertical-align:middle;<%= isUp?'box-shadow:0 0 5px #10B981':'' %>"></span>
                            <%= isUp?'Online':'Offline' %>
                        </span>
                    </div>

                    <!-- Donut chart + Stats list -->
                    <div style="display:flex;gap:14px;align-items:center;">
                        <!-- Donut -->
                        <div style="position:relative;width:110px;height:110px;flex-shrink:0;">
                            <canvas id="pppoe-chart-<%= r.id %>" width="110" height="110"></canvas>
                            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none;line-height:1;">
                                <div class="live-pppoe-val" data-router-id="<%= r.id %>" style="font-size:24px;font-weight:800;color:#818CF8;">—</div>
                                <div style="font-size:9px;color:var(--muted);margin-top:1px;">live</div>
                            </div>
                        </div>

                        <!-- Stats list -->
                        <div style="flex:1;display:flex;flex-direction:column;gap:6px;">
                            <div style="display:flex;justify-content:space-between;align-items:center;">
                                <span style="font-size:12px;color:var(--text);display:flex;align-items:center;gap:6px;">
                                    <span style="width:9px;height:9px;border-radius:50%;background:#818CF8;display:inline-block;flex-shrink:0;"></span>Sesi Live
                                </span>
                                <span class="live-stat-active" data-router-id="<%= r.id %>" style="font-weight:700;color:#818CF8;font-size:15px;">—</span>
                            </div>
                            <div style="display:flex;justify-content:space-between;align-items:center;">
                                <span style="font-size:12px;color:var(--text);display:flex;align-items:center;gap:6px;">
                                    <span style="width:9px;height:9px;border-radius:50%;background:#10B981;display:inline-block;flex-shrink:0;"></span>Aktif DB
                                </span>
                                <span style="font-weight:700;color:#10B981;font-size:15px;"><%= active %></span>
                            </div>
                            <div style="display:flex;justify-content:space-between;align-items:center;">
                                <span style="font-size:12px;color:var(--text);display:flex;align-items:center;gap:6px;">
                                    <span style="width:9px;height:9px;border-radius:50%;background:#EF4444;display:inline-block;flex-shrink:0;"></span>Isolir
                                </span>
                                <span style="font-weight:700;color:#EF4444;font-size:15px;"><%= isolated %></span>
                            </div>
                            <div style="display:flex;justify-content:space-between;align-items:center;">
                                <span style="font-size:12px;color:var(--text);display:flex;align-items:center;gap:6px;">
                                    <span style="width:9px;height:9px;border-radius:50%;background:#94A3B8;display:inline-block;flex-shrink:0;"></span>Offline
                                </span>
                                <span class="live-stat-offline" data-router-id="<%= r.id %>" style="font-weight:700;color:#94A3B8;font-size:15px;">—</span>
                            </div>
                            <div style="border-top:1px solid var(--border);padding-top:5px;display:flex;justify-content:space-between;align-items:center;">
                                <span style="font-size:11px;color:var(--muted);">Total Akun</span>
                                <span style="font-weight:800;font-size:15px;"><%= total %></span>
                            </div>
                        </div>
                    </div>

                    <!-- Utilisasi bar -->
                    <div>
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;">
                            <span style="font-size:11px;color:var(--muted);">Utilisasi Live</span>
                            <span class="live-util-pct" data-router-id="<%= r.id %>" style="font-size:12px;font-weight:700;color:<%= barColor %>;"><%= pct %>%</span>
                        </div>
                        <div style="height:8px;background:var(--card-bg);border-radius:4px;overflow:hidden;">
                            <div class="live-util-bar" data-router-id="<%= r.id %>"
                                 style="height:100%;width:<%= pct %>%;background:<%= barColor %>;border-radius:4px;transition:width .6s ease,background .3s;"></div>
                        </div>
                    </div>
                </div>
                <% }) %>
                </div>

                <% } else { %>
                <div class="empty-hint"><i class="fas fa-server" style="font-size:28px;opacity:.3;display:block;margin-bottom:10px;"></i>Belum ada data router</div>
                <% } %>
            </div>

        </div><!-- /tab-olt -->


        <!-- ════════════════════════════════════════
             TAB 3 — TAGIHAN & ISOLIR
        ════════════════════════════════════════ -->
        <div class="tab-pane" id="tab-billing">

            <!-- Summary -->
            <div class="stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(160px,1fr));margin-bottom:22px;">
                <div class="stat-card orange">
                    <div class="stat-label">Jatuh Tempo Minggu Ini</div>
                    <div class="stat-value"><%= (dueThisWeek||[]).length %></div>
                    <div class="stat-sub">tagihan perlu ditagih</div>
                </div>
                <div class="stat-card red">
                    <div class="stat-label">Sudah Melewati Jatuh Tempo</div>
                    <div class="stat-value"><%= n(stats.overdueInvoices) %></div>
                    <div class="stat-sub">harus segera diselesaikan</div>
                </div>
                <div class="stat-card" style="border-top:3px solid #EF4444;">
                    <div class="stat-label">Pelanggan Terisolir</div>
                    <div class="stat-value"><%= (isolatedList||[]).length %></div>
                    <div class="stat-sub">dari total <%= n(stats.totalCustomers) %> pelanggan</div>
                </div>
                <div class="stat-card blue">
                    <div class="stat-label">Total Tagihan Belum Bayar</div>
                    <div class="stat-value"><%= n(stats.unpaidInvoices) %></div>
                    <div class="stat-sub">semua invoice unpaid</div>
                </div>
            </div>

            <!-- Tagihan Jatuh Tempo Minggu Ini -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">📅 Tagihan Jatuh Tempo 7 Hari ke Depan</h2>
                    <a href="/billing?status=unpaid" class="btn btn-primary" style="font-size:12px;padding:6px 14px;">Lihat Semua</a>
                </div>
                <% if (dueThisWeek.length > 0) { %>
                <div class="table-wrap">
                    <table>
                        <thead><tr><th>Pelanggan</th><th>No. HP</th><th>Paket</th><th>Jumlah</th><th>Jatuh Tempo</th><th>Sisa</th></tr></thead>
                        <tbody>
                        <% dueThisWeek.forEach(inv => {
                            const due = new Date(inv.due_date);
                            const now = new Date(); now.setHours(0,0,0,0);
                            const diff = Math.round((due - now) / 86400000);
                            const dueClass = diff === 0 ? 'due-today' : diff <= 2 ? 'due-soon' : 'due-normal';
                            const dueLabel = diff === 0 ? 'HARI INI' : diff < 0 ? `${Math.abs(diff)}h lalu` : `${diff} hari lagi`;
                        %>
                        <tr>
                            <td style="font-weight:600;"><%= inv.customer_name||'-' %></td>
                            <td style="font-size:12px;"><%= inv.customer_phone||'-' %></td>
                            <td style="font-size:12px;color:var(--muted);"><%= inv.package_name||'-' %></td>
                            <td style="font-weight:700;"><%= fmtRp(inv.amount) %></td>
                            <td style="font-size:12px;"><%= due.toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %></td>
                            <td><span class="<%= dueClass %>"><%= dueLabel %></span></td>
                        </tr>
                        <% }) %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                <div class="empty-hint"><i class="fas fa-check-circle" style="font-size:28px;opacity:.3;display:block;margin-bottom:10px;"></i>Tidak ada tagihan jatuh tempo minggu ini</div>
                <% } %>
            </div>

            <!-- Pelanggan Terisolir -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">🔒 Pelanggan Terisolir</h2>
                    <a href="/customers?status=isolated" class="btn btn-primary" style="font-size:12px;padding:6px 14px;">Lihat Semua</a>
                </div>
                <% if (isolatedList.length > 0) { %>
                <div class="table-wrap">
                    <table>
                        <thead><tr><th>Nama</th><th>No. HP</th><th>Paket</th><th>Harga/Bln</th><th>Durasi Isolir</th></tr></thead>
                        <tbody>
                        <% isolatedList.forEach(c => {
                            const days = parseInt(c.days_isolated) || 0;
                            const urgencyColor = days > 30 ? '#EF4444' : days > 7 ? '#F59E0B' : 'var(--muted)';
                        %>
                        <tr>
                            <td style="font-weight:600;"><%= c.name %></td>
                            <td style="font-size:12px;"><%= c.phone||'-' %></td>
                            <td style="font-size:12px;color:var(--muted);"><%= c.package_name||'-' %></td>
                            <td style="font-size:12px;"><%= fmtRp(c.price) %></td>
                            <td style="font-weight:700;color:<%= urgencyColor %>;"><%= days %> hari</td>
                        </tr>
                        <% }) %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                <div class="empty-hint"><i class="fas fa-user-check" style="font-size:28px;opacity:.3;display:block;margin-bottom:10px;"></i>Tidak ada pelanggan yang terisolir</div>
                <% } %>
            </div>

        </div><!-- /tab-billing -->


        <!-- ════════════════════════════════════════
             TAB 4 — TIKET TEKNISI
        ════════════════════════════════════════ -->
        <div class="tab-pane" id="tab-tickets">

            <!-- Ticket summary cards -->
            <%
                const ts = ticketStats || {};
            %>
            <div class="stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(150px,1fr));margin-bottom:22px;">
                <div class="stat-card red">
                    <div class="stat-label">Tiket Terbuka</div>
                    <div class="stat-value"><%= n(ts.open) %></div>
                    <div class="stat-sub">belum ditangani</div>
                </div>
                <div class="stat-card orange">
                    <div class="stat-label">Dalam Proses</div>
                    <div class="stat-value"><%= n(ts.in_progress) %></div>
                    <div class="stat-sub">sedang dikerjakan</div>
                </div>
                <div class="stat-card green">
                    <div class="stat-label">Selesai</div>
                    <div class="stat-value"><%= n(ts.resolved) %></div>
                    <div class="stat-sub">tiket terselesaikan</div>
                </div>
                <div class="stat-card blue">
                    <div class="stat-label">Tiket Bulan Ini</div>
                    <div class="stat-value"><%= n(ts.this_month) %></div>
                    <div class="stat-sub"><%= n(ts.today) %> dibuka hari ini</div>
                </div>
            </div>

            <!-- Beban per Teknisi -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">👷 Beban Tiket per Teknisi</h2>
                    <a href="/tickets" class="btn btn-primary" style="font-size:12px;padding:6px 14px;">Semua Tiket</a>
                </div>
                <% if (ticketsByTech.length > 0) { %>
                <div class="tech-row">
                    <% ticketsByTech.forEach(t => {
                        const initials = t.technician.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
                    %>
                    <div class="tech-card">
                        <div class="tech-avatar"><%= initials %></div>
                        <div class="tech-name"><%= t.technician %></div>
                        <div class="tech-stats">
                            <div class="tstat">
                                <div class="tstat-val" style="color:#EF4444;"><%= t.open||0 %></div>
                                <div class="tstat-lbl">Terbuka</div>
                            </div>
                            <div class="tstat">
                                <div class="tstat-val" style="color:#F59E0B;"><%= t.in_progress||0 %></div>
                                <div class="tstat-lbl">Proses</div>
                            </div>
                            <div class="tstat">
                                <div class="tstat-val" style="color:#10B981;"><%= t.resolved||0 %></div>
                                <div class="tstat-lbl">Selesai</div>
                            </div>
                        </div>
                        <!-- mini bar beban -->
                        <div style="margin-top:10px;height:5px;background:var(--sub-bg);border-radius:3px;overflow:hidden;">
                            <% const openPct = t.total>0?Math.round((t.open/t.total)*100):0; %>
                            <div style="height:100%;width:<%= openPct %>%;background:<%= openPct>50?'#EF4444':openPct>20?'#F59E0B':'#10B981' %>;border-radius:3px;transition:width .5s;"></div>
                        </div>
                        <div style="font-size:10px;color:var(--muted);margin-top:4px;"><%= t.total %> total tiket</div>
                    </div>
                    <% }) %>
                </div>
                <% } else { %>
                <div class="empty-hint"><i class="fas fa-users" style="font-size:28px;opacity:.3;display:block;margin-bottom:10px;"></i>Belum ada data tiket per teknisi</div>
                <% } %>
            </div>

            <!-- Tiket Dibuka Hari Ini -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">📋 Tiket Dibuka Hari Ini (<%= ticketStats.today||0 %>)</h2>
                </div>
                <% if (todayTickets.length > 0) { %>
                <div class="table-wrap">
                    <table>
                        <thead><tr><th>Pelanggan</th><th>Kategori</th><th>Teknisi</th><th>Status</th><th>Waktu</th></tr></thead>
                        <tbody>
                        <% todayTickets.forEach(tk => { %>
                        <tr>
                            <td>
                                <div style="font-weight:600;"><%= tk.customer_name||'-' %></div>
                                <div style="font-size:11px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;"><%= tk.title||tk.description||'' %></div>
                            </td>
                            <td style="font-size:12px;color:var(--muted);"><%= tk.category||'gangguan' %></td>
                            <td style="font-size:12px;"><%= tk.technician_name||'—' %></td>
                            <td><span class="badge badge-<%= tk.status %>"><%= tk.status==='open'?'Terbuka':tk.status==='in_progress'?'Proses':'Selesai' %></span></td>
                            <td style="font-size:11px;color:var(--muted);"><%= new Date(tk.created_at).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) %></td>
                        </tr>
                        <% }) %>
                        </tbody>
                    </table>
                </div>
                <% } else { %>
                <div class="empty-hint"><i class="fas fa-ticket-alt" style="font-size:28px;opacity:.3;display:block;margin-bottom:10px;"></i>Belum ada tiket dibuka hari ini</div>
                <% } %>
            </div>

            <!-- Chart resolusi tiket per teknisi -->
            <div class="card">
                <div class="card-header"><h2 class="card-title">📊 Perbandingan Status Tiket per Teknisi</h2></div>
                <% if (ticketsByTech.length > 0) { %>
                <canvas id="techTicketChart" height="80"></canvas>
                <% } else { %>
                <div class="empty-hint">Belum ada data</div>
                <% } %>
            </div>

        </div><!-- /tab-tickets -->

    </div><!-- /content -->
</main>

<script>
// ── Tab switching ──
function switchTab(name, btn) {
    document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.dash-tab').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
    localStorage.setItem('dashTab', name);
    if (name === 'olt') { setTimeout(initOltCharts, 50); }
    if (name === 'tickets') { setTimeout(initTicketChart, 50); }
}
// Restore last active tab
(function() {
    const saved = localStorage.getItem('dashTab');
    if (saved && saved !== 'overview') {
        const btn = document.querySelector(`[data-tab="${saved}"]`);
        if (btn) switchTab(saved, btn);
    }
})();

// ── Live Clock ──
const HARI  = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
const BULAN = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
function updateClock() {
    const now = new Date();
    const hh = String(now.getHours()).padStart(2,'0'), mm = String(now.getMinutes()).padStart(2,'0'), ss = String(now.getSeconds()).padStart(2,'0');
    const el = document.getElementById('liveClock');
    if (el) el.textContent = `${hh}:${mm}:${ss}`;
    const d = document.getElementById('liveDay'); if(d) d.textContent = HARI[now.getDay()];
    const f = document.getElementById('liveDate'); if(f) f.textContent = `${now.getDate()} ${BULAN[now.getMonth()]} ${now.getFullYear()}`;
}
updateClock(); setInterval(updateClock, 1000);

// ── Chart helpers ──
const isLight   = document.documentElement.classList.contains('light-theme');
const gridColor = isLight ? 'rgba(0,0,0,0.05)' : 'rgba(255,255,255,0.06)';
const tickColor = isLight ? '#64748B' : '#94A3B8';

// ── Tab 1 Charts ──
const monthlyRevenue   = <%- JSON.stringify(monthlyRevenue) %>;
const monthlyCustomers = <%- JSON.stringify(monthlyCustomers) %>;

new Chart(document.getElementById('revenueChart'), {
    type:'line',
    data:{ labels:monthlyRevenue.map(d=>d.month),
           datasets:[{label:'Pendapatan',data:monthlyRevenue.map(d=>d.revenue),borderColor:'#3B82F6',backgroundColor:'rgba(59,130,246,0.1)',fill:true,tension:0.4,pointRadius:4,pointBackgroundColor:'#3B82F6'}]},
    options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,grid:{color:gridColor},ticks:{color:tickColor,callback:v=>'Rp '+(v/1000).toFixed(0)+'K'}},x:{grid:{color:gridColor},ticks:{color:tickColor}}}}
});
new Chart(document.getElementById('customerChart'), {
    type:'bar',
    data:{ labels:monthlyCustomers.map(d=>d.month),
           datasets:[{label:'Pelanggan Baru',data:monthlyCustomers.map(d=>d.count),backgroundColor:'rgba(139,92,246,0.5)',borderColor:'#8B5CF6',borderWidth:2,borderRadius:6}]},
    options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,grid:{color:gridColor},ticks:{color:tickColor,stepSize:1}},x:{grid:{color:gridColor},ticks:{color:tickColor}}}}
});

// Traffic
const trafficCtx = document.getElementById('trafficChart').getContext('2d');
const trafficChart = new Chart(trafficCtx, {
    type:'line',
    data:{ labels:Array(30).fill(''),
           datasets:[
               {label:'Download (Mbps)',data:Array(30).fill(0),borderColor:'#10B981',backgroundColor:'rgba(16,185,129,0.1)',fill:true,tension:0.4,pointRadius:0,borderWidth:2},
               {label:'Upload (Mbps)',  data:Array(30).fill(0),borderColor:'#3B82F6',backgroundColor:'rgba(59,130,246,0.1)',fill:true,tension:0.4,pointRadius:0,borderWidth:2}
           ]},
    options:{responsive:true,animation:{duration:800},plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,grid:{color:gridColor},ticks:{color:tickColor,callback:v=>v+' M'}},x:{display:false}}}
});
async function updateTraffic() {
    try {
        const iface = document.getElementById('interfaceSelector').value;
        const res = await fetch(`/api/mikrotik/traffic?interface=${iface}`);
        const d = await res.json();
        if (d.success && d.data.length > 0) {
            let rx=0, tx=0; d.data.forEach(r=>{ rx+=r.rx; tx+=r.tx; });
            const rxM=(rx/1000000).toFixed(2), txM=(tx/1000000).toFixed(2);
            document.getElementById('totalRx').textContent = rxM+' Mbps';
            document.getElementById('totalTx').textContent = txM+' Mbps';
            trafficChart.data.datasets[0].data.shift(); trafficChart.data.datasets[0].data.push(rxM);
            trafficChart.data.datasets[1].data.shift(); trafficChart.data.datasets[1].data.push(txM);
            trafficChart.update('none');
        }
    } catch(e) {}
}
document.getElementById('interfaceSelector').addEventListener('change', () => {
    trafficChart.data.datasets[0].data = Array(30).fill(0);
    trafficChart.data.datasets[1].data = Array(30).fill(0);
    trafficChart.update(); updateTraffic();
});
setInterval(updateTraffic, 2000); updateTraffic();

// Expense comparison
const monthlyExpenses = <%- JSON.stringify(monthlyExpenses||[]) %>;
if (monthlyExpenses.length > 0) {
    new Chart(document.getElementById('expenseCompChart'), {
        type:'bar',
        data:{ labels:monthlyRevenue.map(d=>d.month),
               datasets:[
                   {label:'Pemasukan',data:monthlyRevenue.map(d=>d.revenue),backgroundColor:'rgba(16,185,129,0.5)',borderColor:'#10B981',borderWidth:1,borderRadius:5},
                   {label:'Pengeluaran',data:monthlyExpenses.map(d=>d.expense),backgroundColor:'rgba(239,68,68,0.5)',borderColor:'#EF4444',borderWidth:1,borderRadius:5},
                   {label:'Laba',data:monthlyRevenue.map((d,i)=>d.revenue-(monthlyExpenses[i]?.expense||0)),type:'line',borderColor:'#F59E0B',backgroundColor:'rgba(245,158,11,0.1)',fill:true,tension:0.4,pointRadius:4,pointBackgroundColor:'#F59E0B'}
               ]},
        options:{responsive:true,plugins:{legend:{labels:{color:tickColor,font:{size:11}}},tooltip:{callbacks:{label:ctx=>` ${ctx.dataset.label}: Rp ${Math.floor(ctx.parsed.y).toLocaleString('id-ID')}`}}},
            scales:{y:{beginAtZero:true,grid:{color:gridColor},ticks:{color:tickColor,callback:v=>'Rp '+(v/1000000).toFixed(1)+'M'}},x:{grid:{display:false},ticks:{color:tickColor}}}}
    });
}

// Package donut
const packageDist = <%- JSON.stringify(packageDist||[]) %>;
packageDist.forEach(p=>{ p.total_customers=parseInt(p.total_customers)||0; });
if (packageDist.length > 0) {
    const COLORS=['#3B82F6','#10B981','#8B5CF6','#F59E0B','#EF4444','#06B6D4','#F97316','#EC4899','#84CC16','#6366F1'];
    const labels=packageDist.map(p=>p.package_name), data=packageDist.map(p=>p.total_customers), colors=packageDist.map((_,i)=>COLORS[i%COLORS.length]);
    new Chart(document.getElementById('packageDonut'), {
        type:'doughnut',
        data:{labels,datasets:[{data,backgroundColor:colors,borderColor:isLight?'#FFFFFF':'#111827',borderWidth:3,hoverOffset:8}]},
        options:{responsive:false,cutout:'65%',plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>{const p=packageDist[ctx.dataIndex];const pct=Math.round((p.total_customers/data.reduce((a,b)=>a+b,0))*100);return ` ${p.package_name}: ${p.total_customers} (${pct}%)`;
        }}}}}
    });
    const legendEl=document.getElementById('packageLegend'), total=data.reduce((a,b)=>a+b,0);
    packageDist.forEach((p,i)=>{ const pct=total>0?Math.round((p.total_customers/total)*100):0;
        legendEl.innerHTML+=`<div style="display:flex;align-items:center;gap:8px;font-size:12px;"><span style="width:10px;height:10px;border-radius:3px;background:${colors[i]};flex-shrink:0;"></span><span style="flex:1;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${p.package_name}</span><span style="font-weight:700;">${p.total_customers}</span><span style="color:var(--muted);">(${pct}%)</span></div>`;
    });
}

// ── Tab 2 Charts (lazy init) ──
let oltChartsInited = false;
function initOltCharts() {
    if (oltChartsInited) return;
    oltChartsInited = true;

    const _oltOnline  = <%= n(oltStats&&oltStats.online) %>;
    const _oltOffline = <%= n(oltStats&&oltStats.total) - n(oltStats&&oltStats.online) %>;
    new Chart(document.getElementById('onuDonut'), {
        type:'doughnut',
        data:{labels:['Online','Offline'],datasets:[{data:[_oltOnline,_oltOffline],backgroundColor:['#10B981','#EF4444'],borderColor:isLight?'#FFFFFF':'#111827',borderWidth:3,hoverOffset:6}]},
        options:{responsive:false,cutout:'70%',plugins:{legend:{display:false}}}
    });

    const sigDist = <%- JSON.stringify(signalDist||{}) %>;
    new Chart(document.getElementById('signalChart'), {
        type:'bar',
        data:{labels:['Excellent','Good','Fair','Weak','Bad'],datasets:[{data:[sigDist.excellent||0,sigDist.good||0,sigDist.fair||0,sigDist.weak||0,sigDist.bad||0],backgroundColor:['#10B981','#34D399','#F59E0B','#F97316','#EF4444'],borderRadius:5,borderSkipped:false}]},
        options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,grid:{color:gridColor},ticks:{color:tickColor,stepSize:1}},x:{grid:{display:false},ticks:{color:tickColor,font:{size:10}}}}}
    });

    const _acsOnline  = <%= n(acsStats&&acsStats.online) %>;
    const _acsOffline = <%= n(acsStats&&acsStats.total) - n(acsStats&&acsStats.online) %>;
    new Chart(document.getElementById('acsDonut'), {
        type:'doughnut',
        data:{labels:['Online','Offline'],datasets:[{data:[_acsOnline,_acsOffline],backgroundColor:['#10B981','#EF4444'],borderColor:isLight?'#FFFFFF':'#111827',borderWidth:3,hoverOffset:6}]},
        options:{responsive:false,cutout:'70%',plugins:{legend:{labels:{color:tickColor}}}}
    });
}

// ── Tab 4 Chart (lazy init) ──
let techChartInited = false;
function initTicketChart() {
    if (techChartInited) return;
    techChartInited = true;
    const ticketsByTech = <%- JSON.stringify(ticketsByTech||[]) %>;
    if (!ticketsByTech.length || !document.getElementById('techTicketChart')) return;
    new Chart(document.getElementById('techTicketChart'), {
        type:'bar',
        data:{
            labels: ticketsByTech.map(t=>t.technician),
            datasets:[
                {label:'Terbuka',   data:ticketsByTech.map(t=>t.open||0),      backgroundColor:'rgba(239,68,68,0.7)',  borderRadius:4},
                {label:'Proses',    data:ticketsByTech.map(t=>t.in_progress||0),backgroundColor:'rgba(245,158,11,0.7)',borderRadius:4},
                {label:'Selesai',   data:ticketsByTech.map(t=>t.resolved||0),   backgroundColor:'rgba(16,185,129,0.7)', borderRadius:4}
            ]
        },
        options:{responsive:true,plugins:{legend:{labels:{color:tickColor,font:{size:11}}}},
            scales:{x:{stacked:true,grid:{display:false},ticks:{color:tickColor}},y:{stacked:true,beginAtZero:true,grid:{color:gridColor},ticks:{color:tickColor,stepSize:1}}}}
    });
}

// Init OLT charts jika tab OLT sudah aktif saat load
if (localStorage.getItem('dashTab') === 'olt') initOltCharts();
if (localStorage.getItem('dashTab') === 'tickets') initTicketChart();

// ── PPPoE Router donut charts ──
const _pppoeCharts = {};

function initPPPoECharts() {
    if (window._pppoeChartsInited) return;
    window._pppoeChartsInited = true;

    document.querySelectorAll('.pppoe-router-card').forEach(card => {
        const rid      = card.dataset.routerId;
        const total    = parseInt(card.dataset.total)    || 0;
        const active   = parseInt(card.dataset.active)   || 0;
        const isolated = parseInt(card.dataset.isolated) || 0;
        const inactive = Math.max(0, total - active - isolated);
        const canvas   = document.getElementById(`pppoe-chart-${rid}`);
        if (!canvas || _pppoeCharts[rid]) return;

        _pppoeCharts[rid] = new Chart(canvas, {
            type: 'doughnut',
            data: {
                labels: ['Aktif DB', 'Isolir', 'Tidak Aktif'],
                datasets: [{
                    data: total > 0 ? [active, isolated, inactive] : [1],
                    backgroundColor: total > 0
                        ? ['#10B981', '#EF4444', 'rgba(148,163,184,.25)']
                        : ['rgba(148,163,184,.15)'],
                    borderWidth: 0,
                    hoverOffset: 6
                }]
            },
            options: {
                cutout: '70%',
                responsive: false,
                animation: { duration: 700, easing: 'easeOutQuart' },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => `  ${ctx.label}: ${ctx.raw}`
                        }
                    }
                }
            }
        });

        // Init offline stat (DB: total - active - isolated)
        const offEl = card.querySelector(`.live-stat-offline[data-router-id="${rid}"]`);
        if (offEl) offEl.textContent = inactive;
    });
}

// ── Live PPPoE active sessions per router ──
async function loadPPPoELive() {
    const btn = document.getElementById('btnRefreshPPPoE');
    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Memuat...'; }

    // Show loading spinners
    document.querySelectorAll('.live-pppoe-val, .live-stat-active').forEach(el => {
        el.innerHTML = '<i class="fas fa-spinner fa-spin" style="font-size:11px;opacity:.4;"></i>';
    });

    try {
        const resp = await fetch('/api/dashboard/pppoe-live');
        const json = await resp.json();
        if (json.success && Array.isArray(json.data)) {
            json.data.forEach(r => {
                const card    = document.querySelector(`.pppoe-router-card[data-router-id="${r.id}"]`);
                const bigVal  = document.querySelector(`.live-pppoe-val[data-router-id="${r.id}"]`);
                const statVal = document.querySelector(`.live-stat-active[data-router-id="${r.id}"]`);
                const offVal  = document.querySelector(`.live-stat-offline[data-router-id="${r.id}"]`);
                const bar     = document.querySelector(`.live-util-bar[data-router-id="${r.id}"]`);
                const pctEl   = document.querySelector(`.live-util-pct[data-router-id="${r.id}"]`);

                if (r.active_live === null) {
                    const tip = r.error || 'Tidak terhubung';
                    if (bigVal)  bigVal.innerHTML  = `<span title="${tip}" style="color:#EF4444;font-size:18px;cursor:help;">✗</span>`;
                    if (statVal) statVal.innerHTML = `<span title="${tip}" style="color:#EF4444;cursor:help;">✗</span>`;
                    if (offVal)  offVal.textContent = '—';
                } else {
                    const total    = card ? (parseInt(card.dataset.total)    || 0) : 0;
                    const isolated = card ? (parseInt(card.dataset.isolated) || 0) : 0;
                    const offline  = Math.max(0, total - r.active_live - isolated);

                    if (bigVal)  bigVal.textContent  = r.active_live;
                    if (statVal) statVal.textContent = r.active_live;
                    if (offVal)  offVal.textContent  = offline;

                    // Update utilisasi bar
                    if (bar && pctEl) {
                        const livePct = total > 0 ? Math.min(100, Math.round((r.active_live / total) * 100)) : 0;
                        const barClr  = livePct >= 80 ? '#10B981' : livePct >= 50 ? '#F59E0B' : '#EF4444';
                        bar.style.width      = livePct + '%';
                        bar.style.background = barClr;
                        pctEl.textContent    = livePct + '%';
                        pctEl.style.color    = barClr;
                    }

                    // Update donut chart with live data
                    const chart = _pppoeCharts[r.id];
                    if (chart && total > 0) {
                        chart.data.labels = ['Sesi Live', 'Isolir', 'Offline'];
                        chart.data.datasets[0].data            = [r.active_live, isolated, offline];
                        chart.data.datasets[0].backgroundColor = ['#818CF8', '#EF4444', 'rgba(148,163,184,.25)'];
                        chart.update();
                    }
                }
            });

            // Update timestamp
            const ts = document.getElementById('pppoe-last-update');
            if (ts) {
                const now = new Date();
                ts.textContent = `⏱ Diperbarui ${now.toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit',second:'2-digit'})}`;
            }
        }
    } catch(e) {
        document.querySelectorAll('.live-pppoe-val, .live-stat-active').forEach(el => {
            el.innerHTML = '<span style="color:#EF4444;font-size:10px;">Err</span>';
        });
    }

    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-sync-alt"></i> Refresh Live'; }
}

// Auto-init charts & load live data when OLT tab is visible
(function() {
    const savedTab = localStorage.getItem('dashTab');
    if (savedTab === 'olt') {
        setTimeout(() => { initPPPoECharts(); loadPPPoELive(); }, 400);
    }
    document.querySelectorAll('.dash-tab').forEach(btn => {
        btn.addEventListener('click', function() {
            if (this.dataset.tab === 'olt') {
                setTimeout(() => { initPPPoECharts(); loadPPPoELive(); }, 300);
            }
        });
    });
})();
</script>
</body>
</html>
