<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <style>
/* ── Stat Cards ─────────────────────────────────────────────── */
.im-stats    { display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:14px; margin-bottom:24px; }
.im-stat     { background:var(--card-bg); border:1px solid var(--border); border-radius:12px; padding:18px; text-align:center; position:relative; overflow:hidden; }
.im-stat::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
.im-stat.s-total::before  { background:#6366F1; }
.im-stat.s-up::before     { background:#10B981; }
.im-stat.s-down::before   { background:#EF4444; }
.im-stat.s-unknown::before{ background:#94A3B8; }
.im-stat-val { font-size:30px; font-weight:800; line-height:1; margin-bottom:4px; }
.im-stat.s-total  .im-stat-val { color:#6366F1; }
.im-stat.s-up     .im-stat-val { color:#10B981; }
.im-stat.s-down   .im-stat-val { color:#EF4444; }
.im-stat.s-unknown .im-stat-val{ color:#94A3B8; }
.im-stat-lbl { font-size:11px; color:var(--muted); font-weight:600; text-transform:uppercase; letter-spacing:.5px; }

/* ── Toolbar ─────────────────────────────────────────────────── */
.im-toolbar { display:flex; align-items:center; gap:10px; margin-bottom:14px; flex-wrap:wrap; }
.im-search  { flex:1; min-width:180px; max-width:280px; }

/* ── Status Badges ───────────────────────────────────────────── */
.badge-up      { display:inline-flex; align-items:center; gap:5px; background:rgba(16,185,129,.12); color:#10B981; border-radius:20px; padding:3px 10px; font-size:11px; font-weight:700; }
.badge-down    { display:inline-flex; align-items:center; gap:5px; background:rgba(239,68,68,.12);  color:#EF4444;  border-radius:20px; padding:3px 10px; font-size:11px; font-weight:700; }
.badge-unknown { display:inline-flex; align-items:center; gap:5px; background:rgba(148,163,184,.12);color:#94A3B8; border-radius:20px; padding:3px 10px; font-size:11px; font-weight:700; }
.dot { width:7px; height:7px; border-radius:50%; display:inline-block; flex-shrink:0; }
.dot-up      { background:#10B981; animation:pulse-up 2s infinite; }
.dot-down    { background:#EF4444; animation:pulse-dn 1s infinite; }
.dot-unknown { background:#94A3B8; }
@keyframes pulse-up { 0%,100%{box-shadow:0 0 0 0 rgba(16,185,129,.35)} 50%{box-shadow:0 0 0 5px rgba(16,185,129,0)} }
@keyframes pulse-dn { 0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.45)}  50%{box-shadow:0 0 0 5px rgba(239,68,68,0)} }

/* ── Table Extras ────────────────────────────────────────────── */
.im-type-badge { font-size:11px; background:rgba(99,102,241,.12); color:#6366F1; padding:2px 8px; border-radius:20px; font-weight:700; }
.disabled-row td { opacity:.5; }
.actions { display:flex; gap:5px; flex-wrap:wrap; }
.btn-sm  { padding:5px 10px; font-size:12px; border-radius:6px; border:none; cursor:pointer; font-weight:600; display:inline-flex; align-items:center; gap:3px; transition:opacity .15s; }
.btn-sm:hover { opacity:.8; }
.btn-check  { background:#6366F1; color:#fff; }
.btn-edit   { background:#F59E0B; color:#fff; }
.btn-toggle-on  { background:#10B981; color:#fff; }
.btn-toggle-off { background:#94A3B8; color:#fff; }
.btn-del    { background:#EF4444; color:#fff; }
.spinning   { animation:spin .7s linear infinite; display:inline-block; }
@keyframes spin { to{transform:rotate(360deg)} }

/* ── Settings panel ──────────────────────────────────────────── */
.settings-panel { display:none; background:var(--card-bg); border:1px solid var(--border); border-radius:12px; padding:20px; margin-bottom:18px; }
.settings-panel.open { display:block; }
.settings-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
@media(max-width:600px){ .settings-grid { grid-template-columns:1fr; } }

/* ── Modal ───────────────────────────────────────────────────── */
.modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:1200; align-items:center; justify-content:center; padding:16px; }
.modal-overlay.open { display:flex; }
.modal-box { background:var(--modal-bg); border:1px solid var(--border); border-radius:16px; width:100%; max-width:500px; padding:28px; box-shadow:0 20px 60px rgba(0,0,0,.4); }
.modal-title { font-size:17px; font-weight:700; margin-bottom:20px; }
.form-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.form-group { margin-bottom:14px; }
.form-group label { display:block; font-size:12px; font-weight:600; color:var(--muted); margin-bottom:5px; text-transform:uppercase; letter-spacing:.4px; }
.modal-footer { display:flex; justify-content:flex-end; gap:10px; margin-top:20px; }
.btn-cancel { background:var(--bg-color); color:var(--text); border:1px solid var(--border); border-radius:8px; padding:8px 18px; cursor:pointer; font-weight:600; font-size:13px; }

/* ── Toast ───────────────────────────────────────────────────── */
#imToast { display:none; position:fixed; bottom:24px; right:24px; padding:12px 20px; border-radius:10px; font-size:13px; z-index:9999; box-shadow:0 4px 20px rgba(0,0,0,.3); max-width:320px; color:#fff; font-weight:600; }
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: 'IP Monitor' }) %>
    <div class="content">

        <!-- Page Header -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
            <h1 class="page-title" style="margin:0;display:flex;align-items:center;gap:10px;">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
                IP Monitor
            </h1>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <button class="btn" onclick="toggleSettings()" style="border:1px solid var(--border);">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Pengaturan
                </button>
                <button class="btn btn-primary" onclick="openAddModal()">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 4v16m8-8H4"/></svg>
                    Tambah Target
                </button>
            </div>
        </div>

        <!-- Stat Cards -->
        <div class="im-stats">
            <div class="im-stat s-total">
                <div class="im-stat-val"><%= stats.total %></div>
                <div class="im-stat-lbl">Total Target</div>
            </div>
            <div class="im-stat s-up">
                <div class="im-stat-val"><%= stats.up %></div>
                <div class="im-stat-lbl">🟢 Online</div>
            </div>
            <div class="im-stat s-down">
                <div class="im-stat-val"><%= stats.down %></div>
                <div class="im-stat-lbl">🔴 Down</div>
            </div>
            <div class="im-stat s-unknown">
                <div class="im-stat-val"><%= stats.unknown %></div>
                <div class="im-stat-lbl">⚪ Belum Dicek</div>
            </div>
        </div>

        <!-- Settings Panel -->
        <div class="settings-panel" id="settingsPanel">
            <div style="font-weight:700;font-size:14px;margin-bottom:14px;">⚙️ Pengaturan Notifikasi</div>
            <div class="settings-grid">
                <div class="form-group">
                    <label>Interval Cek Default (menit)</label>
                    <input type="number" id="cfg_interval" class="form-control" value="<%= globalInterval %>" min="1" max="60">
                    <div style="font-size:11px;color:var(--muted);margin-top:4px;">Dipakai sebagai nilai awal saat tambah target baru.</div>
                </div>
                <div class="form-group">
                    <label>Telegram Chat ID (Grup Notifikasi)</label>
                    <input type="text" id="cfg_telegram" class="form-control" value="<%= telegramChat %>" placeholder="-1001234567890">
                    <div style="font-size:11px;color:var(--muted);margin-top:4px;">Alert DOWN/RECOVERED dikirim ke chat ini. Bot Token diambil dari Pengaturan utama.</div>
                </div>
            </div>
            <button class="btn btn-primary" onclick="saveSettings()">💾 Simpan Pengaturan</button>
        </div>

        <!-- Toolbar -->
        <div class="im-toolbar">
            <input type="text" class="form-control im-search" id="searchBox" placeholder="🔍 Cari nama / IP..." oninput="filterTable()">
            <span style="margin-left:auto;font-size:12px;color:var(--muted)" id="lastRefresh"></span>
        </div>

        <!-- Table -->
        <div class="card" style="padding:0;overflow:auto;">
            <table id="monitorTable">
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Nama</th>
                        <th>Target / IP</th>
                        <th>Tipe</th>
                        <th>Respon</th>
                        <th>Terakhir Cek</th>
                        <th>Gagal</th>
                        <th>Interval</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                <% if (monitors.length === 0) { %>
                    <tr><td colspan="9" style="text-align:center;padding:40px;color:var(--muted);">
                        Belum ada target. Klik <b>Tambah Target</b> untuk mulai.
                    </td></tr>
                <% } %>
                <% monitors.forEach(function(m) { %>
                    <tr id="row-<%= m.id %>" class="<%= m.enabled ? '' : 'disabled-row' %>"
                        data-name="<%= m.name.toLowerCase() %>"
                        data-ip="<%= m.ip_address.toLowerCase() %>">
                        <td>
                            <% if (m.status === 'up') { %>
                                <span class="badge-up"><span class="dot dot-up"></span> UP</span>
                            <% } else if (m.status === 'down') { %>
                                <span class="badge-down"><span class="dot dot-down"></span> DOWN</span>
                            <% } else { %>
                                <span class="badge-unknown"><span class="dot dot-unknown"></span> UNKNOWN</span>
                            <% } %>
                        </td>
                        <td style="font-weight:600;">
                            <%= m.name %>
                            <% if (!m.enabled) { %><span style="font-size:10px;color:var(--muted);margin-left:4px;">(nonaktif)</span><% } %>
                            <% if (m.notes) { %><div style="font-size:11px;color:var(--muted);font-weight:400;margin-top:2px;"><%= m.notes %></div><% } %>
                        </td>
                        <td style="font-family:monospace;font-size:12px;">
                            <%= m.ip_address %><% if (m.port) { %>:<b><%= m.port %></b><% } %>
                        </td>
                        <td><span class="im-type-badge"><%= (m.check_type || 'icmp').toUpperCase() %></span></td>
                        <td id="ms-<%= m.id %>"><%= m.response_ms ? m.response_ms + ' ms' : '—' %></td>
                        <td style="font-size:12px;color:var(--muted);" id="lc-<%= m.id %>">
                            <% if (m.last_check) { %>
                                <%= new Date(m.last_check).toLocaleString('id-ID') %>
                            <% } else { %>
                                Belum pernah
                            <% } %>
                        </td>
                        <td id="fail-<%= m.id %>" style="<%= (m.consecutive_failures || 0) > 0 ? 'color:#EF4444;font-weight:700' : '' %>">
                            <%= m.consecutive_failures || 0 %>
                        </td>
                        <td style="font-size:12px;"><%= m.check_interval || 5 %> mnt</td>
                        <td>
                            <div class="actions">
                                <button class="btn-sm btn-check" id="chk-<%= m.id %>"
                                    data-id="<%= m.id %>"
                                    onclick="manualCheck(this.dataset.id)" title="Cek Sekarang">
                                    <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                                    Cek
                                </button>
                                <button class="btn-sm btn-edit"
                                    data-id="<%= m.id %>"
                                    data-name="<%- m.name.replace(/"/g, '&quot;') %>"
                                    data-ip="<%- m.ip_address.replace(/"/g, '&quot;') %>"
                                    data-port="<%= m.port || '' %>"
                                    data-type="<%= m.check_type || 'icmp' %>"
                                    data-interval="<%= m.check_interval || 5 %>"
                                    data-notes="<%- (m.notes || '').replace(/"/g, '&quot;') %>"
                                    onclick="openEditModal(this)" title="Edit">
                                    <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                    Edit
                                </button>
                                <button class="btn-sm <%= m.enabled ? 'btn-toggle-on' : 'btn-toggle-off' %>"
                                    data-id="<%= m.id %>"
                                    onclick="toggleTarget(this.dataset.id)"
                                    title="<%= m.enabled ? 'Nonaktifkan' : 'Aktifkan' %>">
                                    <%= m.enabled ? '⏸' : '▶' %>
                                </button>
                                <button class="btn-sm btn-del"
                                    data-id="<%= m.id %>"
                                    data-name="<%- m.name.replace(/"/g, '&quot;') %>"
                                    onclick="deleteTarget(this.dataset.id, this.dataset.name)" title="Hapus">
                                    <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        </div>

    </div><!-- /content -->
</main>

<!-- ── Modal Tambah / Edit ──────────────────────────────────── -->
<div class="modal-overlay" id="modalTarget">
    <div class="modal-box">
        <div class="modal-title" id="modalTargetTitle">➕ Tambah Target</div>
        <form onsubmit="submitTarget(event)">
            <input type="hidden" id="targetId">
            <div class="form-group">
                <label>Nama Target *</label>
                <input type="text" id="f_name" class="form-control" placeholder="misal: Router Utama" required>
            </div>
            <div class="form-row">
                <div class="form-group" style="margin-bottom:0">
                    <label>IP / URL *</label>
                    <input type="text" id="f_ip" class="form-control" placeholder="192.168.1.1" required>
                </div>
                <div class="form-group" style="margin-bottom:0">
                    <label>Port (TCP saja)</label>
                    <input type="number" id="f_port" class="form-control" placeholder="8291">
                </div>
            </div>
            <div class="form-row" style="margin-top:14px;">
                <div class="form-group" style="margin-bottom:0">
                    <label>Tipe Cek</label>
                    <select id="f_type" class="form-control" onchange="onTypeChange()">
                        <option value="icmp">ICMP Ping</option>
                        <option value="tcp">TCP Connect</option>
                        <option value="http">HTTP/HTTPS</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom:0">
                    <label>Interval (menit)</label>
                    <input type="number" id="f_interval" class="form-control" value="5" min="1" max="60">
                </div>
            </div>
            <div class="form-group" style="margin-top:14px;">
                <label>Catatan (opsional)</label>
                <input type="text" id="f_notes" class="form-control" placeholder="Lokasi / keterangan">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="closeModal('modalTarget')">Batal</button>
                <button type="submit" class="btn btn-primary" id="btnSaveTarget">💾 Simpan</button>
            </div>
        </form>
    </div>
</div>

<!-- ── Toast ────────────────────────────────────────────────── -->
<div id="imToast"></div>

<script>
const imToast = (msg, ok = true) => {
    const el = document.getElementById('imToast');
    el.textContent = msg;
    el.style.display = 'block';
    el.style.background = ok ? '#10B981' : '#EF4444';
    clearTimeout(el._t);
    el._t = setTimeout(() => { el.style.display = 'none'; }, 3500);
};

// ── Settings ─────────────────────────────────────────────────
function toggleSettings() {
    document.getElementById('settingsPanel').classList.toggle('open');
}
async function saveSettings() {
    const body = {
        monitor_check_interval: document.getElementById('cfg_interval').value,
        monitor_telegram_chat:  document.getElementById('cfg_telegram').value
    };
    try {
        const r = await fetch('/ip-monitor/settings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        const d = await r.json();
        imToast(d.message, d.success);
    } catch(e) { imToast('Error: ' + e.message, false); }
}

// ── Modal helpers ─────────────────────────────────────────────
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function openAddModal() {
    document.getElementById('targetId').value = '';
    document.getElementById('modalTargetTitle').textContent = '➕ Tambah Target';
    document.getElementById('f_name').value = '';
    document.getElementById('f_ip').value   = '';
    document.getElementById('f_port').value = '';
    document.getElementById('f_type').value = 'icmp';
    document.getElementById('f_interval').value = '<%= globalInterval || 5 %>';
    document.getElementById('f_notes').value = '';
    document.getElementById('f_port').disabled = true;
    document.getElementById('btnSaveTarget').textContent = '💾 Simpan';
    openModal('modalTarget');
}

function openEditModal(btn) {
    const d = btn.dataset;
    document.getElementById('targetId').value       = d.id;
    document.getElementById('modalTargetTitle').textContent = '✏️ Edit Target';
    document.getElementById('f_name').value         = d.name;
    document.getElementById('f_ip').value           = d.ip;
    document.getElementById('f_port').value         = d.port;
    document.getElementById('f_type').value         = d.type;
    document.getElementById('f_interval').value     = d.interval;
    document.getElementById('f_notes').value        = d.notes;
    document.getElementById('f_port').disabled      = (d.type !== 'tcp');
    document.getElementById('btnSaveTarget').textContent = '💾 Update';
    openModal('modalTarget');
}

function onTypeChange() {
    const t = document.getElementById('f_type').value;
    document.getElementById('f_port').disabled = (t !== 'tcp');
}

// ── Submit Add/Edit ───────────────────────────────────────────
async function submitTarget(e) {
    e.preventDefault();
    const id   = document.getElementById('targetId').value;
    const body = {
        name:           document.getElementById('f_name').value.trim(),
        ip_address:     document.getElementById('f_ip').value.trim(),
        port:           document.getElementById('f_port').value || null,
        check_type:     document.getElementById('f_type').value,
        check_interval: document.getElementById('f_interval').value,
        notes:          document.getElementById('f_notes').value.trim()
    };
    const url    = id ? `/ip-monitor/${id}` : '/ip-monitor';
    const method = id ? 'PUT' : 'POST';
    try {
        const r = await fetch(url, {
            method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
        });
        const d = await r.json();
        if (d.success) {
            imToast(d.message);
            closeModal('modalTarget');
            setTimeout(() => location.reload(), 900);
        } else {
            imToast(d.message, false);
        }
    } catch(err) { imToast('Error: ' + err.message, false); }
}

// ── Manual Check ─────────────────────────────────────────────
async function manualCheck(id) {
    const btn = document.getElementById('chk-' + id);
    const origHTML = btn.innerHTML;
    btn.innerHTML = '<span class="spinning">⟳</span>';
    btn.disabled  = true;
    try {
        const r = await fetch(`/ip-monitor/${id}/check`, { method: 'POST' });
        const d = await r.json();
        if (d.success) {
            const row  = document.getElementById('row-' + id);
            const tdSt = row.querySelector('td:first-child');
            if (d.up) {
                tdSt.innerHTML = '<span class="badge-up"><span class="dot dot-up"></span> UP</span>';
            } else {
                tdSt.innerHTML = '<span class="badge-down"><span class="dot dot-down"></span> DOWN</span>';
            }
            const msTd = document.getElementById('ms-' + id);
            if (msTd) msTd.textContent = d.ms ? d.ms + ' ms' : '—';
            const lcTd = document.getElementById('lc-' + id);
            if (lcTd) lcTd.textContent = new Date().toLocaleString('id-ID');
            imToast(d.message, d.up);
        } else {
            imToast(d.message, false);
        }
    } catch(err) { imToast('Error: ' + err.message, false); }
    btn.innerHTML = origHTML;
    btn.disabled  = false;
}

// ── Toggle Enable/Disable ─────────────────────────────────────
async function toggleTarget(id) {
    try {
        const r = await fetch(`/ip-monitor/${id}/toggle`, { method: 'POST' });
        const d = await r.json();
        if (d.success) { location.reload(); }
        else imToast(d.message, false);
    } catch(e) { imToast('Error: ' + e.message, false); }
}

// ── Delete ────────────────────────────────────────────────────
async function deleteTarget(id, name) {
    if (!confirm(`Hapus target "${name}"?`)) return;
    try {
        const r = await fetch(`/ip-monitor/${id}`, { method: 'DELETE' });
        const d = await r.json();
        if (d.success) {
            imToast(d.message);
            const row = document.getElementById('row-' + id);
            if (row) row.remove();
        } else {
            imToast(d.message, false);
        }
    } catch(e) { imToast('Error: ' + e.message, false); }
}

// ── Search filter ─────────────────────────────────────────────
function filterTable() {
    const q = document.getElementById('searchBox').value.toLowerCase();
    document.querySelectorAll('#monitorTable tbody tr[id^="row-"]').forEach(row => {
        const match = row.dataset.name.includes(q) || row.dataset.ip.includes(q);
        row.style.display = match ? '' : 'none';
    });
}

// ── Close modal on backdrop click ─────────────────────────────
document.querySelectorAll('.modal-overlay').forEach(ov => {
    ov.addEventListener('click', e => { if (e.target === ov) ov.classList.remove('open'); });
});

// ── Timestamp ────────────────────────────────────────────────
document.getElementById('lastRefresh').textContent = 'Dimuat: ' + new Date().toLocaleTimeString('id-ID');
</script>

</body>
</html>
