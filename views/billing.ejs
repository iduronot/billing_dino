<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <style>
        /* ── Date Banner ── */
        .date-banner { background:linear-gradient(135deg,rgba(59,130,246,.1),rgba(139,92,246,.1)); border:1px solid rgba(59,130,246,.2); border-radius:16px; padding:18px 24px; margin-bottom:20px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px; }
        .date-left { display:flex; align-items:center; gap:20px; }
        .date-clock { font-size:34px; font-weight:800; font-variant-numeric:tabular-nums; background:linear-gradient(135deg,#60A5FA,#A78BFA); -webkit-background-clip:text; -webkit-text-fill-color:transparent; line-height:1; }
        .date-detail { display:flex; flex-direction:column; gap:2px; }
        .date-day  { font-size:18px; font-weight:700; }
        .date-full { font-size:12px; color:var(--muted); }

        /* ── Date Filter ── */
        .date-filter { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
        .date-filter label { font-size:11px; color:var(--muted); font-weight:600; }
        .date-filter input[type=date],
        .date-filter select.df-select { background:var(--sub-bg); border:1px solid var(--border); color:var(--text); border-radius:8px; padding:7px 10px; font-size:12px; font-family:'Outfit',sans-serif; outline:none; }
        .date-filter input[type=date]:focus,
        .date-filter select.df-select:focus { border-color:var(--primary); }
        .date-filter select.df-select option { background:#1E293B; color:#F8FAFC; }
        .date-filter .df-btn { background:var(--primary); color:white; border:none; border-radius:8px; padding:7px 14px; font-size:12px; font-weight:600; cursor:pointer; font-family:'Outfit',sans-serif; }
        .date-filter .df-reset { background:var(--sub-bg); border:1px solid var(--border); color:var(--muted); border-radius:8px; padding:7px 12px; font-size:12px; cursor:pointer; font-family:'Outfit',sans-serif; text-decoration:none; display:inline-flex; align-items:center; gap:4px; }

        /* ── Stats ── */
        .stats-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(190px,1fr)); gap:14px; margin-bottom:20px; }
        .stat-card { background:var(--card-bg); border:1px solid var(--border); border-radius:16px; padding:20px; position:relative; overflow:hidden; }
        .stat-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
        .stat-card.green::before  { background:linear-gradient(90deg,#10B981,#34D399); }
        .stat-card.orange::before { background:linear-gradient(90deg,#F59E0B,#FCD34D); }
        .stat-card.red::before    { background:linear-gradient(90deg,#EF4444,#F87171); }
        .stat-card.blue::before   { background:linear-gradient(90deg,#3B82F6,#6366F1); }
        .stat-card.purple::before { background:linear-gradient(90deg,#8B5CF6,#A78BFA); }
        .stat-label { font-size:12px; color:var(--muted); margin-bottom:8px; font-weight:500; }
        .stat-value { font-size:24px; font-weight:700; line-height:1; }
        .stat-sub   { font-size:11px; color:var(--muted); margin-top:6px; }
        .stat-badge { font-size:10px; padding:2px 7px; border-radius:10px; margin-left:6px; background:rgba(59,130,246,.15); color:var(--primary); font-weight:600; }

        /* ── Filter Stats (saat filter aktif) ── */
        .filter-stats { background:rgba(59,130,246,.06); border:1px solid rgba(59,130,246,.2); border-radius:12px; padding:14px 18px; margin-bottom:18px; display:flex; align-items:center; gap:20px; flex-wrap:wrap; }
        .filter-stats-title { font-size:12px; color:var(--primary); font-weight:700; }
        .filter-stats-item { font-size:13px; }
        .filter-stats-item b { color:var(--text); }

        /* ── Toolbar ── */
        .toolbar { display:flex; gap:10px; margin-bottom:14px; flex-wrap:wrap; align-items:center; }
        .toolbar input, .toolbar select { background:var(--sub-bg); border:1px solid var(--border); color:var(--text); border-radius:10px; padding:8px 12px; font-size:13px; font-family:'Outfit',sans-serif; outline:none; }
        .toolbar select option { background:#1E293B; color:#F8FAFC; }
        .light-theme .toolbar select option { background:#fff; color:#1E293B; }

        /* ── Table & Pagination ── */
        .card { background:var(--card-bg); border:1px solid var(--border); border-radius:16px; overflow:hidden; margin-bottom:20px; }
        table { width:100%; border-collapse:collapse; }
        th { background:var(--sub-bg); color:var(--muted); font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.6px; padding:11px 14px; text-align:left; white-space:nowrap; }
        td { padding:11px 14px; border-bottom:1px solid var(--border); font-size:13px; vertical-align:middle; }
        tr:last-child td { border-bottom:none; }
        tr:hover td { background:var(--hover-bg); }
        .pagination { display:flex; justify-content:space-between; align-items:center; padding:14px 18px; border-top:1px solid var(--border); flex-wrap:wrap; gap:10px; }
        .page-info { font-size:13px; color:var(--muted); }
        .page-info b { color:var(--text); }
        .page-btns { display:flex; gap:6px; }
        .page-btn { padding:6px 14px; border-radius:8px; border:1px solid var(--border); background:var(--sub-bg); color:var(--muted); text-decoration:none; font-size:13px; transition:all .2s; }
        .page-btn:hover, .page-btn.active { background:var(--primary); color:white; border-color:var(--primary); }

        /* ── Modal ── */
        .overlay { position:fixed; top:0; left:0; right:0; bottom:0; background:var(--overlay-bg); backdrop-filter:blur(4px); display:none; align-items:center; justify-content:center; z-index:999; }
        .modal { background:var(--modal-bg); border:1px solid var(--border); border-radius:20px; width:100%; max-width:480px; padding:28px; }
        .modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
        .modal-title { font-size:18px; font-weight:600; margin:0; }
        .close-btn { background:none; border:none; color:var(--muted); font-size:22px; cursor:pointer; }
        .form-group { margin-bottom:14px; }
        .form-group label { display:block; margin-bottom:6px; font-size:13px; color:var(--muted); }
        .toast { position:fixed; bottom:24px; right:24px; background:var(--toast-bg); color:var(--text); border:1px solid var(--border); border-radius:12px; padding:14px 20px; z-index:9999; display:none; font-size:14px; box-shadow:0 8px 24px rgba(0,0,0,.5); }
        .toast.show { display:block; }

        /* ── Searchable Customer Picker ── */
        .cust-picker { position:relative; }
        .cust-input-wrap {
            display:flex; align-items:center; gap:8px;
            background:var(--input-bg,var(--sub-bg)); border:1px solid var(--border);
            border-radius:10px; padding:0 12px; transition:border-color .2s;
        }
        .cust-input-wrap:focus-within { border-color:var(--primary); box-shadow:0 0 0 3px rgba(59,130,246,.12); }
        .cust-search-icon { color:var(--muted); font-size:13px; flex-shrink:0; }
        .cust-search-input {
            flex:1; background:none; border:none; outline:none; padding:11px 0;
            color:var(--text); font-size:14px; font-family:'Outfit',sans-serif;
        }
        .cust-search-input::placeholder { color:var(--muted); }
        .cust-clear {
            background:none; border:none; color:var(--muted); font-size:18px;
            cursor:pointer; line-height:1; padding:0; flex-shrink:0;
        }
        .cust-clear:hover { color:var(--text); }
        .cust-dropdown {
            display:none; position:absolute; left:0; right:0; top:calc(100% + 6px);
            background:var(--modal-bg); border:1px solid var(--border); border-radius:12px;
            max-height:260px; overflow-y:auto; z-index:6000;
            box-shadow:0 12px 40px rgba(0,0,0,.5);
        }
        .cust-dropdown.open { display:block; }
        .cust-item {
            padding:11px 16px; cursor:pointer; border-bottom:1px solid var(--border);
            transition:background .1s;
        }
        .cust-item:last-child { border-bottom:none; }
        .cust-item:hover, .cust-item.focused { background:rgba(59,130,246,.1); }
        .cust-item-name { font-size:14px; font-weight:600; color:var(--text); }
        .cust-item-sub { font-size:11px; color:var(--muted); margin-top:2px; display:flex; gap:10px; }
        .cust-item-sub span { display:inline-flex; align-items:center; gap:4px; }
        .cust-empty { padding:24px 16px; text-align:center; color:var(--muted); font-size:13px; }
        .cust-counter { padding:6px 14px; font-size:11px; color:var(--muted); border-bottom:1px solid var(--border); background:var(--sub-bg); }

        /* ── Action Menu ── */
        .act-wrap { display:flex; align-items:center; gap:6px; }
        .act-pay {
            display:inline-flex; align-items:center; gap:6px;
            background:linear-gradient(135deg,#10B981,#059669);
            color:white; border:none; border-radius:8px;
            padding:6px 12px; font-size:12px; font-weight:600;
            cursor:pointer; font-family:'Outfit',sans-serif;
            white-space:nowrap; transition:opacity .15s;
        }
        .act-pay:hover { opacity:.88; }
        .act-paid-badge {
            display:inline-flex; align-items:center; gap:5px;
            background:rgba(16,185,129,.12); color:#10B981;
            border:1px solid rgba(16,185,129,.25); border-radius:8px;
            padding:5px 10px; font-size:12px; font-weight:600;
            white-space:nowrap;
        }
        .act-more { position:relative; }
        .act-more-btn {
            width:32px; height:32px; border-radius:8px;
            border:1px solid var(--border); background:var(--sub-bg);
            color:var(--muted); cursor:pointer; font-size:18px; line-height:1;
            display:flex; align-items:center; justify-content:center;
            transition:all .15s;
        }
        .act-more-btn:hover { background:rgba(255,255,255,.1); color:var(--text); }
        .act-dropdown {
            display:none; position:absolute; right:0; top:calc(100% + 6px);
            background:var(--modal-bg); border:1px solid var(--border);
            border-radius:12px; min-width:180px; z-index:5000;
            box-shadow:0 8px 32px rgba(0,0,0,.45); overflow:hidden;
        }
        .act-dropdown.open { display:block; }
        .act-dropdown hr { border:none; border-top:1px solid var(--border); margin:4px 0; }
        .act-dropdown button,
        .act-dropdown a {
            display:flex; align-items:center; gap:10px; width:100%;
            padding:10px 14px; background:none; border:none;
            color:var(--text); font-size:13px; font-family:'Outfit',sans-serif;
            cursor:pointer; text-decoration:none; text-align:left;
            transition:background .12s;
        }
        .act-dropdown button:hover,
        .act-dropdown a:hover { background:rgba(255,255,255,.06); }
        .act-dropdown button.danger { color:#EF4444; }
        .act-dropdown button.danger:hover { background:rgba(239,68,68,.08); }
        .act-dropdown .act-icon { width:20px; text-align:center; font-size:14px; opacity:.85; }
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: t.billing_invoice }) %>
    <div class="content">

        <!-- ── DATE BANNER ── -->
        <div class="date-banner">
            <div class="date-left">
                <div class="date-clock" id="liveClock">--:--</div>
                <div class="date-detail">
                    <div class="date-day"  id="liveDay">--</div>
                    <div class="date-full" id="liveDate">-- --- ----</div>
                </div>
            </div>
            <!-- Date Filter -->
            <form method="GET" action="/billing" class="date-filter" id="dateForm">
                <input type="hidden" name="status"  value="<%= statusFilter %>">
                <input type="hidden" name="search"  value="<%= search %>">
                <input type="hidden" name="page"    value="1">
                <label>Kolom</label>
                <select name="dateField" class="df-select">
                    <option value="created_at" <%= dateField==='created_at'?'selected':'' %>>Tgl Buat</option>
                    <option value="due_date"   <%= dateField==='due_date'  ?'selected':'' %>>Jatuh Tempo</option>
                    <option value="paid_at"    <%= dateField==='paid_at'   ?'selected':'' %>>Tgl Bayar</option>
                </select>
                <label>Dari</label>
                <input type="date" name="dateFrom" value="<%= dateFrom %>">
                <label>Sampai</label>
                <input type="date" name="dateTo"   value="<%= dateTo %>">
                <button type="submit" class="df-btn"><i class="fas fa-filter"></i> Filter</button>
                <% if (useDate) { %>
                <a href="/billing?status=<%= statusFilter %>&search=<%= search %>" class="df-reset">
                    <i class="fas fa-times"></i> Reset
                </a>
                <% } %>
            </form>
        </div>

        <!-- Header -->
        <div class="page-header">
            <h1 class="page-title"><%= t.invoice_list %></h1>
            <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;align-items:center">
                <button class="btn btn-warning" onclick="generateBulk()">⚡ <%= t.generate_bulk %></button>
                <button class="btn" style="background:rgba(239,68,68,.15);color:var(--danger);border:1px solid rgba(239,68,68,.3)" onclick="runIsolir()">🔒 <%= t.auto_isolir %></button>
                <button class="btn" style="background:rgba(37,211,102,.15);color:#25D366;border:1px solid rgba(37,211,102,.3)" onclick="sendReminders()">📱 <%= t.send_wa_reminder %></button>
                <a href="/export/invoices" class="btn" style="background:rgba(16,185,129,.15);color:var(--success);border:1px solid rgba(16,185,129,.3)">📥 <%= t.export_csv %></a>
                <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='flex'">+ <%= t.add_invoice %></button>
            </div>
        </div>

        <!-- ── STAT CARDS ── -->
        <div class="stats-grid">
            <div class="stat-card green">
                <div class="stat-label"><%= t.paid %> (Global)</div>
                <div class="stat-value"><%= stats.paid || 0 %></div>
                <div class="stat-sub">semua invoice lunas</div>
            </div>
            <div class="stat-card orange">
                <div class="stat-label"><%= t.unpaid %> (Global)</div>
                <div class="stat-value"><%= stats.unpaid || 0 %></div>
                <div class="stat-sub">belum terbayar</div>
            </div>
            <div class="stat-card red">
                <div class="stat-label"><%= t.overdue %></div>
                <div class="stat-value"><%= stats.overdue || 0 %></div>
                <div class="stat-sub">lewat jatuh tempo</div>
            </div>
            <div class="stat-card blue">
                <div class="stat-label"><%= t.monthly_revenue %></div>
                <div class="stat-value" style="font-size:18px;">Rp <%= Math.floor(stats.totalRevenue||0).toLocaleString('id-ID') %></div>
                <div class="stat-sub">bulan ini</div>
            </div>
        </div>

        <!-- ── STATS FILTER (muncul hanya jika filter aktif) ── -->
        <% if (useDate && filteredStats) { %>
        <div class="filter-stats">
            <span class="filter-stats-title">
                <i class="fas fa-filter"></i>
                Hasil Filter:
                <%= dateField === 'created_at' ? 'Tgl Buat' : dateField === 'due_date' ? 'Jatuh Tempo' : 'Tgl Bayar' %>
                <% if (dateFrom) { %> dari <b><%= new Date(dateFrom).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %></b><% } %>
                <% if (dateTo)   { %> s/d <b><%= new Date(dateTo).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %></b><% } %>
            </span>
            <span class="filter-stats-item">💰 Pendapatan: <b>Rp <%= Math.floor(filteredStats.revenue||0).toLocaleString('id-ID') %></b></span>
            <span class="filter-stats-item">✅ Lunas: <b><%= filteredStats.paid || 0 %></b></span>
            <span class="filter-stats-item">⏳ Belum: <b><%= filteredStats.unpaid || 0 %></b></span>
            <span class="filter-stats-item" style="color:var(--muted);">📋 Total tampil: <b><%= pagination.total %></b> invoice</span>
        </div>
        <% } %>

        <!-- ── TOOLBAR ── -->
        <form method="GET" action="/billing" style="display:flex;gap:8px;align-items:center;margin-bottom:14px;flex-wrap:nowrap;">
            <input type="hidden" name="dateFrom"  value="<%= dateFrom %>">
            <input type="hidden" name="dateTo"    value="<%= dateTo %>">
            <input type="hidden" name="dateField" value="<%= dateField %>">
            <input type="hidden" name="page"      value="1">
            <input type="text" name="search" class="form-control" placeholder="<%= t.search_customer %>" value="<%= search %>" style="flex:1;min-width:180px;max-width:280px;">
            <select name="status" class="form-control" style="width:150px;flex-shrink:0;">
                <option value="all"    <%= statusFilter==='all'   ?'selected':'' %>><%= t.all_status %></option>
                <option value="paid"   <%= statusFilter==='paid'  ?'selected':'' %>><%= t.paid %></option>
                <option value="unpaid" <%= statusFilter==='unpaid'?'selected':'' %>><%= t.unpaid %></option>
            </select>
            <button type="submit" class="btn btn-primary" style="white-space:nowrap;flex-shrink:0;"><i class="fas fa-search"></i> <%= t.search_btn %></button>
            <% if (search || statusFilter !== 'all') { %>
            <a href="/billing?dateFrom=<%= dateFrom %>&dateTo=<%= dateTo %>&dateField=<%= dateField %>" class="btn" style="background:var(--sub-bg);border:1px solid var(--border);color:var(--muted);flex-shrink:0;white-space:nowrap;">✕ Reset</a>
            <% } %>
        </form>

        <!-- ── TABLE ── -->
        <div class="card">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th><%= t.customer %></th>
                        <th>Paket</th>
                        <th><%= t.amount %></th>
                        <th><%= t.due_date %></th>
                        <th>Dibuat</th>
                        <th><%= t.status %></th>
                        <th><%= t.action %></th>
                    </tr>
                </thead>
                <tbody>
                <% if (invoices && invoices.length > 0) { %>
                    <% invoices.forEach(i => { %>
                    <tr>
                        <td style="color:var(--muted);font-size:11px;">#<%= i.id %></td>
                        <td>
                            <div style="font-weight:600;"><%= i.customer_name || '-' %></div>
                            <div style="font-size:11px;color:var(--muted);"><%= i.pppoe_username || '' %></div>
                            <% if(i.customer_status === 'isolated') { %>
                            <span class="badge" style="background:rgba(239,68,68,.1);color:var(--danger);border:1px solid rgba(239,68,68,.2);font-size:10px;"><%= t.isolated %></span>
                            <% } %>
                        </td>
                        <td style="font-size:12px;color:var(--muted);"><%= i.package_name || '-' %></td>
                        <td style="font-weight:700;">Rp <%= parseFloat(i.amount).toLocaleString('id-ID') %></td>
                        <td>
                            <div style="color:var(--text);">
                                <%= i.due_date ? new Date(i.due_date).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) : '-' %>
                            </div>
                            <% if(i.status === 'unpaid' && i.due_date && new Date(i.due_date) < new Date()) { %>
                            <div style="color:var(--danger);font-size:11px;font-weight:600;">⚠ <%= t.late %></div>
                            <% } %>
                        </td>
                        <td style="font-size:12px;color:var(--muted);">
                            <%= i.created_at ? new Date(i.created_at).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) : '-' %>
                        </td>
                        <td>
                            <span class="badge badge-<%= i.status %>"><%= i.status === 'paid' ? '✓ ' + t.paid : t.unpaid %></span>
                            <% if(i.status === 'paid' && i.paid_at) { %>
                            <div style="font-size:11px;color:var(--muted);margin-top:3px;">
                                <%= new Date(i.paid_at).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) %>
                            </div>
                            <% } %>
                        </td>
                        <td>
                            <div class="act-wrap">
                                <% if(i.status !== 'paid') { %>
                                <button class="act-pay" onclick="payInvoice(<%= i.id %>)">
                                    <i class="fas fa-check-circle"></i> Catat Bayar
                                </button>
                                <% } else { %>
                                <span class="act-paid-badge">
                                    <i class="fas fa-check-circle"></i> Lunas
                                </span>
                                <% } %>

                                <div class="act-more">
                                    <button class="act-more-btn" onclick="toggleActMenu(this)" title="Aksi lainnya">⋮</button>
                                    <div class="act-dropdown">
                                        <% if(i.status !== 'paid') { %>
                                        <button onclick="closeAllMenus();unisolateOnly(<%= i.id %>)">
                                            <span class="act-icon"><i class="fas fa-unlock"></i></span> Aktifkan PPPoE
                                        </button>
                                        <button onclick="closeAllMenus();deferInvoice(<%= i.id %>)">
                                            <span class="act-icon"><i class="fas fa-calendar-alt"></i></span> Tunda Invoice
                                        </button>
                                        <hr>
                                        <% } %>
                                        <button onclick="closeAllMenus();openEditById(<%= i.id %>)">
                                            <span class="act-icon"><i class="fas fa-edit"></i></span> Edit Invoice
                                        </button>
                                        <button onclick="closeAllMenus();openPrintModal(<%= i.id %>)">
                                            <span class="act-icon"><i class="fas fa-print"></i></span> Cetak Invoice
                                        </button>
                                        <button onclick="closeAllMenus();sendWA('<%= i.customer_phone %>','#<%= i.id %>','<%= parseFloat(i.amount).toLocaleString('id-ID') %>','<%= i.due_date ? new Date(i.due_date).toLocaleDateString('id-ID') : '' %>')">
                                            <span class="act-icon" style="color:#25D366"><i class="fab fa-whatsapp"></i></span> Kirim WA Tagihan
                                        </button>
                                        <% if(i.status !== 'paid') { %>
                                        <hr>
                                        <button class="danger" onclick="closeAllMenus();deleteItem('/billing/api/<%= i.id %>','<%= t.delete_confirm %>')">
                                            <span class="act-icon"><i class="fas fa-trash-alt"></i></span> Hapus Invoice
                                        </button>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                <% } else { %>
                    <tr><td colspan="8" style="text-align:center;color:var(--muted);padding:50px;">
                        <i class="fas fa-file-invoice" style="font-size:32px;opacity:.3;display:block;margin-bottom:12px;"></i>
                        <%= t.no_customer_data %>
                    </td></tr>
                <% } %>
                </tbody>
            </table>

            <!-- Pagination -->
            <% if (pagination.totalPages >= 1) { %>
            <%
                const buildUrl = (p) => {
                    const q = new URLSearchParams();
                    if (search)                  q.set('search', search);
                    if (statusFilter !== 'all')  q.set('status', statusFilter);
                    if (dateFrom)                q.set('dateFrom', dateFrom);
                    if (dateTo)                  q.set('dateTo', dateTo);
                    if (dateField)               q.set('dateField', dateField);
                    q.set('page', p);
                    return '/billing?' + q.toString();
                };
            %>
            <div class="pagination">
                <div class="page-info">
                    Menampilkan <b><%= Math.min((pagination.page-1)*pagination.perPage+1, pagination.total) %>–<%= Math.min(pagination.page*pagination.perPage, pagination.total) %></b>
                    dari <b><%= pagination.total %></b> invoice
                </div>
                <div class="page-btns">
                    <a href="<%= buildUrl(pagination.page-1) %>" class="page-btn <%= pagination.page <= 1 ? 'disabled' : '' %>" style="<%= pagination.page <= 1 ? 'pointer-events:none;opacity:.4;' : '' %>">← Prev</a>
                    <span class="page-btn active"><%= pagination.page %> / <%= pagination.totalPages %></span>
                    <a href="<%= buildUrl(pagination.page+1) %>" class="page-btn <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>" style="<%= pagination.page >= pagination.totalPages ? 'pointer-events:none;opacity:.4;' : '' %>">Next →</a>
                </div>
            </div>
            <% } %>
        </div>

    </div>
</main>

<!-- Add Invoice Modal -->
<div class="overlay" id="addModal" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal" onclick="event.stopPropagation()" style="max-width:500px;">
        <div class="modal-header">
            <h2 class="modal-title">➕ <%= t.add_invoice %></h2>
            <button class="close-btn" onclick="document.getElementById('addModal').style.display='none'">×</button>
        </div>
        <form id="addInvoiceForm">
            <!-- Searchable Customer Picker -->
            <div class="form-group">
                <label><%= t.customer %> *</label>
                <input type="hidden" id="invCustomer" required>
                <div class="cust-picker" id="custPicker">
                    <div class="cust-input-wrap">
                        <i class="fas fa-search cust-search-icon"></i>
                        <input type="text" id="custSearch" class="cust-search-input"
                            placeholder="Ketik nama atau PPPoE username..." autocomplete="off"
                            oninput="filterCustomers()" onfocus="openCustDropdown()" onkeydown="custKeyNav(event)">
                        <button type="button" class="cust-clear" id="custClear" onclick="clearCustPicker()" style="display:none">×</button>
                    </div>
                    <div class="cust-dropdown" id="custDropdown"></div>
                </div>
                <div id="custSelected" style="display:none; margin-top:8px; padding:10px 14px; background:rgba(59,130,246,.08); border:1px solid rgba(59,130,246,.25); border-radius:10px; font-size:13px;">
                    <span style="color:var(--primary); font-weight:600;" id="custSelectedName"></span>
                    <span style="color:var(--muted); font-size:11px; margin-left:8px;" id="custSelectedInfo"></span>
                </div>
            </div>
            <div class="form-group">
                <label><%= t.amount %> (Rp)</label>
                <input type="number" id="invAmount" class="form-control" placeholder="Otomatis dari paket jika kosong">
            </div>
            <div class="form-group">
                <label><%= t.due_date %></label>
                <input type="date" id="invDue" class="form-control">
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:13px;margin-top:6px;font-size:15px;">
                <i class="fas fa-save"></i> <%= t.save %>
            </button>
        </form>
    </div>
</div>

<!-- Edit Invoice Modal -->
<div class="overlay" id="editModal" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal" onclick="event.stopPropagation()">
        <div class="modal-header"><h2 class="modal-title"><%= t.edit_invoice %></h2><button class="close-btn" onclick="document.getElementById('editModal').style.display='none'">×</button></div>
        <form id="editInvForm">
            <input type="hidden" id="editInvId">
            <div class="form-group"><label>Invoice #</label><input type="text" id="editInvNum" class="form-control" readonly style="opacity:.6"></div>
            <div class="form-group"><label><%= t.amount %> (Rp)</label><input type="number" id="editInvAmount" class="form-control" required></div>
            <div class="form-group"><label><%= t.due_date %></label><input type="date" id="editInvDue" class="form-control" required></div>
            <div class="form-group"><label><%= t.status_label %></label>
                <select id="editInvStatus" class="form-control">
                    <option value="unpaid"><%= t.unpaid %></option>
                    <option value="paid"><%= t.paid %></option>
                    <option value="cancelled"><%= t.cancelled %></option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:12px;margin-top:6px;"><%= t.save_changes %></button>
        </form>
    </div>
</div>

<div class="toast" id="toast"></div>
<textarea id="invoicesData" style="display:none;"><%= JSON.stringify(invoices) %></textarea>
<textarea id="customersData" style="display:none;"><%= JSON.stringify(customers.map(c=>({id:c.id,name:c.name,phone:c.phone||'',pppoe:c.pppoe_username||'',pkg:c.package_name||'',price:c.package_price||0,iso:c.isolation_date||20}))) %></textarea>

<script>
// ── Searchable Customer Picker ──
let allCustomers = [];
try { allCustomers = JSON.parse(document.getElementById('customersData').value); } catch(e) {}

let custFocusIdx = -1;

function openCustDropdown() {
    filterCustomers();
    document.getElementById('custDropdown').classList.add('open');
}

function filterCustomers() {
    const q = document.getElementById('custSearch').value.toLowerCase().trim();
    const dropdown = document.getElementById('custDropdown');
    const MAX = 80;

    const filtered = q
        ? allCustomers.filter(c =>
            c.name.toLowerCase().includes(q) ||
            c.pppoe.toLowerCase().includes(q) ||
            c.phone.includes(q))
        : allCustomers;

    custFocusIdx = -1;
    document.getElementById('custClear').style.display = q ? 'block' : 'none';

    if (filtered.length === 0) {
        dropdown.innerHTML = `<div class="cust-empty"><i class="fas fa-search" style="opacity:.4;font-size:20px;display:block;margin-bottom:8px;"></i>Tidak ada pelanggan "<b>${q}</b>"</div>`;
        dropdown.classList.add('open');
        return;
    }

    const shown = filtered.slice(0, MAX);
    let html = '';
    if (filtered.length > MAX) {
        html += `<div class="cust-counter">Menampilkan ${MAX} dari ${filtered.length} hasil — ketik lebih spesifik</div>`;
    } else if (filtered.length > 0) {
        html += `<div class="cust-counter">${filtered.length} pelanggan ditemukan</div>`;
    }
    html += shown.map((c, idx) => `
        <div class="cust-item" data-id="${c.id}" data-idx="${idx}" onclick="selectCustomer(${c.id},'${c.name.replace(/'/g,"\\'")}','${c.pppoe}','${c.pkg}',${c.price},${c.iso})">
            <div class="cust-item-name">${highlight(c.name, q)}</div>
            <div class="cust-item-sub">
                ${c.pppoe ? `<span><i class="fas fa-network-wired"></i> ${highlight(c.pppoe, q)}</span>` : ''}
                ${c.phone ? `<span><i class="fas fa-phone"></i> ${c.phone}</span>` : ''}
                ${c.pkg   ? `<span><i class="fas fa-box"></i> ${c.pkg}</span>` : ''}
            </div>
        </div>`).join('');

    dropdown.innerHTML = html;
    dropdown.classList.add('open');
}

function highlight(text, q) {
    if (!q) return text;
    const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi');
    return text.replace(re, '<mark style="background:rgba(59,130,246,.3);color:inherit;border-radius:2px;padding:0 1px;">$1</mark>');
}

function selectCustomer(id, name, pppoe, pkg, price, iso) {
    document.getElementById('invCustomer').value = id;
    document.getElementById('custSearch').value  = name;
    document.getElementById('custClear').style.display = 'block';
    document.getElementById('custDropdown').classList.remove('open');

    // Show selected badge
    const sel = document.getElementById('custSelected');
    document.getElementById('custSelectedName').textContent = name;
    document.getElementById('custSelectedInfo').textContent =
        [pppoe ? '📡 '+pppoe : '', pkg ? '📦 '+pkg : '', price ? 'Rp '+Number(price).toLocaleString('id-ID') : ''].filter(Boolean).join('  •  ');
    sel.style.display = 'block';

    // Auto-fill amount & due date
    if (price && !document.getElementById('invAmount').value) {
        document.getElementById('invAmount').value = price;
    }
    if (!document.getElementById('invDue').value && iso) {
        const now = new Date();
        const y = now.getFullYear(), m = now.getMonth() + 1;
        document.getElementById('invDue').value = `${y}-${String(m).padStart(2,'0')}-${String(iso).padStart(2,'0')}`;
    }
    custFocusIdx = -1;
}

function clearCustPicker() {
    document.getElementById('invCustomer').value = '';
    document.getElementById('custSearch').value  = '';
    document.getElementById('custClear').style.display = 'none';
    document.getElementById('custSelected').style.display = 'none';
    document.getElementById('custDropdown').classList.remove('open');
    document.getElementById('invAmount').value = '';
    document.getElementById('invDue').value = '';
    document.getElementById('custSearch').focus();
}

function custKeyNav(e) {
    const items = document.querySelectorAll('#custDropdown .cust-item');
    if (!items.length) return;
    if (e.key === 'ArrowDown') {
        e.preventDefault();
        custFocusIdx = Math.min(custFocusIdx + 1, items.length - 1);
    } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        custFocusIdx = Math.max(custFocusIdx - 1, 0);
    } else if (e.key === 'Enter' && custFocusIdx >= 0) {
        e.preventDefault();
        items[custFocusIdx].click();
        return;
    } else if (e.key === 'Escape') {
        document.getElementById('custDropdown').classList.remove('open');
        return;
    }
    items.forEach((el, i) => el.classList.toggle('focused', i === custFocusIdx));
    if (custFocusIdx >= 0) items[custFocusIdx].scrollIntoView({ block:'nearest' });
}

// Tutup dropdown saat klik luar
document.addEventListener('click', (e) => {
    if (!e.target.closest('#custPicker')) {
        document.getElementById('custDropdown').classList.remove('open');
    }
});

// Reset picker saat modal dibuka
document.getElementById('addModal').addEventListener('click', function(e) {
    if (e.target === this) {
        clearCustPicker();
        document.getElementById('addInvoiceForm').reset();
    }
});

// ── Action dropdown ──
function toggleActMenu(btn) {
    const dropdown = btn.nextElementSibling;
    const isOpen = dropdown.classList.contains('open');
    closeAllMenus();
    if (!isOpen) dropdown.classList.add('open');
}
function closeAllMenus() {
    document.querySelectorAll('.act-dropdown.open').forEach(d => d.classList.remove('open'));
}
document.addEventListener('click', (e) => {
    if (!e.target.closest('.act-more')) closeAllMenus();
});

// ── Live Clock ──
const HARI  = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
const BULAN = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
function updateClock() {
    const now = new Date();
    const hh  = String(now.getHours()).padStart(2,'0');
    const mm  = String(now.getMinutes()).padStart(2,'0');
    document.getElementById('liveClock').textContent = `${hh}:${mm}`;
    document.getElementById('liveDay').textContent   = HARI[now.getDay()];
    document.getElementById('liveDate').textContent  = `${now.getDate()} ${BULAN[now.getMonth()]} ${now.getFullYear()}`;
}
updateClock(); setInterval(updateClock, 1000);

// ── Invoice actions ──
let allInvoices = [];
try { allInvoices = JSON.parse(document.getElementById('invoicesData').value); } catch(e) {}

document.getElementById('addInvoiceForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!document.getElementById('invCustomer').value) {
        document.getElementById('custSearch').focus();
        document.getElementById('custPicker').querySelector('.cust-input-wrap').style.borderColor = '#EF4444';
        setTimeout(() => document.getElementById('custPicker').querySelector('.cust-input-wrap').style.borderColor = '', 1500);
        return showToast('Pilih pelanggan terlebih dahulu', 'error');
    }
    const res = await fetch('/billing/api/create', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ customer_id: document.getElementById('invCustomer').value, amount: document.getElementById('invAmount').value||null, due_date: document.getElementById('invDue').value||null }) });
    const data = await res.json();
    showToast(data.message, data.success?'success':'error');
    if(data.success){ document.getElementById('addModal').style.display='none'; clearCustPicker(); document.getElementById('addInvoiceForm').reset(); setTimeout(()=>location.reload(),1000); }
});

document.getElementById('editInvForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('editInvId').value;
    const body = { amount: document.getElementById('editInvAmount').value, due_date: document.getElementById('editInvDue').value, status: document.getElementById('editInvStatus').value };
    const res = await fetch('/billing/api/' + id, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    const d = await res.json();
    showToast(d.message, d.success?'success':'error');
    if(d.success){ document.getElementById('editModal').style.display='none'; setTimeout(()=>location.reload(),1000); }
});

function openEditModal(inv) {
    document.getElementById('editInvId').value     = inv.id;
    document.getElementById('editInvNum').value    = '#' + inv.id;
    document.getElementById('editInvAmount').value = inv.amount;
    document.getElementById('editInvDue').value    = inv.due_date ? new Date(inv.due_date).toISOString().split('T')[0] : '';
    document.getElementById('editInvStatus').value = inv.status;
    document.getElementById('editModal').style.display = 'flex';
}
function openEditById(id) { const inv = allInvoices.find(x => x.id == id); if(inv) openEditModal(inv); }

async function payInvoice(id){if(!confirm(<%- JSON.stringify(t.confirm_pay) %>))return;const res=await fetch('/billing/api/'+id+'/pay',{method:'POST'});const d=await res.json();showToast(d.message,d.success?'success':'error');if(d.success)setTimeout(()=>location.reload(),1000);}
async function unisolateOnly(id){if(!confirm(<%- JSON.stringify(t.confirm_unisolate) %>))return;const res=await fetch('/billing/api/'+id+'/unisolate',{method:'POST'});const d=await res.json();showToast(d.message,d.success?'success':'error');if(d.success)setTimeout(()=>location.reload(),1000);}
async function deferInvoice(id){if(!confirm(<%- JSON.stringify(t.confirm_defer) %>))return;const res=await fetch('/billing/api/'+id+'/defer',{method:'POST'});const d=await res.json();showToast(d.message,d.success?'success':'error');if(d.success)setTimeout(()=>location.reload(),1200);}
async function deleteItem(url,msg){if(!confirm(msg))return;const res=await fetch(url,{method:'DELETE'});const d=await res.json();showToast(d.message,d.success?'success':'error');if(d.success)setTimeout(()=>location.reload(),1000);}
async function generateBulk(){if(!confirm(<%- JSON.stringify(t.confirm_generate_bulk) %>))return;showToast(<%- JSON.stringify(t.generating) %>,'success');const res=await fetch('/billing/api/generate-bulk',{method:'POST'});const d=await res.json();showToast(d.message,d.success?'success':'error');if(d.success)setTimeout(()=>location.reload(),2000);}
async function runIsolir(){if(!confirm(<%- JSON.stringify(t.confirm_run_isolir) %>))return;showToast(<%- JSON.stringify(t.running_isolir) %>,'success');const res=await fetch('/billing/api/run-isolir',{method:'POST'});const d=await res.json();showToast(d.message,d.success?'success':'error');if(d.success)setTimeout(()=>location.reload(),1500);}
async function sendReminders(){if(!confirm(<%- JSON.stringify(t.confirm_send_reminders) %>))return;showToast(<%- JSON.stringify(t.sending_reminders) %>,'success');try{const res=await fetch('/billing/api/send-reminders',{method:'POST'});const d=await res.json();showToast(d.message,d.success?'success':'error');}catch(e){showToast('Error: '+e.message,'error');}}
function sendWA(phone,invNum,amount,dueDate){if(!phone){alert(<%- JSON.stringify(t.no_phone) %>);return;}phone=phone.replace(/[^0-9]/g,'');if(phone.startsWith('0'))phone='62'+phone.substring(1);const rawMsg=<%- JSON.stringify(t.wa_bill_msg||'') %>;const msg=rawMsg.replace('{invNum}',invNum).replace('{amount}',amount).replace('{dueDate}',dueDate);window.open('https://wa.me/'+phone+'?text='+encodeURIComponent(msg),'_blank');}
function showToast(msg,type){const t=document.getElementById('toast');t.textContent=msg;t.style.borderColor=type==='success'?'rgba(16,185,129,.4)':'rgba(239,68,68,.4)';t.style.color=type==='success'?'#10B981':'#EF4444';t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3500);}
function openPrintModal(id){
    const modal=document.getElementById('printModal');
    const frame=document.getElementById('printFrame');
    frame.src='/print/invoice?ids='+id;
    modal.style.display='flex';
    document.body.style.overflow='hidden';
}
function closePrintModal(){
    const modal=document.getElementById('printModal');
    modal.style.display='none';
    document.getElementById('printFrame').src='about:blank';
    document.body.style.overflow='';
}
function doPrint(){document.getElementById('printFrame').contentWindow.print();}
</script>

<!-- Print Invoice Modal -->
<div id="printModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.85);backdrop-filter:blur(6px);align-items:center;justify-content:center;flex-direction:column;gap:12px">
    <div style="display:flex;align-items:center;gap:10px">
        <button onclick="doPrint()" style="background:linear-gradient(135deg,#3B82F6,#6366F1);color:white;border:none;border-radius:10px;padding:10px 22px;font-size:14px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;display:inline-flex;align-items:center;gap:8px"><i class="fas fa-print"></i> Cetak</button>
        <button onclick="closePrintModal()" style="background:rgba(255,255,255,0.1);color:white;border:1px solid rgba(255,255,255,0.2);border-radius:10px;padding:10px 22px;font-size:14px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif">Tutup</button>
    </div>
    <iframe id="printFrame" src="about:blank" style="width:min(860px,96vw);height:85vh;border:none;border-radius:16px;background:white;box-shadow:0 25px 60px rgba(0,0,0,0.5)"></iframe>
</div>
</body>
</html>
