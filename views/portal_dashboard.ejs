<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= company.company_name || 'Dino-Bill' %> | Portal Pelanggan</title>
    <script>
        const savedTheme = localStorage.getItem('theme') || 'dark';
        if (savedTheme === 'light') document.documentElement.classList.add('light-theme');
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');
        :root {
            --primary: #3B82F6; --secondary: #8B5CF6; --bg: #0B0F19; --card: rgba(30,41,59,.6);
            --border: rgba(255,255,255,0.08); --text: #F8FAFC; --muted: #94A3B8; --success: #10B981;
            --danger: #EF4444; --warning: #F59E0B; --input-bg: rgba(15,23,42,0.6);
            --nav-bg: rgba(17,24,39,0.8);
        }
        .light-theme {
            --bg: #F1F5F9; --card: #FFFFFF; --border: rgba(0,0,0,0.08);
            --text: #1E293B; --muted: #64748B; --input-bg: #FFFFFF;
            --nav-bg: rgba(255,255,255,0.9);
        }
        * { box-sizing: border-box; }
        body { margin:0; font-family:'Outfit',sans-serif; background:var(--bg); color:var(--text); padding-bottom:100px; transition: all 0.3s; }
        .container { max-width:500px; margin:0 auto; padding:20px; }

        .header { display:flex; justify-content:space-between; align-items:center; padding:10px 0 20px; }
        .brand { font-size:20px; font-weight:800; background:linear-gradient(135deg,#60A5FA,#A78BFA); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }

        .welcome-card { background:linear-gradient(135deg,rgba(59,130,246,0.2),rgba(139,92,246,0.1)); border:1px solid var(--border); border-radius:24px; padding:24px; margin-bottom:20px; text-align:center; position:relative; overflow:hidden; }
        .welcome-card::before { content:''; position:absolute; top:-50px; right:-50px; width:120px; height:120px; background:var(--primary); filter:blur(60px); opacity:0.3; }
        .user-name { font-size:22px; font-weight:700; margin:10px 0 4px; }
        .status-badge { display:inline-block; padding:6px 14px; border-radius:20px; font-size:11px; font-weight:700; margin-top:10px; text-transform:uppercase; letter-spacing:0.5px; }
        .status-active { background:rgba(16,185,129,0.15); color:var(--success); border:1px solid rgba(16,185,129,0.3); }
        .status-isolated { background:rgba(239,68,68,0.15); color:var(--danger); border:1px solid rgba(239,68,68,0.3); }

        .info-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px; }
        .info-card { background:var(--card); border:1px solid var(--border); border-radius:18px; padding:16px; text-align:center; backdrop-filter:blur(10px); }
        .info-label { font-size:11px; color:var(--muted); text-transform:uppercase; margin-bottom:4px; letter-spacing:0.5px; }
        .info-value { font-size:16px; font-weight:700; }

        .section-title { font-size:17px; font-weight:600; margin:20px 0 12px; padding-left:4px; }

        .invoice-card { background:var(--card); border:1px solid var(--border); border-radius:18px; padding:18px; margin-bottom:12px; }
        .inv-top { display:flex; justify-content:space-between; align-items:center; }
        .inv-info h4 { margin:0 0 4px; font-size:15px; }
        .inv-info p { margin:0; font-size:12px; color:var(--muted); }
        .badge { padding:4px 10px; border-radius:20px; font-size:10px; font-weight:700; text-transform:uppercase; }
        .badge-unpaid { background:rgba(245,158,11,0.15); color:var(--warning); border:1px solid rgba(245,158,11,0.3); }
        .badge-paid { background:rgba(16,185,129,0.15); color:var(--success); border:1px solid rgba(16,185,129,0.3); }
        .badge-inprog { background:rgba(59,130,246,0.15); color:var(--primary); border:1px solid rgba(59,130,246,0.3); }

        .btn { padding:12px 16px; border-radius:12px; border:none; font-weight:700; cursor:pointer; font-family:'Outfit',sans-serif; transition:all 0.2s; font-size:14px; width:100%; display:flex; align-items:center; justify-content:center; gap:8px; }
        .btn-primary { background:linear-gradient(135deg,var(--primary),#6366F1); color:white; box-shadow:0 8px 16px rgba(59,130,246,0.25); }
        .btn-qris { background:linear-gradient(135deg,#E53935,#D81B60); color:white; box-shadow:0 8px 16px rgba(229,57,53,0.3); margin-top:12px; height:48px; }
        .btn:active { transform: scale(0.98); }
        .btn:disabled { opacity:0.6; cursor:not-allowed; }

        .form-group { margin-bottom:14px; }
        .form-group label { display:block; font-size:12px; color:var(--muted); margin-bottom:6px; font-weight:500; }
        .form-control { width:100%; padding:12px 14px; background:var(--input-bg); border:1px solid var(--border); border-radius:10px; color:var(--text); font-size:14px; outline:none; font-family:'Outfit',sans-serif; }
        .form-control:focus { border-color:var(--primary); }

        .bottom-nav { position:fixed; bottom:20px; left:20px; right:20px; background:var(--nav-bg); backdrop-filter:blur(20px); border:1px solid var(--border); border-radius:24px; height:65px; display:flex; align-items:center; justify-content:space-around; z-index:1000; box-shadow:0 10px 30px rgba(0,0,0,0.2); }
        .nav-item { display:flex; flex-direction:column; align-items:center; gap:4px; color:var(--muted); text-decoration:none; transition:all 0.2s; cursor:pointer; }
        .nav-item.active { color:var(--primary); }
        .nav-item svg { width:22px; height:22px; }
        .nav-item span { font-size:10px; font-weight:600; }

        .page-section { display:none; animation: fadeIn 0.3s ease; }
        .page-section.active { display:block; }
        @keyframes fadeIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }

        .toast { position:fixed; bottom:100px; left:20px; right:20px; background:var(--bg); border:1px solid var(--border); border-radius:14px; padding:14px 20px; z-index:9999; display:none; font-size:14px; text-align:center; box-shadow:0 8px 24px rgba(0,0,0,0.5); }
        .toast.show { display:block; }

        /* ── QR Modal ── */
        .qr-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.75); backdrop-filter:blur(6px); z-index:3000; display:none; align-items:center; justify-content:center; padding:20px; }
        .qr-overlay.show { display:flex; }
        .qr-box { background:var(--bg); border:1px solid var(--border); border-radius:28px; padding:28px 24px; width:100%; max-width:380px; text-align:center; animation: fadeIn 0.25s ease; }
        .qr-title { font-size:18px; font-weight:700; margin-bottom:4px; }
        .qr-amount { font-size:26px; font-weight:800; color:var(--primary); margin:8px 0 16px; }
        .qr-img-wrap { background:white; border-radius:18px; padding:16px; display:inline-block; margin-bottom:16px; }
        .qr-img-wrap img { width:200px; height:200px; display:block; }
        .qr-status-row { display:flex; align-items:center; justify-content:center; gap:8px; font-size:13px; color:var(--muted); margin-bottom:16px; }
        .qr-status-dot { width:8px; height:8px; border-radius:50%; background:var(--warning); animation: pulse 1.4s infinite; }
        .qr-status-dot.paid { background:var(--success); animation:none; }
        @keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }
        .qr-timer { font-size:12px; color:var(--muted); margin-bottom:4px; }
        .qr-timer span { color:var(--warning); font-weight:700; }
        .qr-close { background:rgba(255,255,255,0.06); border:1px solid var(--border); color:var(--muted); border-radius:10px; padding:10px 20px; cursor:pointer; font-family:'Outfit',sans-serif; font-size:13px; font-weight:600; width:100%; }
        .qr-success-icon { font-size:56px; margin:8px 0; }

        /* Loading spinner */
        .spinner { width:36px; height:36px; border:3px solid rgba(255,255,255,0.1); border-top-color:var(--primary); border-radius:50%; animation:spin 0.8s linear infinite; margin:16px auto; }
        @keyframes spin { to { transform:rotate(360deg); } }
    </style>
</head>
<body>
<div class="container">
    <!-- Header -->
    <div class="header">
        <% if (company.company_logo) { %>
        <img src="<%= company.company_logo %>" alt="<%= company.company_name %>" style="max-height:36px;max-width:140px;object-fit:contain;filter:drop-shadow(0 2px 6px rgba(59,130,246,0.25))">
        <% } else { %>
        <span class="brand">🦖 <%= company.company_name || 'Dino-Net' %></span>
        <% } %>
        <div style="display:flex; align-items:center; gap:12px;">
            <button id="themeToggle" style="background:var(--card); border:1px solid var(--border); color:var(--text); width:32px; height:32px; border-radius:10px; cursor:pointer; display:flex; align-items:center; justify-content:center;">
                <i class="fas fa-moon"></i>
            </button>
            <div style="font-size:11px;color:var(--muted);font-weight:600">PORTAL</div>
        </div>
    </div>

    <!-- Section: HOME -->
    <div id="section-home" class="page-section active">
        <div class="welcome-card">
            <div style="width:50px;height:50px;border-radius:50%;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:20px;">👤</div>
            <div class="user-name"><%= customer.name %></div>
            <div style="color:var(--muted);font-size:13px;font-weight:500">PPPoE: <%= customer.pppoe_username || '-' %> | 📱 <%= customer.phone || '-' %></div>
            <div class="status-badge <%= customer.status === 'active' ? 'status-active' : 'status-isolated' %>">
                <%= customer.status === 'active' ? '● Aktif' : '● Terisolir' %>
            </div>
        </div>

        <div class="info-grid">
            <div class="info-card">
                <div class="info-label">Paket Layanan</div>
                <div class="info-value"><%= customer.package_name || 'Personal' %></div>
                <div style="font-size:10px;color:var(--muted);margin-top:4px"><%= customer.speed_limit || 'Best Effort' %></div>
            </div>
            <div class="info-card">
                <div class="info-label">Tagihan</div>
                <div class="info-value" style="color:<%= unpaidCount > 0 ? 'var(--danger)' : 'var(--success)' %>"><%= unpaidCount %></div>
                <div style="font-size:10px;color:var(--muted);margin-top:4px"><%= unpaidCount > 0 ? 'Belum Bayar' : 'Lunas ✓' %></div>
            </div>
        </div>

        <% if (unpaidCount > 0) { %>
        <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:20px;padding:20px;margin-bottom:20px;text-align:center">
            <div style="font-size:13px;color:var(--muted);font-weight:600">TOTAL TAGIHAN</div>
            <div style="font-size:28px;font-weight:800;margin:6px 0;color:var(--text)">Rp <%= parseFloat(unpaidTotal || 0).toLocaleString('id-ID') %></div>
            <div style="font-size:11px;color:var(--muted);background:rgba(255,255,255,0.05);display:inline-block;padding:4px 10px;border-radius:10px"><%= unpaidCount %> Invoice</div>
        </div>
        <% } %>

        <div class="section-title">Tagihan Terakhir</div>
        <% if (invoices.length > 0) { %>
            <% invoices.slice(0, 3).forEach((inv, invIdx) => { %>
            <div class="invoice-card">
                <div class="inv-top">
                    <div class="inv-info">
                        <h4>Periode <%= new Date(inv.due_date).toLocaleDateString('id-ID', { month: 'long', year: 'numeric' }) %></h4>
                        <p>Jatuh Tempo: <%= new Date(inv.due_date).toLocaleDateString('id-ID') %></p>
                        <p style="font-weight:700;margin-top:4px;color:var(--text);font-size:14px">Rp <%= parseFloat(inv.amount).toLocaleString('id-ID') %></p>
                    </div>
                    <span class="badge <%= inv.status === 'paid' ? 'badge-paid' : 'badge-unpaid' %>">
                        <%= inv.status === 'paid' ? 'Lunas' : 'Belum Bayar' %>
                    </span>
                </div>

                <% if (inv.status === 'unpaid') { %>
                <!-- Payment info inside unpaid invoice card -->
                <% if (paymentGateway === 'xendit') { %>
                <button class="btn btn-qris" onclick="openQRIS(<%= inv.id %>, <%= inv.amount %>)">
                    <i class="fas fa-qrcode"></i> Bayar dengan QRIS
                </button>
                <% } else { %>
                <!-- Tab switcher per invoice -->
                <div style="margin-top:14px">
                    <div style="display:flex;gap:5px;background:var(--input-bg);border:1px solid var(--border);border-radius:12px;padding:3px;margin-bottom:12px">
                        <button id="ptab-transfer-<%= inv.id %>" onclick="switchPayTab(<%= inv.id %>,'transfer')" style="flex:1;padding:8px;border:none;border-radius:9px;font-weight:700;font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif;background:var(--primary);color:#fff;transition:all .2s">🏦 Transfer Bank</button>
                        <button id="ptab-qris-<%= inv.id %>" onclick="switchPayTab(<%= inv.id %>,'qris')" style="flex:1;padding:8px;border:none;border-radius:9px;font-weight:700;font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif;background:none;color:var(--muted);transition:all .2s">🔲 QRIS</button>
                    </div>
                    <!-- Transfer Bank pane -->
                    <div id="ppane-transfer-<%= inv.id %>" style="background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.3);border-radius:12px;padding:14px">
                        <div style="color:var(--warning);font-weight:700;font-size:13px;margin-bottom:8px">💳 Transfer Bank</div>
                        <div style="font-size:13px;color:var(--text);line-height:1.9">
                            Bank: <strong style="color:var(--primary)"><%= company.bank_name %></strong><br>
                            No. Rek: <strong style="color:var(--primary);font-size:15px;letter-spacing:.5px"><%= company.bank_account %></strong>
                            <button onclick="copyText('<%= company.bank_account %>')" style="margin-left:6px;background:rgba(59,130,246,.15);color:var(--primary);border:1px solid rgba(59,130,246,.3);border-radius:6px;padding:2px 8px;font-size:11px;cursor:pointer">Salin</button><br>
                            A/N: <strong><%= company.bank_holder %></strong>
                        </div>
                    </div>
                    <!-- QRIS pane -->
                    <div id="ppane-qris-<%= inv.id %>" style="display:none;text-align:center">
                        <% if (company.qris_image) { %>
                        <div style="background:rgba(16,185,129,.06);border:1px solid rgba(16,185,129,.3);border-radius:12px;padding:14px">
                            <div style="color:var(--success);font-weight:700;font-size:13px;margin-bottom:10px">🔲 Scan QRIS untuk Bayar</div>
                            <img src="<%= company.qris_image %>" alt="QRIS" style="max-width:220px;width:100%;border-radius:10px;border:1px solid var(--border);background:#fff;padding:6px">
                            <div style="font-size:11px;color:var(--muted);margin-top:8px">Scan menggunakan aplikasi bank / e-wallet manapun</div>
                        </div>
                        <% } else { %>
                        <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;color:var(--muted);font-size:13px">
                            <div style="font-size:24px;margin-bottom:6px">🔲</div>
                            QRIS belum dikonfigurasi admin
                        </div>
                        <% } %>
                    </div>
                </div>
                <% } %>

                <!-- Upload bukti bayar -->
                <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border)">
                    <% if (inv.proof_image) { %>
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;background:rgba(16,185,129,.06);border:1px solid rgba(16,185,129,.25);border-radius:10px;padding:10px">
                        <img src="<%= inv.proof_image %>" alt="Bukti" onclick="openProofViewer('<%= inv.proof_image %>')" style="width:52px;height:52px;object-fit:cover;border-radius:8px;border:1px solid var(--border);cursor:pointer;flex-shrink:0">
                        <div style="flex:1;min-width:0">
                            <div style="font-size:12px;font-weight:700;color:var(--success)">✅ Bukti Terupload</div>
                            <div style="font-size:11px;color:var(--muted);margin-top:2px">Menunggu konfirmasi admin</div>
                            <button onclick="openProofViewer('<%= inv.proof_image %>')" style="margin-top:4px;font-size:11px;background:none;border:none;color:var(--primary);cursor:pointer;padding:0;font-family:'Outfit',sans-serif">Lihat selengkapnya →</button>
                        </div>
                    </div>
                    <% } %>
                    <label for="proof-<%= inv.id %>" style="display:inline-flex;align-items:center;gap:6px;background:rgba(59,130,246,.1);color:var(--primary);border:1px solid rgba(59,130,246,.3);border-radius:10px;padding:8px 14px;font-size:12px;font-weight:700;cursor:pointer">
                        <i class="fas fa-camera"></i> <%= inv.proof_image ? 'Ganti Bukti Bayar' : 'Upload Bukti Bayar' %>
                    </label>
                    <input type="file" id="proof-<%= inv.id %>" accept="image/*,.pdf" style="display:none" onchange="uploadProof(<%= inv.id %>, this)">
                    <span id="proof-status-<%= inv.id %>" style="font-size:11px;color:var(--muted);margin-left:8px"></span>
                </div>
                <% } %>
            </div>
            <% }); %>
        <% } else { %>
            <div class="info-card" style="padding:40px;color:var(--muted);font-size:13px">Belum ada riwayat tagihan.</div>
        <% } %>
    </div>

    <!-- Section: WIFI -->
    <div id="section-wifi" class="page-section">
        <div class="section-title">Pengaturan WiFi</div>
        <div class="info-card" style="text-align:left; margin-bottom:20px; border-color:var(--primary);">
            <div style="font-size:13px; color:var(--muted); line-height:1.5; margin-bottom:15px">
                Ubah Nama WiFi (SSID) dan Kata Sandi langsung dari sini. Perubahan diterapkan otomatis ke ONT Anda.
            </div>
            <form id="wifiForm">
                <div class="form-group">
                    <label>Nama WiFi (SSID)</label>
                    <input type="text" id="wifi_ssid" class="form-control" placeholder="Memuat..." required>
                </div>
                <div class="form-group">
                    <label>Kata Sandi WiFi</label>
                    <input type="text" id="wifi_pass" class="form-control" placeholder="Memuat..." required>
                </div>
                <button type="submit" id="btnUpdateWifi" class="btn btn-primary">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                    Update WiFi
                </button>
            </form>
        </div>
        <div style="font-size:11px; color:var(--muted); text-align:center; padding:10px; background:rgba(255,255,255,0.03); border-radius:10px;">
            Catatan: Perangkat akan terputus sesaat setelah Nama/Password WiFi diubah.
        </div>
    </div>

    <!-- Section: BILLING (History) -->
    <div id="section-billing" class="page-section">
        <div class="section-title">Riwayat Tagihan</div>
        <% invoices.forEach(inv => { %>
        <div class="invoice-card" style="<%= inv.status === 'unpaid' ? 'cursor:pointer' : '' %>" onclick="<%= inv.status === 'unpaid' ? 'toggleInvDetail(' + inv.id + ')' : '' %>">
            <div class="inv-top">
                <div class="inv-info">
                    <h4>Invoice #<%= String(inv.id).padStart(6, '0') %></h4>
                    <p><%= new Date(inv.due_date).toLocaleDateString('id-ID', { month: 'long', year: 'numeric' }) %></p>
                    <p style="font-weight:700;margin-top:4px;color:var(--text)">Rp <%= parseFloat(inv.amount).toLocaleString('id-ID') %></p>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px">
                    <span class="badge <%= inv.status === 'paid' ? 'badge-paid' : 'badge-unpaid' %>">
                        <%= inv.status === 'paid' ? 'Lunas' : 'Belum Bayar' %>
                    </span>
                    <% if (inv.status === 'unpaid') { %><span style="font-size:10px;color:var(--muted)">ketuk untuk bayar ▾</span><% } %>
                </div>
            </div>
            <% if (inv.status === 'paid') { %>
            <div style="font-size:11px;color:var(--success);margin-top:10px;display:flex;align-items:center;gap:4px;">
                <i class="fas fa-check-circle"></i>
                Dibayar via <%= inv.payment_method || 'Manual' %> · <%= inv.paid_at ? new Date(inv.paid_at).toLocaleDateString('id-ID') : '-' %>
            </div>
            <% } else { %>
            <!-- Expandable payment detail (hidden by default) -->
            <div id="inv-detail-<%= inv.id %>" style="display:none;margin-top:14px">
                <% if (paymentGateway === 'xendit') { %>
                <button class="btn btn-qris" onclick="event.stopPropagation();openQRIS(<%= inv.id %>, <%= inv.amount %>)">
                    <i class="fas fa-qrcode"></i> Bayar dengan QRIS
                </button>
                <% } else { %>
                <div style="display:flex;gap:5px;background:var(--input-bg);border:1px solid var(--border);border-radius:12px;padding:3px;margin-bottom:12px">
                    <button id="htab-transfer-<%= inv.id %>" onclick="event.stopPropagation();switchPayTab(<%= inv.id %>,'transfer','h')" style="flex:1;padding:8px;border:none;border-radius:9px;font-weight:700;font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif;background:var(--primary);color:#fff;transition:all .2s">🏦 Transfer Bank</button>
                    <button id="htab-qris-<%= inv.id %>" onclick="event.stopPropagation();switchPayTab(<%= inv.id %>,'qris','h')" style="flex:1;padding:8px;border:none;border-radius:9px;font-weight:700;font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif;background:none;color:var(--muted);transition:all .2s">🔲 QRIS</button>
                </div>
                <div id="hpane-transfer-<%= inv.id %>" style="background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.3);border-radius:12px;padding:14px">
                    <div style="color:var(--warning);font-weight:700;font-size:13px;margin-bottom:8px">💳 Transfer Bank</div>
                    <div style="font-size:13px;color:var(--text);line-height:1.9">
                        Bank: <strong style="color:var(--primary)"><%= company.bank_name %></strong><br>
                        No. Rek: <strong style="color:var(--primary);font-size:15px;letter-spacing:.5px"><%= company.bank_account %></strong>
                        <button onclick="event.stopPropagation();copyText('<%= company.bank_account %>')" style="margin-left:6px;background:rgba(59,130,246,.15);color:var(--primary);border:1px solid rgba(59,130,246,.3);border-radius:6px;padding:2px 8px;font-size:11px;cursor:pointer">Salin</button><br>
                        A/N: <strong><%= company.bank_holder %></strong>
                    </div>
                </div>
                <div id="hpane-qris-<%= inv.id %>" style="display:none;text-align:center">
                    <% if (company.qris_image) { %>
                    <div style="background:rgba(16,185,129,.06);border:1px solid rgba(16,185,129,.3);border-radius:12px;padding:14px">
                        <div style="color:var(--success);font-weight:700;font-size:13px;margin-bottom:10px">🔲 Scan QRIS untuk Bayar</div>
                        <img src="<%= company.qris_image %>" alt="QRIS" style="max-width:220px;width:100%;border-radius:10px;border:1px solid var(--border);background:#fff;padding:6px">
                        <div style="font-size:11px;color:var(--muted);margin-top:8px">Scan menggunakan aplikasi bank / e-wallet manapun</div>
                    </div>
                    <% } else { %>
                    <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;color:var(--muted);font-size:13px">
                        <div style="font-size:24px;margin-bottom:6px">🔲</div>
                        QRIS belum dikonfigurasi admin
                    </div>
                    <% } %>
                </div>
                <% } %>
                <!-- Upload bukti bayar -->
                <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border)" onclick="event.stopPropagation()">
                    <% if (inv.proof_image) { %>
                    <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;background:rgba(16,185,129,.06);border:1px solid rgba(16,185,129,.25);border-radius:10px;padding:10px">
                        <img src="<%= inv.proof_image %>" alt="Bukti" onclick="openProofViewer('<%= inv.proof_image %>')" style="width:52px;height:52px;object-fit:cover;border-radius:8px;border:1px solid var(--border);cursor:pointer;flex-shrink:0">
                        <div style="flex:1;min-width:0">
                            <div style="font-size:12px;font-weight:700;color:var(--success)">✅ Bukti Terupload</div>
                            <div style="font-size:11px;color:var(--muted);margin-top:2px">Menunggu konfirmasi admin</div>
                            <button onclick="openProofViewer('<%= inv.proof_image %>')" style="margin-top:4px;font-size:11px;background:none;border:none;color:var(--primary);cursor:pointer;padding:0;font-family:'Outfit',sans-serif">Lihat selengkapnya →</button>
                        </div>
                    </div>
                    <% } %>
                    <label for="hproof-<%= inv.id %>" style="display:inline-flex;align-items:center;gap:6px;background:rgba(59,130,246,.1);color:var(--primary);border:1px solid rgba(59,130,246,.3);border-radius:10px;padding:8px 14px;font-size:12px;font-weight:700;cursor:pointer">
                        <i class="fas fa-camera"></i> <%= inv.proof_image ? 'Ganti Bukti Bayar' : 'Upload Bukti Bayar' %>
                    </label>
                    <input type="file" id="hproof-<%= inv.id %>" accept="image/*,.pdf" style="display:none" onchange="uploadProof(<%= inv.id %>, this)">
                    <span style="font-size:11px;color:var(--muted);margin-left:8px"></span>
                </div>
            </div>
            <% } %>
        </div>
        <% }); %>
    </div>

    <!-- Section: SUPPORT -->
    <div id="section-support" class="page-section">
        <div class="section-title">Lapor Gangguan</div>
        <div class="info-card" style="text-align:left;margin-bottom:20px">
            <p style="font-size:13px;color:var(--muted);line-height:1.5;margin-bottom:15px">
                Internet lambat atau mati? Kirim laporan di sini, tim teknisi kami akan segera memeriksa.
            </p>
            <form id="ticketForm">
                <div class="form-group">
                    <label>Subjek Gangguan</label>
                    <input type="text" id="ticket_title" class="form-control" placeholder="Contoh: Internet Mati, Lambat, dll" required>
                </div>
                <div class="form-group">
                    <label>Detail Keluhan</label>
                    <textarea id="ticket_desc" class="form-control" rows="3" placeholder="Jelaskan kendala Anda..." required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">
                    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                    Kirim Laporan
                </button>
            </form>
        </div>

        <div class="section-title">Riwayat Laporan</div>
        <div id="ticketList" style="margin-bottom:20px;">
            <div style="text-align:center; padding:20px; color:var(--muted); font-size:13px;">Memuat riwayat laporan...</div>
        </div>

        <div class="section-title">Kontak Kami</div>
        <div class="info-card" style="text-align:left">
            <div style="font-size:13px;line-height:1.8">
                <strong style="color:var(--text)">📍 Alamat:</strong><br><%= company.company_address || '-' %><br>
                <strong style="color:var(--text)">📞 WhatsApp:</strong><br><%= company.company_phone || '-' %><br>
            </div>
            <% if (company.company_phone) { %>
            <a href="https://wa.me/<%= String(company.company_phone).replace(/[^0-9]/g, '') %>" class="btn" style="background:#25D366;color:white;margin-top:15px;text-decoration:none">
