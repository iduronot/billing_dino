                <div class="form-group"><label>Nama Lengkap</label><div style="font-weight:600;margin-bottom:10px;"><%= customer.name %></div></div>
                <div class="form-group"><label>No. Telepon (WhatsApp)</label><input type="text" id="pPhone" class="form-control" value="<%= customer.phone || '' %>"></div>
                <div class="form-group"><label>Email</label><input type="email" id="pEmail" class="form-control" value="<%= customer.email || '' %>"></div>
                <div class="form-group"><label>Alamat Pasang</label><div style="font-size:13px;line-height:1.4"><%= customer.address || '-' %></div></div>
                <div class="form-group"><label>PPPoE Username</label><div style="font-family:monospace;color:var(--primary)"><%= customer.pppoe_username || '-' %></div></div>
                <button type="submit" class="btn" style="background:rgba(59,130,246,0.1);color:var(--primary);border:1px solid rgba(59,130,246,0.2);margin-top:10px;">Update Profil</button>
            </form>
        </div>

        <div class="section-title">Ganti Password Portal</div>
        <div class="info-card">
            <form id="pwForm">
                <div class="form-group"><label>Password Lama</label><input type="password" id="curPw" class="form-control" required></div>
                <div class="form-group"><label>Password Baru</label><input type="password" id="newPw" class="form-control" required></div>
                <button type="submit" class="btn btn-primary">Simpan Password</button>
            </form>
        </div>

        <a href="/portal/logout" class="btn" style="margin-top:30px;background:rgba(239,68,68,0.1);color:var(--danger);border:1px solid rgba(239,68,68,0.2)">Keluar dari Portal</a>
    </div>

    <!-- Bottom Navigation -->
    <div class="bottom-nav">
        <div class="nav-item active" onclick="showSection('home', this)">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            <span>Beranda</span>
        </div>
        <div class="nav-item" onclick="showSection('billing', this)">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            <span>Tagihan</span>
        </div>
<div class="nav-item" onclick="showSection('support', this)">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            <span>Bantuan</span>
        </div>
        <div class="nav-item" onclick="showSection('profile', this)">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span>Akun</span>
        </div>
    </div>
</div>

<!-- QR Code Modal -->
<div id="qrOverlay" class="qr-overlay">
    <div class="qr-box">
        <!-- State: Loading -->
        <div id="qrStateLoading">
            <div class="qr-title">Membuat QR Code...</div>
            <div class="spinner"></div>
            <div style="font-size:13px;color:var(--muted)">Mohon tunggu sebentar</div>
        </div>

        <!-- State: QR Ready -->
        <div id="qrStateReady" style="display:none">
            <div style="font-size:13px;color:var(--muted);font-weight:600;margin-bottom:4px">SCAN UNTUK MEMBAYAR</div>
            <div class="qr-amount" id="qrAmount">Rp 0</div>
            <div class="qr-img-wrap">
                <img id="qrImage" src="" alt="QR Code">
            </div>
            <div class="qr-status-row">
                <div class="qr-status-dot" id="qrDot"></div>
                <span id="qrStatusText">Menunggu pembayaran...</span>
            </div>
            <div class="qr-timer">Berlaku selama: <span id="qrCountdown">23:59</span></div>
            <div style="font-size:11px;color:var(--muted);margin-bottom:16px">
                Buka aplikasi mobile banking atau e-wallet, pilih QRIS, lalu scan QR di atas.
            </div>
            <button class="qr-close" onclick="closeQRIS()">Tutup</button>
        </div>

        <!-- State: QR No Image (show string) -->
        <div id="qrStateString" style="display:none">
            <div style="font-size:13px;color:var(--muted);font-weight:600;margin-bottom:4px">SALIN KODE QRIS</div>
            <div class="qr-amount" id="qrAmount2">Rp 0</div>
            <div style="background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:12px;padding:12px;margin-bottom:12px;word-break:break-all;font-size:11px;font-family:monospace;max-height:100px;overflow-y:auto;" id="qrStringText"></div>
            <button class="btn btn-primary" style="margin-bottom:12px" onclick="copyQRString()">
                <i class="fas fa-copy"></i> Salin Kode QRIS
            </button>
            <div class="qr-status-row">
                <div class="qr-status-dot" id="qrDot2"></div>
                <span id="qrStatusText2">Menunggu pembayaran...</span>
            </div>
            <div class="qr-timer">Berlaku selama: <span id="qrCountdown2">23:59</span></div>
            <button class="qr-close" style="margin-top:12px" onclick="closeQRIS()">Tutup</button>
        </div>

        <!-- State: Paid -->
        <div id="qrStatePaid" style="display:none">
            <div class="qr-success-icon">✅</div>
            <div class="qr-title" style="color:var(--success)">Pembayaran Berhasil!</div>
            <div style="font-size:13px;color:var(--muted);margin:12px 0 20px">
                Tagihan Anda telah lunas. Layanan internet akan aktif dalam beberapa saat.
            </div>
            <button class="btn btn-primary" onclick="location.reload()">
                <i class="fas fa-sync-alt"></i> Refresh Halaman
            </button>
        </div>
    </div>
</div>

<!-- Ticket Detail Modal -->
<div id="ticketDetailOverlay" onclick="if(event.target===this)closeTicketDetail()" style="display:none;position:fixed;inset:0;z-index:4000;background:rgba(0,0,0,0.8);backdrop-filter:blur(6px);align-items:flex-end;justify-content:center;padding:0">
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:28px 28px 0 0;width:100%;max-width:500px;max-height:90vh;display:flex;flex-direction:column;animation:slideUp .25s ease">
        <div style="padding:16px 20px 0;display:flex;justify-content:space-between;align-items:center;flex-shrink:0">
            <div style="font-size:16px;font-weight:700" id="tdTitle">Detail Laporan</div>
            <button onclick="closeTicketDetail()" style="background:rgba(255,255,255,0.06);border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:6px 14px;font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif">✕ Tutup</button>
        </div>
        <!-- Meta info -->
        <div id="tdMeta" style="padding:12px 20px;flex-shrink:0;border-bottom:1px solid var(--border)"></div>
        <!-- Timeline/comments -->
        <div id="tdTimeline" style="flex:1;overflow-y:auto;padding:14px 20px;display:flex;flex-direction:column;gap:10px"></div>
        <!-- Reply box (only if not closed) -->
        <div id="tdReplyBox" style="padding:12px 20px 20px;flex-shrink:0;border-top:1px solid var(--border)">
            <div style="display:flex;gap:8px">
                <textarea id="tdReplyInput" rows="2" class="form-control" placeholder="Tulis balasan atau info tambahan..." style="resize:none;flex:1;font-size:13px"></textarea>
                <button id="tdReplySend" onclick="sendTicketReply()" style="background:var(--primary);color:#fff;border:none;border-radius:10px;padding:10px 14px;font-size:13px;font-weight:700;cursor:pointer;font-family:'Outfit',sans-serif;flex-shrink:0">Kirim</button>
            </div>
        </div>
    </div>
</div>
<style>
@keyframes slideUp { from { transform:translateY(60px); opacity:0; } to { transform:translateY(0); opacity:1; } }
</style>

<!-- Proof Viewer Modal -->
<div id="proofViewerOverlay" onclick="if(event.target===this)closeProofViewer()" style="display:none;position:fixed;inset:0;z-index:5000;background:rgba(0,0,0,0.9);backdrop-filter:blur(8px);align-items:center;justify-content:center;flex-direction:column;gap:14px;padding:20px">
    <div style="display:flex;gap:10px;align-items:center">
        <span style="color:white;font-size:13px;font-weight:600">Bukti Pembayaran</span>
        <button onclick="closeProofViewer()" style="background:rgba(239,68,68,.2);color:#FCA5A5;border:1px solid rgba(239,68,68,.3);border-radius:8px;padding:6px 16px;font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif">✕ Tutup</button>
    </div>
    <img id="proofViewerImg" src="" alt="Bukti" style="max-width:min(480px,92vw);max-height:78vh;border-radius:14px;object-fit:contain;background:#fff;padding:6px;box-shadow:0 20px 50px rgba(0,0,0,.7)">
</div>

<div class="toast" id="toast"></div>

<script>
    // ── Navigation ──
    function showSection(id, el) {
        document.querySelectorAll('.page-section').forEach(s => s.classList.remove('active'));
        document.getElementById('section-' + id).classList.add('active');
        document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
        if (el) el.classList.add('active');
        window.scrollTo(0, 0);
    }

    // ── QRIS Payment ──
    let _qrPollInterval = null;
    let _qrTimerInterval = null;
    let _currentRefId = null;

    async function openQRIS(invoiceId, amount) {
        const overlay = document.getElementById('qrOverlay');
        overlay.classList.add('show');
        setState('loading');

        try {
            const res = await fetch(`/portal/pay/${invoiceId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const d = await res.json();

            if (!d.success) {
                overlay.classList.remove('show');
                showToast(d.message || 'Gagal membuat QR', 'error');
                return;
            }

            _currentRefId = d.data.referenceId;
            const formattedAmount = 'Rp ' + parseFloat(amount).toLocaleString('id-ID');

            if (d.data.qrImageUrl) {
                document.getElementById('qrAmount').textContent = formattedAmount;
                document.getElementById('qrImage').src = d.data.qrImageUrl;
                setState('ready');
            } else if (d.data.qrString) {
                document.getElementById('qrAmount2').textContent = formattedAmount;
                document.getElementById('qrStringText').textContent = d.data.qrString;
                setState('string');
            } else {
                overlay.classList.remove('show');
                showToast('QR tidak tersedia dari Xendit', 'error');
                return;
            }

            // Countdown 24 jam
            startCountdown(d.data.expiresAt);
            // Poll status setiap 5 detik
            startPolling();

        } catch (e) {
            overlay.classList.remove('show');
            showToast('Error: ' + e.message, 'error');
        }
    }

    function setState(state) {
        ['loading','ready','string','paid'].forEach(s => {
            document.getElementById('qrState' + s.charAt(0).toUpperCase() + s.slice(1)).style.display = 'none';
        });
        document.getElementById('qrState' + state.charAt(0).toUpperCase() + state.slice(1)).style.display = 'block';
    }

    function startPolling() {
        clearInterval(_qrPollInterval);
        _qrPollInterval = setInterval(async () => {
            if (!_currentRefId) return;
            try {
                const res = await fetch(`/portal/qr-status/${_currentRefId}`);
                const d = await res.json();
                if (d.success && d.data && d.data.status === 'SUCCEEDED') {
                    stopPolling();
                    setState('paid');
                }
            } catch (_) {}
        }, 5000);
    }

    function stopPolling() {
        clearInterval(_qrPollInterval);
        clearInterval(_qrTimerInterval);
        _qrPollInterval = null;
        _qrTimerInterval = null;
    }

    function startCountdown(expiresAt) {
        clearInterval(_qrTimerInterval);
        const targets = ['qrCountdown', 'qrCountdown2'];

        const tick = () => {
            const diff = Math.max(0, new Date(expiresAt) - Date.now());
            const h = Math.floor(diff / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            const s = Math.floor((diff % 60000) / 1000);
            const str = h > 0
                ? `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`
                : `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
            targets.forEach(id => {
                const el = document.getElementById(id);
                if (el) el.textContent = str;
            });
            if (diff === 0) { clearInterval(_qrTimerInterval); }
        };
        tick();
        _qrTimerInterval = setInterval(tick, 1000);
    }

    function closeQRIS() {
        stopPolling();
        _currentRefId = null;
        document.getElementById('qrOverlay').classList.remove('show');
    }

    async function copyQRString() {
        const text = document.getElementById('qrStringText').textContent;
        try {
            await navigator.clipboard.writeText(text);
            showToast('Kode QRIS disalin!', 'success');
        } catch (_) {
            showToast('Gagal menyalin, salin manual.', 'error');
        }
    }

    // ── Tickets ──
    document.getElementById('ticketForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const res = await fetch('/portal/ticket', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title: document.getElementById('ticket_title').value, description: document.getElementById('ticket_desc').value })
        });
        const d = await res.json();
        showToast(d.message, d.success ? 'success' : 'error');
        if (d.success) { e.target.reset(); loadTickets(); }
    });

    const TICKET_STATUS = {
        open:        { label: 'Menunggu',  cls: 'badge-unpaid',  color: 'var(--warning)' },
        in_progress: { label: 'Diproses',  cls: 'badge-inprog',  color: 'var(--primary)' },
        closed:      { label: 'Selesai',   cls: 'badge-paid',    color: 'var(--success)' }
    };

    async function loadTickets() {
        const list = document.getElementById('ticketList');
        try {
            const res = await fetch('/portal/tickets');
            const d = await res.json();
            if (!d.success) { list.innerHTML = '<div class="info-card" style="color:var(--muted);font-size:13px;">Gagal memuat laporan.</div>'; return; }
            if (d.tickets.length === 0) {
                list.innerHTML = '<div class="info-card" style="color:var(--muted);font-size:13px;">Belum ada riwayat laporan.</div>';
                return;
            }
            list.innerHTML = d.tickets.map(t => {
                const st = TICKET_STATUS[t.status] || TICKET_STATUS.open;
                const techHtml = t.technician_names ? `<span style="font-size:11px;color:var(--primary)"><i class="fas fa-user-hard-hat" style="margin-right:3px"></i>${t.technician_names}</span>` : '';
                const commentBadge = t.comment_count > 0 ? `<span style="font-size:11px;color:var(--muted);margin-left:6px"><i class="fas fa-comment"></i> ${t.comment_count}</span>` : '';
                return `
                <div class="invoice-card" style="padding:14px;margin-bottom:10px;cursor:pointer;transition:border-color .2s" onmouseenter="this.style.borderColor='var(--primary)'" onmouseleave="this.style.borderColor=''" onclick="openTicketDetail(${t.id})">
                    <div class="inv-top">
                        <div class="inv-info" style="flex:1;min-width:0">
                            <h4 style="font-size:14px;margin:0 0 3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${t.title}</h4>
                            <p style="font-size:11px;color:var(--muted);margin:0">${new Date(t.created_at).toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'})}</p>
                            <div style="margin-top:5px;display:flex;align-items:center;flex-wrap:wrap;gap:6px">${techHtml}${commentBadge}</div>
                        </div>
                        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0;margin-left:10px">
                            <span class="badge ${st.cls}">${st.label}</span>
                            <span style="font-size:10px;color:var(--muted)">ketuk detail ›</span>
                        </div>
                    </div>
                </div>`;
            }).join('');
        } catch (_) {}
    }
    loadTickets();

    let _currentTicketId = null;

    async function openTicketDetail(ticketId) {
        _currentTicketId = ticketId;
        const overlay = document.getElementById('ticketDetailOverlay');
        overlay.style.display = 'flex';
        document.getElementById('tdTitle').textContent = 'Memuat...';
        document.getElementById('tdMeta').innerHTML = '<div class="spinner" style="width:24px;height:24px;margin:8px auto"></div>';
        document.getElementById('tdTimeline').innerHTML = '';
        document.getElementById('tdReplyBox').style.display = 'none';

        try {
            const res = await fetch(`/portal/ticket/${ticketId}`);
            const d = await res.json();
            if (!d.success) { document.getElementById('tdTitle').textContent = 'Gagal memuat'; return; }
            renderTicketDetail(d.ticket, d.comments);
        } catch(e) {
            document.getElementById('tdTitle').textContent = 'Error: ' + e.message;
        }
    }

    function renderTicketDetail(t, comments) {
        const st = TICKET_STATUS[t.status] || TICKET_STATUS.open;
        document.getElementById('tdTitle').textContent = t.title;

        // Meta
        const techLine = t.technician_names
            ? `<div style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text)"><i class="fas fa-user-hard-hat" style="color:var(--primary)"></i> Teknisi: <strong>${t.technician_names}</strong></div>`
            : `<div style="font-size:12px;color:var(--muted)">Belum ada teknisi yang ditugaskan</div>`;
        const catLine = t.category ? `<span style="font-size:11px;background:rgba(139,92,246,.15);color:#A78BFA;border:1px solid rgba(139,92,246,.3);border-radius:6px;padding:2px 8px">${t.category}</span>` : '';
        const locLine = t.location ? `<div style="font-size:12px;color:var(--muted);margin-top:4px"><i class="fas fa-map-marker-alt" style="margin-right:4px"></i>${t.location}</div>` : '';
        document.getElementById('tdMeta').innerHTML = `
            <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:8px">
                <span class="badge ${st.cls}" style="font-size:11px">${st.label}</span>
                ${catLine}
                <span style="font-size:11px;color:var(--muted)">${new Date(t.created_at).toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'})}</span>
            </div>
            ${techLine}${locLine}
            ${t.description ? `<div style="font-size:12px;color:var(--muted);margin-top:6px;line-height:1.5">${t.description}</div>` : ''}`;

        // Timeline
        const timeline = document.getElementById('tdTimeline');
        const entries = [];

        // Ticket created
        entries.push({ time: t.created_at, role: 'customer', username: 'Anda', text: '📋 Laporan dikirim: ' + t.title, isSystem: false });

        // Comments
        comments.forEach(c => {
            entries.push({ time: c.created_at, role: c.role, username: c.username, text: c.comment, isSystem: false });
        });

        // Resolved note
        if (t.status === 'closed' && t.response_note) {
            entries.push({ time: t.resolved_at, role: 'system', username: 'Sistem', text: '✅ Selesai: ' + t.response_note, isSystem: true });
        }

        if (entries.length === 0) {
            timeline.innerHTML = '<div style="text-align:center;color:var(--muted);font-size:13px;padding:20px">Belum ada aktivitas</div>';
        } else {
            timeline.innerHTML = entries.map(e => {
                const isCustomer = e.role === 'customer';
                const isTech = e.role === 'technician' || e.role === 'admin';
                const isSystem = e.role === 'system';
                const bg = isCustomer ? 'rgba(59,130,246,.1)' : isSystem ? 'rgba(16,185,129,.08)' : 'rgba(139,92,246,.1)';
                const border = isCustomer ? 'rgba(59,130,246,.3)' : isSystem ? 'rgba(16,185,129,.25)' : 'rgba(139,92,246,.3)';
                const nameColor = isCustomer ? 'var(--primary)' : isSystem ? 'var(--success)' : '#A78BFA';
                const align = isCustomer ? 'flex-end' : 'flex-start';
                const timeStr = e.time ? new Date(e.time).toLocaleString('id-ID',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) : '';
                return `<div style="display:flex;flex-direction:column;align-items:${align}">
                    <div style="max-width:88%;background:${bg};border:1px solid ${border};border-radius:12px;padding:10px 13px">
                        <div style="font-size:11px;color:${nameColor};font-weight:700;margin-bottom:4px">${e.username}${timeStr ? ' · ' + timeStr : ''}</div>
                        <div style="font-size:13px;color:var(--text);line-height:1.5;white-space:pre-wrap">${e.text}</div>
                    </div>
                </div>`;
            }).join('');
        }

        // Scroll to bottom of timeline
        setTimeout(() => { timeline.scrollTop = timeline.scrollHeight; }, 50);

        // Show reply box only if ticket is not closed
        const replyBox = document.getElementById('tdReplyBox');
        replyBox.style.display = t.status === 'closed' ? 'none' : '';
        document.getElementById('tdReplyInput').value = '';
    }

    async function sendTicketReply() {
        const input = document.getElementById('tdReplyInput');
        const btn = document.getElementById('tdReplySend');
        const text = input.value.trim();
        if (!text || !_currentTicketId) return;
        btn.disabled = true; btn.textContent = '...';
        try {
            const res = await fetch(`/portal/ticket/${_currentTicketId}/comment`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ comment: text })
            });
            const d = await res.json();
            if (d.success) {
                input.value = '';
                // Reload detail
                const res2 = await fetch(`/portal/ticket/${_currentTicketId}`);
                const d2 = await res2.json();
                if (d2.success) renderTicketDetail(d2.ticket, d2.comments);
            } else {
                showToast(d.message, 'error');
            }
        } catch(e) { showToast('Gagal mengirim', 'error'); }
        btn.disabled = false; btn.textContent = 'Kirim';
    }

    function closeTicketDetail() {
        document.getElementById('ticketDetailOverlay').style.display = 'none';
        _currentTicketId = null;
        loadTickets(); // refresh status list
    }

    // ── Profile ──
    document.getElementById('profileForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const res = await fetch('/portal/update-profile', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone: document.getElementById('pPhone').value, email: document.getElementById('pEmail').value })
        });
        const d = await res.json();
        showToast(d.message, d.success ? 'success' : 'error');
    });

    document.getElementById('pwForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const res = await fetch('/portal/change-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ current_password: document.getElementById('curPw').value, new_password: document.getElementById('newPw').value })
        });
        const d = await res.json();
        showToast(d.message, d.success ? 'success' : 'error');
        if (d.success) e.target.reset();
    });

    // ── WiFi ──
    async function loadWifi() {
        const ssidInput = document.getElementById('wifi_ssid');
        const passInput = document.getElementById('wifi_pass');
        ssidInput.value = ''; ssidInput.placeholder = 'Memuat...';
        passInput.value = ''; passInput.placeholder = 'Memuat...';
        try {
            const res = await fetch('/portal/wifi');
            const d = await res.json();
            if (d.success) { ssidInput.value = d.ssid; passInput.value = d.password; }
            else showToast(d.message, 'error');
        } catch (_) { showToast('Gagal terhubung ke server', 'error'); }
    }

    document.getElementById('wifiForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!confirm('Perangkat akan terputus sesaat setelah Nama/Password WiFi diubah. Lanjutkan?')) return;
        const btn = document.getElementById('btnUpdateWifi');
        btn.disabled = true; btn.textContent = '⏳ Memproses...';
        try {
            const res = await fetch('/portal/wifi', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ssid: document.getElementById('wifi_ssid').value, password: document.getElementById('wifi_pass').value })
            });
            const d = await res.json();
            showToast(d.message, d.success ? 'success' : 'error');
        } catch (_) { showToast('Error jaringan', 'error'); }
        finally { btn.disabled = false; btn.textContent = 'Update WiFi'; }
    });

    // ── Payment tabs (per invoice) ──
    // prefix: 'p' for beranda section, 'h' for history section
    function switchPayTab(invId, tab, prefix) {
        prefix = prefix || 'p';
        const isTransfer = tab === 'transfer';
        document.getElementById(prefix + 'pane-transfer-' + invId).style.display = isTransfer ? '' : 'none';
        document.getElementById(prefix + 'pane-qris-'     + invId).style.display = isTransfer ? 'none' : '';
        const btnT = document.getElementById(prefix + 'tab-transfer-' + invId);
        const btnQ = document.getElementById(prefix + 'tab-qris-'     + invId);
        btnT.style.background = isTransfer ? 'var(--primary)' : 'none';
        btnT.style.color      = isTransfer ? '#fff' : 'var(--muted)';
        btnQ.style.background = !isTransfer ? 'var(--primary)' : 'none';
        btnQ.style.color      = !isTransfer ? '#fff' : 'var(--muted)';
    }

    // ── Toggle invoice detail in billing history ──
    function toggleInvDetail(invId) {
        const detail = document.getElementById('inv-detail-' + invId);
        if (!detail) return;
        detail.style.display = detail.style.display === 'none' ? '' : 'none';
    }

    // ── Proof viewer modal ──
    function openProofViewer(src) {
        document.getElementById('proofViewerImg').src = src;
        document.getElementById('proofViewerOverlay').style.display = 'flex';
    }
    function closeProofViewer() {
        document.getElementById('proofViewerOverlay').style.display = 'none';
    }

    // ── Copy text ──
    function copyText(text) {
        navigator.clipboard.writeText(text).then(() => showToast('Disalin!', 'success')).catch(() => {
            const el = document.createElement('textarea');
            el.value = text; document.body.appendChild(el); el.select(); document.execCommand('copy'); document.body.removeChild(el);
            showToast('Disalin!', 'success');
        });
    }

    // ── Upload bukti pembayaran ──
    async function uploadProof(invoiceId, input) {
        const file = input.files[0];
        if (!file) return;
        if (file.size > 5 * 1024 * 1024) return showToast('File terlalu besar (maks 5MB)', 'error');
        const statusEl = input.nextElementSibling;
        if (statusEl) statusEl.textContent = 'Mengupload...';
        const fd = new FormData();
        fd.append('proof', file);
        try {
            const res = await fetch(`/portal/upload-proof/${invoiceId}`, { method: 'POST', body: fd });
            const d = await res.json();
            if (statusEl) statusEl.textContent = '';
            if (d.success) {
                showToast('✅ Bukti pembayaran berhasil diupload!', 'success');
                const label = input.previousElementSibling;
                if (label) label.innerHTML = '<i class="fas fa-camera"></i> Ganti Bukti Bayar';
            } else {
                showToast('❌ ' + d.message, 'error');
            }
        } catch(e) {
            if (statusEl) statusEl.textContent = '';
            showToast('❌ Gagal upload: ' + e.message, 'error');
        }
        input.value = '';
    }

    // ── Toast ──
    function showToast(msg, type) {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.style.borderColor = type === 'success' ? 'rgba(16,185,129,.4)' : 'rgba(239,68,68,.4)';
        t.style.color = type === 'success' ? '#10B981' : '#EF4444';
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 4000);
    }

    // ── Theme ──
    const themeToggle = document.getElementById('themeToggle');
    const themeIcon = themeToggle.querySelector('i');
    function updateThemeUI() {
        const isLight = document.documentElement.classList.contains('light-theme');
        themeIcon.className = isLight ? 'fas fa-sun' : 'fas fa-moon';
        themeToggle.style.color = isLight ? '#F59E0B' : 'var(--text)';
    }
    updateThemeUI();
    themeToggle.addEventListener('click', () => {
        const isLight = document.documentElement.classList.toggle('light-theme');
        localStorage.setItem('theme', isLight ? 'light' : 'dark');
        updateThemeUI();
    });

    // Tutup modal saat klik di luar box
    document.getElementById('qrOverlay').addEventListener('click', function(e) {
        if (e.target === this) closeQRIS();
    });
</script>
</body>
</html>
