<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* ── Layout ── */
        .wa-layout { display:grid; grid-template-columns:280px 1fr; gap:0; height:calc(100vh - 130px); border:1px solid var(--border); border-radius:18px; overflow:hidden; background:var(--card-bg); }
        .wa-sidebar { border-right:1px solid var(--border); display:flex; flex-direction:column; overflow:hidden; }
        .wa-main { display:flex; flex-direction:column; overflow:hidden; }

        /* ── Stats Row ── */
        .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:18px; }
        .stat-card { background:var(--card-bg); border:1px solid var(--border); border-radius:14px; padding:16px; position:relative; overflow:hidden; }
        .stat-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
        .stat-card.blue::before   { background:linear-gradient(90deg,#3B82F6,#60A5FA); }
        .stat-card.green::before  { background:linear-gradient(90deg,#10B981,#34D399); }
        .stat-card.purple::before { background:linear-gradient(90deg,#8B5CF6,#A78BFA); }
        .stat-card.red::before    { background:linear-gradient(90deg,#EF4444,#F87171); }
        .stat-label { font-size:11px; color:var(--muted); font-weight:600; text-transform:uppercase; letter-spacing:.5px; margin-bottom:6px; }
        .stat-val   { font-size:26px; font-weight:800; line-height:1; }

        /* ── Sidebar ── */
        .wa-search { padding:14px; border-bottom:1px solid var(--border); }
        .wa-search input { width:100%; background:var(--sub-bg); border:1px solid var(--border); border-radius:10px; padding:9px 14px; font-size:13px; color:var(--text); font-family:'Outfit',sans-serif; outline:none; box-sizing:border-box; }
        .wa-search input:focus { border-color:var(--primary); }
        .contact-list { flex:1; overflow-y:auto; }
        .contact-item { display:flex; align-items:center; gap:12px; padding:13px 16px; cursor:pointer; border-bottom:1px solid var(--border); transition:background .15s; }
        .contact-item:hover, .contact-item.active { background:var(--hover-bg); }
        .contact-item.active { border-left:3px solid var(--primary); }
        .avatar { width:42px; height:42px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:15px; font-weight:700; flex-shrink:0; }
        .contact-info { flex:1; min-width:0; }
        .contact-name  { font-weight:600; font-size:13px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .contact-preview { font-size:11px; color:var(--muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; margin-top:2px; }
        .contact-meta  { display:flex; flex-direction:column; align-items:flex-end; gap:4px; flex-shrink:0; }
        .contact-time  { font-size:10px; color:var(--muted); }
        .unread-badge  { background:var(--primary); color:white; border-radius:10px; font-size:10px; font-weight:700; padding:2px 7px; min-width:18px; text-align:center; }
        .unread-badge.wa { background:#25D366; }

        /* ── Chat Area ── */
        .chat-header { padding:14px 18px; border-bottom:1px solid var(--border); display:flex; align-items:center; gap:12px; flex-shrink:0; }
        .chat-name { font-weight:700; font-size:15px; }
        .chat-phone { font-size:12px; color:var(--muted); }
        .chat-actions { margin-left:auto; display:flex; gap:8px; }
        .chat-messages { flex:1; overflow-y:auto; padding:18px; display:flex; flex-direction:column; gap:10px; }
        .msg-bubble { max-width:72%; padding:10px 14px; border-radius:14px; font-size:13px; line-height:1.5; position:relative; }
        .msg-bubble.in  { background:var(--sub-bg); border-radius:2px 14px 14px 14px; align-self:flex-start; }
        .msg-bubble.out { background:rgba(59,130,246,.15); border:1px solid rgba(59,130,246,.2); border-radius:14px 2px 14px 14px; align-self:flex-end; }
        .msg-time { font-size:10px; color:var(--muted); margin-top:4px; display:block; }
        .msg-time.out { text-align:right; }
        .msg-empty { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; color:var(--muted); font-size:14px; gap:12px; }
        .msg-empty i { font-size:48px; opacity:.2; }
        .chat-input-area { padding:10px 14px; border-top:1px solid var(--border); display:flex; gap:10px; align-items:flex-end; flex-shrink:0; }
        .chat-input { flex:1; background:var(--sub-bg); border:1px solid var(--border); border-radius:12px; padding:12px 14px; font-size:13px; color:var(--text); font-family:'Outfit',sans-serif; outline:none; resize:none; min-height:52px; max-height:200px; line-height:1.5; }
        .chat-input:focus { border-color:var(--primary); }
        .btn-send { background:var(--primary); color:white; border:none; border-radius:12px; padding:10px 18px; cursor:pointer; font-size:15px; display:flex; align-items:center; justify-content:center; transition:opacity .2s; }
        .btn-send:hover { opacity:.85; }
        .btn-send:disabled { opacity:.4; cursor:not-allowed; }

        /* ── Chart panel ── */
        .chart-panel { background:var(--card-bg); border:1px solid var(--border); border-radius:16px; padding:18px; margin-bottom:18px; }
        .chart-title { font-size:13px; font-weight:700; margin:0 0 14px; }

        /* ── Send broadcast ── */
        .modal-overlay { position:fixed; inset:0; background:var(--overlay-bg); backdrop-filter:blur(6px); display:none; align-items:center; justify-content:center; z-index:2000; }
        .modal-card { background:var(--sidebar-bg); border:1px solid var(--border); border-radius:20px; width:100%; max-width:540px; padding:28px; }
        .modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:18px; }
        .form-group { margin-bottom:14px; }
        .form-group label { display:block; margin-bottom:6px; font-size:12px; font-weight:600; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; }
        .toast { position:fixed; bottom:24px; right:24px; background:var(--toast-bg); color:var(--text); border:1px solid var(--border); border-radius:12px; padding:14px 20px; z-index:9999; display:none; font-size:14px; }
        .toast.show { display:block; }

        .wa-status { display:inline-flex; align-items:center; gap:6px; font-size:12px; font-weight:600; padding:4px 12px; border-radius:20px; }
        .wa-status.ready    { background:rgba(16,185,129,.1); color:#10B981; border:1px solid rgba(16,185,129,.25); }
        .wa-status.init     { background:rgba(245,158,11,.1); color:#F59E0B; border:1px solid rgba(245,158,11,.25); }
        .wa-status.offline  { background:rgba(239,68,68,.1);  color:#EF4444; border:1px solid rgba(239,68,68,.25); }

        @media(max-width:900px) { .wa-layout { grid-template-columns:1fr; height:auto; } .stats-row { grid-template-columns:repeat(2,1fr); } }

        /* ── Tabs ── */
        .wa-tabs { display:flex; gap:4px; background:var(--sub-bg); border:1px solid var(--border); border-radius:12px; padding:4px; margin-bottom:20px; width:fit-content; }
        .wa-tab  { padding:8px 20px; border-radius:9px; border:none; background:none; color:var(--muted); font-size:13px; font-weight:600; cursor:pointer; font-family:'Outfit',sans-serif; transition:all .2s; display:flex; align-items:center; gap:7px; }
        .wa-tab.active { background:var(--card-bg); color:var(--text); box-shadow:0 1px 4px rgba(0,0,0,.15); }
        .tab-pane { display:none; }
        .tab-pane.active { display:block; }

        /* ── Template / Auto-reply table ── */
        .mgmt-card { background:var(--card-bg); border:1px solid var(--border); border-radius:16px; overflow:hidden; }
        .mgmt-card-header { padding:16px 20px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
        .mgmt-card-header h3 { font-size:14px; font-weight:700; margin:0; }
        .var-hint { background:var(--sub-bg); border:1px solid var(--border); border-radius:10px; padding:10px 16px; font-size:11px; color:var(--muted); margin-bottom:14px; line-height:1.7; }
        .var-hint code { background:rgba(59,130,246,.15); color:#60A5FA; padding:1px 5px; border-radius:4px; font-family:'Courier New',monospace; font-size:11px; }
        .tpl-row { display:flex; align-items:flex-start; gap:12px; padding:14px 20px; border-bottom:1px solid var(--border); }
        .tpl-row:last-child { border-bottom:none; }
        .tpl-body { flex:1; min-width:0; }
        .tpl-name { font-weight:700; font-size:13px; margin-bottom:3px; }
        .tpl-content { font-size:12px; color:var(--muted); white-space:pre-wrap; word-break:break-word; }
        .tpl-actions { display:flex; gap:6px; flex-shrink:0; }
        .match-badge { font-size:10px; padding:2px 8px; border-radius:10px; font-weight:600; }
        .match-contains   { background:rgba(59,130,246,.15); color:#60A5FA; }
        .match-exact      { background:rgba(139,92,246,.15); color:#A78BFA; }
        .match-startswith { background:rgba(16,185,129,.15); color:#34D399; }
        .toggle-switch { position:relative; width:38px; height:20px; flex-shrink:0; margin-top:2px; }
        .toggle-switch input { opacity:0; width:0; height:0; }
        .toggle-track { position:absolute; inset:0; background:var(--border); border-radius:20px; cursor:pointer; transition:.2s; }
        .toggle-track::before { content:''; position:absolute; height:14px; width:14px; left:3px; bottom:3px; background:white; border-radius:50%; transition:.2s; }
        .toggle-switch input:checked + .toggle-track { background:#10B981; }
        .toggle-switch input:checked + .toggle-track::before { transform:translateX(18px); }

        /* ── Searchable customer dropdown ── */
        .cust-dropdown { position:relative; }
        .cust-input-wrap { display:flex; align-items:center; position:relative; }
        .cust-search-input { width:100%; padding:10px 36px 10px 14px; background:var(--input-bg); border:1px solid var(--border); border-radius:10px; color:var(--text); font-size:14px; font-family:'Outfit',sans-serif; outline:none; transition:border-color .2s; }
        .cust-search-input:focus { border-color:var(--primary); }
        .cust-clear-btn { position:absolute; right:10px; background:none; border:none; color:var(--muted); cursor:pointer; font-size:14px; display:none; line-height:1; padding:2px; }
        .cust-list { position:absolute; top:calc(100% + 4px); left:0; right:0; background:var(--modal-bg); border:1px solid var(--border); border-radius:10px; box-shadow:0 8px 24px rgba(0,0,0,.3); max-height:220px; overflow-y:auto; z-index:3000; display:none; }
        .cust-list.open { display:block; }
        .cust-list-item { padding:10px 14px; cursor:pointer; border-bottom:1px solid var(--border); transition:background .15s; }
        .cust-list-item:last-child { border-bottom:none; }
        .cust-list-item:hover, .cust-list-item.highlighted { background:var(--hover-bg); }
        .cust-item-name { font-size:13px; font-weight:600; }
        .cust-item-phone { font-size:11px; color:var(--muted); margin-top:1px; }
        .cust-no-result { padding:14px; text-align:center; color:var(--muted); font-size:13px; }

        /* ── Template picker in chat ── */
        .tpl-picker { position:absolute; bottom:100%; left:0; right:0; background:var(--modal-bg); border:1px solid var(--border); border-radius:12px; box-shadow:0 8px 24px rgba(0,0,0,.3); max-height:240px; overflow-y:auto; z-index:500; display:none; margin-bottom:6px; }
        .tpl-picker.open { display:block; }
        .tpl-pick-item { padding:10px 14px; cursor:pointer; border-bottom:1px solid var(--border); transition:background .15s; }
        .tpl-pick-item:last-child { border-bottom:none; }
        .tpl-pick-item:hover { background:var(--hover-bg); }
        .tpl-pick-name { font-size:12px; font-weight:700; margin-bottom:2px; }
        .tpl-pick-preview { font-size:11px; color:var(--muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .chat-input-wrap { flex:1; position:relative; }
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: 'WA Manager' }) %>
    <div class="content">

        <!-- Header -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:18px; flex-wrap:wrap; gap:12px;">
            <div>
                <h1 class="page-title" style="margin:0;">💬 WhatsApp Manager</h1>
                <p style="margin:4px 0 0; font-size:13px; color:var(--muted);">Baca, balas, dan kirim pesan WA ke pelanggan</p>
            </div>
            <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
                <span class="wa-status <%= waStatus.status === 'READY' ? 'ready' : waStatus.status === 'INITIALIZING' ? 'init' : 'offline' %>" id="waStatusBadge">
                    <span style="width:7px; height:7px; border-radius:50%; background:currentColor;"></span>
                    <span id="waStatusText"><%= waStatus.status === 'READY' ? 'Terhubung' : waStatus.status === 'INITIALIZING' ? 'Menghubungkan...' : 'Tidak Terhubung' %></span>
                </span>
                <button class="btn" style="background:rgba(37,211,102,.15); color:#25D366; border:1px solid rgba(37,211,102,.3);" onclick="syncMessages(this)">
                    <i class="fas fa-sync-alt"></i> Sync Pesan
                </button>
                <button class="btn" style="background:rgba(245,158,11,.1); color:#F59E0B; border:1px solid rgba(245,158,11,.25); font-size:12px;" onclick="cleanupData(this)" title="Bersihkan nomor @lid di database">
                    <i class="fas fa-broom"></i> Fix Data
                </button>
                <button class="btn btn-primary" onclick="openSendModal()">
                    <i class="fas fa-paper-plane"></i> Kirim ke Pelanggan
                </button>
            </div>
        </div>

        <!-- ── TABS ── -->
        <div class="wa-tabs">
            <button class="wa-tab active" onclick="switchWaTab('chat',this)"><i class="fab fa-whatsapp"></i> Chat</button>
            <button class="wa-tab" onclick="switchWaTab('templates',this)"><i class="fas fa-file-alt"></i> Template Pesan</button>
            <button class="wa-tab" onclick="switchWaTab('autoreply',this)"><i class="fas fa-robot"></i> Auto Reply</button>
        </div>

        <!-- ════════════ TAB CHAT ════════════ -->
        <div class="tab-pane active" id="pane-chat">

        <!-- ── STAT CARDS ── -->
        <div class="stats-row">
            <div class="stat-card blue">
                <div class="stat-label">Total Pesan (30 hari)</div>
                <div class="stat-val" id="statTotal"><%= stats.total || 0 %></div>
            </div>
            <div class="stat-card green">
                <div class="stat-label">Pesan Masuk</div>
                <div class="stat-val" id="statIncoming"><%= stats.incoming || 0 %></div>
            </div>
            <div class="stat-card purple">
                <div class="stat-label">Pesan Keluar</div>
                <div class="stat-val" id="statOutgoing"><%= stats.outgoing || 0 %></div>
            </div>
            <div class="stat-card red">
                <div class="stat-label">Belum Dibaca</div>
                <div class="stat-val" id="statUnread"><%= stats.unread || 0 %></div>
            </div>
        </div>

        <!-- ── CHART TREND ── -->
        <div class="chart-panel">
            <p class="chart-title">📈 Aktivitas Pesan 7 Hari Terakhir</p>
            <canvas id="trendChart" height="70"></canvas>
        </div>

        <!-- ── CHAT LAYOUT ── -->
        <div class="wa-layout">
            <!-- Sidebar kontak -->
            <div class="wa-sidebar">
                <div class="wa-search">
                    <input type="text" id="contactSearch" placeholder="🔍  Cari nama atau nomor..." oninput="filterContacts()">
                </div>
                <div class="contact-list" id="contactList">
                    <% if (contacts && contacts.length > 0) { %>
                        <% contacts.forEach(c => { %>
                        <div class="contact-item" data-phone="<%= c.phone %>" data-name="<%= (c.customer_name || c.name || c.phone) %>" data-custid="<%= c.customer_id || '' %>"
                             onclick="openChat('<%= c.phone %>', '<%= (c.customer_name || c.name || c.phone).replace(/'/g, "\\'") %>', '<%= c.customer_id || '' %>')">
                            <div class="avatar" style="background:hsl(<%= parseInt(c.phone.slice(-3)) % 360 %>,60%,35%);">
                                <%= (c.customer_name || c.name || c.phone).charAt(0).toUpperCase() %>
                            </div>
                            <div class="contact-info">
                                <div class="contact-name"><%= c.customer_name || c.name || c.phone.split('@')[0] %></div>
                                <div class="contact-preview"><%= c.last_message ? c.last_message.substring(0,40) : '-' %></div>
                            </div>
                            <div class="contact-meta">
                                <div class="contact-time">
                                    <% if (c.last_message_at) { %>
                                        <%= new Date(c.last_message_at * 1000).toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'}) %>
                                    <% } %>
                                </div>
                                <% if (c.unread_count > 0) { %>
                                <div class="unread-badge wa"><%= c.unread_count %></div>
                                <% } %>
                            </div>
                        </div>
                        <% }) %>
                    <% } else { %>
                    <div style="text-align:center; color:var(--muted); padding:40px 20px; font-size:13px;">
                        <i class="fas fa-comments" style="font-size:32px; opacity:.2; display:block; margin-bottom:12px;"></i>
                        Belum ada percakapan.<br>Klik "Sync Pesan" untuk memuat.
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- Area chat -->
            <div class="wa-main" id="chatMain">
                <div class="chat-messages msg-empty" id="chatMessages">
                    <i class="fab fa-whatsapp" style="font-size:56px; color:#25D366; opacity:.3;"></i>
                    <p>Pilih percakapan untuk mulai membaca pesan</p>
                </div>
                <div class="chat-input-area" id="chatInputArea" style="display:none;">
                    <div class="chat-input-wrap">
                        <div class="tpl-picker" id="tplPicker"></div>
                        <textarea class="chat-input" id="chatInput" rows="2" placeholder="Ketik pesan..." onkeydown="handleEnter(event)" oninput="autoResize(this)"></textarea>
                    </div>
                    <button title="Pilih Template" onclick="toggleTplPicker()" style="background:var(--sub-bg);color:var(--muted);border:1px solid var(--border);border-radius:12px;padding:10px 13px;cursor:pointer;font-size:14px;flex-shrink:0;transition:all .2s" onmouseover="this.style.color=getComputedStyle(document.documentElement).getPropertyValue('--text')" onmouseout="this.style.color=getComputedStyle(document.documentElement).getPropertyValue('--muted')"><i class="fas fa-file-alt"></i></button>
                    <button class="btn-send" id="btnSend" onclick="sendReply()">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>

        </div><!-- /pane-chat -->

        <!-- ════════════ TAB TEMPLATE PESAN ════════════ -->
        <div class="tab-pane" id="pane-templates">
            <div class="var-hint">
                <strong>Variabel yang tersedia:</strong> &nbsp;
                <code>{nama}</code> nama pelanggan &nbsp;·&nbsp;
                <code>{nomor}</code> nomor WA &nbsp;·&nbsp;
                <code>{paket}</code> nama paket &nbsp;·&nbsp;
                <code>{jumlah}</code> tagihan belum bayar &nbsp;·&nbsp;
                <code>{tanggal}</code> jatuh tempo tagihan
            </div>
            <div class="mgmt-card">
                <div class="mgmt-card-header">
                    <h3><i class="fas fa-file-alt" style="color:var(--primary)"></i> Daftar Template</h3>
                    <button class="btn btn-primary btn-sm" onclick="openTplModal()"><i class="fas fa-plus"></i> Tambah Template</button>
                </div>
                <div id="tplList"><div style="padding:30px;text-align:center;color:var(--muted);"><i class="fas fa-spinner fa-spin"></i> Memuat...</div></div>
            </div>
        </div>

        <!-- ════════════ TAB AUTO REPLY ════════════ -->
        <div class="tab-pane" id="pane-autoreply">
            <div class="var-hint">
                <strong>Variabel yang tersedia:</strong> &nbsp;
                <code>{nama}</code> <code>{nomor}</code> <code>{paket}</code> <code>{jumlah}</code> <code>{tanggal}</code>
                &nbsp;·&nbsp; <strong>Match type:</strong>
                <code>contains</code> = pesan mengandung kata &nbsp;·&nbsp;
                <code>exact</code> = pesan sama persis &nbsp;·&nbsp;
                <code>startswith</code> = pesan diawali kata
            </div>
            <div class="mgmt-card">
                <div class="mgmt-card-header">
                    <h3><i class="fas fa-robot" style="color:#10B981"></i> Aturan Auto Reply</h3>
                    <button class="btn btn-primary btn-sm" onclick="openArModal()"><i class="fas fa-plus"></i> Tambah Aturan</button>
                </div>
                <div id="arList"><div style="padding:30px;text-align:center;color:var(--muted);"><i class="fas fa-spinner fa-spin"></i> Memuat...</div></div>
            </div>
        </div>

    </div>
</main>

<!-- Modal Kirim ke Pelanggan -->
<div class="modal-overlay" id="sendModal" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal-card">
        <div class="modal-header">
            <h3 style="font-size:17px; font-weight:700; margin:0;">📤 Kirim Pesan ke Pelanggan</h3>
            <button onclick="document.getElementById('sendModal').style.display='none'" style="background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;">×</button>
        </div>
        <div class="form-group">
            <label>Cari Pelanggan</label>
            <div class="cust-dropdown">
                <div class="cust-input-wrap">
                    <input type="text" id="custSearchInput" class="cust-search-input" placeholder="🔍  Ketik nama atau nomor pelanggan..." autocomplete="off"
                        oninput="filterCustList()" onfocus="openCustList()" onkeydown="custKeyNav(event)">
                    <button class="cust-clear-btn" id="custClearBtn" onclick="clearCustSelection()" title="Hapus pilihan">✕</button>
                </div>
                <div class="cust-list" id="custList"></div>
            </div>
        </div>
        <div class="form-group">
            <label>Nomor WA *</label>
            <input type="text" id="sendPhone" class="form-control" placeholder="08xxxxxxxxxx atau 628xxxxxxx">
        </div>
        <div class="form-group">
            <label>Pesan *</label>
            <textarea id="sendMessage" class="form-control" rows="5" placeholder="Tulis pesan di sini..." style="resize:vertical;"></textarea>
        </div>
        <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:4px;">
            <button onclick="document.getElementById('sendModal').style.display='none';clearCustSelection()" class="btn" style="background:var(--sub-bg); border:1px solid var(--border);">Batal</button>
            <button onclick="sendToCustomer()" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Kirim</button>
        </div>
    </div>
</div>

<!-- Modal Template -->
<div class="modal-overlay" id="tplModal" onclick="if(event.target===this)closeTplModal()">
    <div class="modal-card">
        <div class="modal-header">
            <h3 style="font-size:17px;font-weight:700;margin:0" id="tplModalTitle">📝 Tambah Template</h3>
            <button onclick="closeTplModal()" style="background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer">×</button>
        </div>
        <input type="hidden" id="tplEditId">
        <div class="form-group">
            <label>Nama Template *</label>
            <input type="text" id="tplName" class="form-control" placeholder="cth: Tagihan Bulanan">
        </div>
        <div class="form-group">
            <label>Isi Pesan *</label>
            <textarea id="tplContent" class="form-control" rows="6" placeholder="Halo {nama}, tagihan Anda sebesar {jumlah} jatuh tempo {tanggal}. Terima kasih." style="resize:vertical"></textarea>
        </div>
        <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:4px">
            <button onclick="closeTplModal()" class="btn" style="background:var(--sub-bg);border:1px solid var(--border)">Batal</button>
            <button onclick="saveTpl()" class="btn btn-primary"><i class="fas fa-save"></i> Simpan</button>
        </div>
    </div>
</div>

<!-- Modal Auto Reply -->
<div class="modal-overlay" id="arModal" onclick="if(event.target===this)closeArModal()">
    <div class="modal-card">
        <div class="modal-header">
            <h3 style="font-size:17px;font-weight:700;margin:0" id="arModalTitle">🤖 Tambah Auto Reply</h3>
            <button onclick="closeArModal()" style="background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer">×</button>
        </div>
        <input type="hidden" id="arEditId">
        <div class="form-group">
            <label>Keyword (Kata Pemicu) *</label>
            <input type="text" id="arKeyword" class="form-control" placeholder="cth: tagihan, bayar, isolir">
        </div>
        <div class="form-group">
            <label>Tipe Pencocokan</label>
            <select id="arMatchType" class="form-control">
                <option value="contains">Contains — pesan mengandung kata ini</option>
                <option value="exact">Exact — pesan sama persis</option>
                <option value="startswith">Starts With — pesan diawali kata ini</option>
            </select>
        </div>
        <div class="form-group">
            <label>Balasan Otomatis *</label>
            <textarea id="arReply" class="form-control" rows="6" placeholder="Halo {nama}! Tagihan Anda sebesar {jumlah} jatuh tempo {tanggal}. Hubungi kami untuk info lebih lanjut." style="resize:vertical"></textarea>
        </div>
        <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:4px">
            <button onclick="closeArModal()" class="btn" style="background:var(--sub-bg);border:1px solid var(--border)">Batal</button>
            <button onclick="saveAr()" class="btn btn-primary"><i class="fas fa-save"></i> Simpan</button>
        </div>
    </div>
</div>

<div class="toast" id="toast"></div>

<script>
const isDark    = !document.documentElement.classList.contains('light-theme');
const gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.05)';
const tickColor = isDark ? '#94A3B8' : '#64748B';

// ── Trend Chart ──
const dailyStats = <%- JSON.stringify(dailyStats || []) %>;
const last7 = [];
for (let i = 6; i >= 0; i--) {
    const d = new Date(); d.setDate(d.getDate() - i);
    const key = d.toISOString().split('T')[0];
    const found = dailyStats.find(s => s.date && s.date.toString().startsWith(key));
    last7.push({ date: d.toLocaleDateString('id-ID',{weekday:'short',day:'2-digit'}), incoming: found ? parseInt(found.incoming)||0 : 0, outgoing: found ? parseInt(found.outgoing)||0 : 0 });
}

new Chart(document.getElementById('trendChart'), {
    type: 'bar',
    data: {
        labels: last7.map(d => d.date),
        datasets: [
            { label:'Masuk', data: last7.map(d => d.incoming), backgroundColor:'rgba(59,130,246,0.6)', borderColor:'#3B82F6', borderWidth:1, borderRadius:5 },
            { label:'Keluar', data: last7.map(d => d.outgoing), backgroundColor:'rgba(16,185,129,0.6)', borderColor:'#10B981', borderWidth:1, borderRadius:5 }
        ]
    },
    options: {
        responsive:true,
        plugins:{ legend:{ labels:{ color:tickColor, font:{size:11} } } },
        scales:{
            x:{ grid:{display:false}, ticks:{color:tickColor} },
            y:{ beginAtZero:true, grid:{color:gridColor}, ticks:{color:tickColor, stepSize:1} }
        }
    }
});

// ── Chat State ──
let currentPhone = null, currentName = null;

function filterContacts() {
    const q = document.getElementById('contactSearch').value.toLowerCase();
    document.querySelectorAll('.contact-item').forEach(el => {
        const name = el.dataset.name.toLowerCase();
        const phone = el.dataset.phone;
        el.style.display = (!q || name.includes(q) || phone.includes(q)) ? '' : 'none';
    });
}

async function openChat(phone, name, customerId) {
    // Strip suffix @c.us/@lid/@g.us jika ada
    phone = phone.split('@')[0].replace(/\D/g, '');
    currentPhone = phone;
    currentName  = name;

    // Simpan ke URL hash agar tidak hilang saat refresh
    history.replaceState(null, '', '#' + phone);

    // Highlight active
    document.querySelectorAll('.contact-item').forEach(el => el.classList.remove('active'));
    const el = document.querySelector(`.contact-item[data-phone="${phone}"]`);
    if (el) {
        el.classList.add('active');
        // Reset unread badge
        const badge = el.querySelector('.unread-badge');
        if (badge) badge.remove();
    }

    // Load messages
    const msgs = document.getElementById('chatMessages');
    msgs.className = 'chat-messages';
    msgs.innerHTML = '<div style="text-align:center; color:var(--muted); padding:20px;"><i class="fas fa-spinner fa-spin"></i> Memuat pesan...</div>';
    document.getElementById('chatInputArea').style.display = 'flex';

    // Update header
    let header = document.getElementById('chatHeader');
    if (!header) {
        header = document.createElement('div');
        header.id = 'chatHeader';
        header.className = 'chat-header';
        document.getElementById('chatMain').insertBefore(header, msgs);
    }
    const initials = name.charAt(0).toUpperCase();
    const hue = parseInt(phone.slice(-3)) % 360;
    header.innerHTML = `
        <div class="avatar" style="background:hsl(${hue},60%,35%);">${initials}</div>
        <div>
            <div class="chat-name">${name}</div>
            <div class="chat-phone">+${phone.split('@')[0]}</div>
        </div>
        <div class="chat-actions">
            ${customerId ? `<a href="/customers/${customerId}" class="btn" style="font-size:12px;padding:6px 12px;background:var(--sub-bg);border:1px solid var(--border);color:var(--text);text-decoration:none;">👤 Profil</a>` : ''}
        </div>`;

    try {
        const res  = await fetch(`/wa/api/messages/${phone}`);
        const data = await res.json();
        if (data.success && data.messages.length > 0) {
            msgs.innerHTML = data.messages.map(m => `
                <div class="msg-bubble ${m.from_me ? 'out' : 'in'}">
                    ${escapeHtml(m.body)}
                    <span class="msg-time ${m.from_me ? 'out' : ''}">
                        ${new Date(m.timestamp * 1000).toLocaleString('id-ID',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})}
                        ${m.from_me ? ' ✓' : ''}
                    </span>
                </div>`).join('');
        } else {
            msgs.innerHTML = '<div style="text-align:center;color:var(--muted);padding:30px;font-size:13px;">Belum ada pesan</div>';
        }
        msgs.scrollTop = msgs.scrollHeight;
        // Update unread count
        updateStats();
    } catch(e) {
        msgs.innerHTML = '<div style="text-align:center;color:var(--muted);padding:30px;">Gagal memuat pesan</div>';
    }
}

async function sendReply() {
    if (!currentPhone) return;
    const input = document.getElementById('chatInput');
    const msg   = input.value.trim();
    if (!msg) return;

    const btn = document.getElementById('btnSend');
    btn.disabled = true;
    input.disabled = true;

    const res  = await fetch('/wa/api/send', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ phone: currentPhone, message: msg })
    });
    const data = await res.json();

    if (data.success) {
        // Tambah bubble langsung
        const msgs = document.getElementById('chatMessages');
        const now  = new Date();
        msgs.innerHTML += `
            <div class="msg-bubble out">
                ${escapeHtml(msg)}
                <span class="msg-time out">${now.toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'})} ✓</span>
            </div>`;
        msgs.scrollTop = msgs.scrollHeight;
        input.value = '';
        autoResize(input);
    } else {
        showToast(data.message, 'error');
    }
    btn.disabled  = false;
    input.disabled = false;
    input.focus();
}

function handleEnter(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendReply(); }
}
function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 100) + 'px';
}

// ── Searchable customer dropdown ──
const allCustomers = <%- JSON.stringify(customers.map(c => ({ name: c.name, phone: c.phone }))) %>;
let custHighlight = -1;

function normalizeName(s) { return (s||'').toLowerCase(); }

function filterCustList() {
    const q = normalizeName(document.getElementById('custSearchInput').value);
    openCustList(q);
}

function openCustList(q) {
    const list = document.getElementById('custList');
    const query = q !== undefined ? q : normalizeName(document.getElementById('custSearchInput').value);
    const filtered = query
        ? allCustomers.filter(c => normalizeName(c.name).includes(query) || (c.phone||'').includes(query))
        : allCustomers;

    if (!filtered.length) {
        list.innerHTML = '<div class="cust-no-result">Pelanggan tidak ditemukan</div>';
    } else {
        list.innerHTML = filtered.slice(0, 80).map((c, i) => `
            <div class="cust-list-item" data-phone="${c.phone}" data-name="${escHtml(c.name)}" data-idx="${i}"
                 onmousedown="selectCust('${c.phone}','${escHtml(c.name).replace(/'/g,"\\'")}')">
                <div class="cust-item-name">${highlight(c.name, query)}</div>
                <div class="cust-item-phone">${c.phone||''}</div>
            </div>`).join('');
    }
    list.classList.add('open');
    custHighlight = -1;
}

function highlight(text, q) {
    if (!q) return escHtml(text);
    const idx = normalizeName(text).indexOf(q);
    if (idx < 0) return escHtml(text);
    return escHtml(text.slice(0, idx)) +
           '<mark style="background:rgba(59,130,246,.25);color:inherit;border-radius:2px">' +
           escHtml(text.slice(idx, idx + q.length)) + '</mark>' +
           escHtml(text.slice(idx + q.length));
}

function selectCust(phone, name) {
    document.getElementById('sendPhone').value          = phone;
    document.getElementById('custSearchInput').value    = name;
    document.getElementById('custClearBtn').style.display = 'block';
    document.getElementById('custList').classList.remove('open');
}

function clearCustSelection() {
    document.getElementById('sendPhone').value          = '';
    document.getElementById('custSearchInput').value    = '';
    document.getElementById('custClearBtn').style.display = 'none';
    document.getElementById('custList').classList.remove('open');
    document.getElementById('custSearchInput').focus();
}

function custKeyNav(e) {
    const items = document.querySelectorAll('#custList .cust-list-item');
    if (!items.length) return;
    if (e.key === 'ArrowDown') {
        e.preventDefault();
        custHighlight = Math.min(custHighlight + 1, items.length - 1);
    } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        custHighlight = Math.max(custHighlight - 1, 0);
    } else if (e.key === 'Enter' && custHighlight >= 0) {
        e.preventDefault();
        const el = items[custHighlight];
        selectCust(el.dataset.phone, el.dataset.name);
        return;
    } else if (e.key === 'Escape') {
        document.getElementById('custList').classList.remove('open');
        return;
    } else { return; }
    items.forEach((el, i) => el.classList.toggle('highlighted', i === custHighlight));
    items[custHighlight]?.scrollIntoView({ block:'nearest' });
}

// Tutup dropdown saat klik di luar
document.addEventListener('click', e => {
    if (!e.target.closest('.cust-dropdown')) {
        document.getElementById('custList')?.classList.remove('open');
    }
});

// Reset dropdown saat modal dibuka
document.getElementById('sendModal').addEventListener('click', () => {});
function openSendModal() {
    clearCustSelection();
    document.getElementById('sendMessage').value = '';
    document.getElementById('sendModal').style.display = 'flex';
    setTimeout(() => document.getElementById('custSearchInput').focus(), 100);
}

async function sendToCustomer() {
    const phone   = document.getElementById('sendPhone').value.trim();
    const message = document.getElementById('sendMessage').value.trim();
    if (!phone || !message) return showToast('Nomor dan pesan wajib diisi', 'error');

    const res  = await fetch('/wa/api/send', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ phone, message })
    });
    const d = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) {
        document.getElementById('sendModal').style.display = 'none';
        document.getElementById('sendMessage').value = '';
        clearCustSelection();
    }
}

// ── Sync ──
async function cleanupData(btn) {
    const oldHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
    const res = await fetch('/wa/api/cleanup', { method: 'POST' });
    const d   = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) setTimeout(() => location.reload(), 800);
    btn.disabled = false;
    btn.innerHTML = oldHtml;
}

async function syncMessages(btn) {
    const oldHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sync...';
    const res = await fetch('/wa/api/sync', { method: 'POST' });
    const d   = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) setTimeout(() => location.reload(), 1000);
    btn.disabled = false;
    btn.innerHTML = oldHtml;
}

// ── Live stats update ──
async function updateStats() {
    try {
        const res  = await fetch('/wa/api/stats');
        const data = await res.json();
        if (data.success && data.stats) {
            const s = data.stats;
            document.getElementById('statTotal').textContent    = s.total || 0;
            document.getElementById('statIncoming').textContent = s.incoming || 0;
            document.getElementById('statOutgoing').textContent = s.outgoing || 0;
            document.getElementById('statUnread').textContent   = s.unread || 0;
        }
    } catch(e) {}
}
setInterval(updateStats, 15000);

// ── Live status WA ──
async function checkWAStatus() {
    try {
        const res  = await fetch('/wa/api/status');
        const data = await res.json();
        const badge = document.getElementById('waStatusBadge');
        const text  = document.getElementById('waStatusText');
        badge.className = 'wa-status ' + (data.status === 'READY' ? 'ready' : data.status === 'INITIALIZING' ? 'init' : 'offline');
        text.textContent = data.status === 'READY' ? 'Terhubung' : data.status === 'INITIALIZING' ? 'Menghubungkan...' : 'Tidak Terhubung';
    } catch(e) {}
}
setInterval(checkWAStatus, 10000);

// ── Auto-open chat dari URL hash saat refresh ──
(function autoOpenFromHash() {
    const hash = window.location.hash.replace('#', '');
    if (!hash) return;
    const el = document.querySelector(`.contact-item[data-phone="${hash}"]`);
    if (el) {
        // Ambil custId dari data attribute (lebih aman dari parsing onclick)
        const phone  = el.dataset.phone;
        const name   = el.dataset.name;
        const custId = el.dataset.custid || '';
        setTimeout(() => openChat(phone, name, custId), 300);
    }
})();

function escapeHtml(str) {
    return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
}
function showToast(msg, type) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.style.borderColor = type === 'success' ? 'rgba(16,185,129,.4)' : 'rgba(239,68,68,.4)';
    t.style.color = type === 'success' ? '#10B981' : '#EF4444';
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3500);
}

// ── Tab switching ──
function switchWaTab(tab, btn) {
    document.querySelectorAll('.wa-tab').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('pane-' + tab).classList.add('active');
    if (tab === 'templates') loadTemplates();
    if (tab === 'autoreply') loadAutoReplies();
}

// ──────────────────────────────────────────
// TEMPLATE PESAN
// ──────────────────────────────────────────
let templates = [];

async function loadTemplates() {
    const res = await fetch('/wa/api/templates');
    const d   = await res.json();
    templates = d.data || [];
    renderTemplates();
    renderTplPicker();
}

function renderTemplates() {
    const el = document.getElementById('tplList');
    if (!templates.length) {
        el.innerHTML = '<div style="padding:30px;text-align:center;color:var(--muted);font-size:13px;"><i class="fas fa-file-alt" style="font-size:32px;opacity:.2;display:block;margin-bottom:10px"></i>Belum ada template. Klik "+ Tambah Template".</div>';
        return;
    }
    el.innerHTML = templates.map(t => `
        <div class="tpl-row">
            <div class="tpl-body">
                <div class="tpl-name">${escHtml(t.name)}</div>
                <div class="tpl-content">${escHtml(t.content)}</div>
            </div>
            <div class="tpl-actions">
                <button class="btn btn-sm" style="background:var(--sub-bg);border:1px solid var(--border)" onclick="editTpl(${t.id})"><i class="fas fa-edit"></i></button>
                <button class="btn btn-sm" style="background:rgba(239,68,68,.1);color:#EF4444;border:1px solid rgba(239,68,68,.2)" onclick="deleteTpl(${t.id})"><i class="fas fa-trash"></i></button>
            </div>
        </div>`).join('');
}

function renderTplPicker() {
    const el = document.getElementById('tplPicker');
    if (!templates.length) {
        el.innerHTML = '<div style="padding:12px 14px;color:var(--muted);font-size:12px;">Belum ada template</div>';
        return;
    }
    el.innerHTML = templates.map(t => `
        <div class="tpl-pick-item" onclick="applyTemplate(${JSON.stringify(t.content).replace(/</g,'&lt;')})">
            <div class="tpl-pick-name">${escHtml(t.name)}</div>
            <div class="tpl-pick-preview">${escHtml(t.content.substring(0,60))}${t.content.length>60?'…':''}</div>
        </div>`).join('');
}

function applyTemplate(content) {
    document.getElementById('chatInput').value = content;
    autoResize(document.getElementById('chatInput'));
    document.getElementById('tplPicker').classList.remove('open');
}

function toggleTplPicker() {
    const p = document.getElementById('tplPicker');
    if (!templates.length) loadTemplates().then(() => p.classList.toggle('open'));
    else p.classList.toggle('open');
}
document.addEventListener('click', e => {
    if (!e.target.closest('.chat-input-wrap') && !e.target.closest('[onclick*="toggleTplPicker"]')) {
        document.getElementById('tplPicker')?.classList.remove('open');
    }
});

function openTplModal(id) {
    document.getElementById('tplEditId').value = id || '';
    document.getElementById('tplModalTitle').textContent = id ? '✏️ Edit Template' : '📝 Tambah Template';
    if (id) {
        const t = templates.find(x => x.id == id);
        document.getElementById('tplName').value    = t ? t.name : '';
        document.getElementById('tplContent').value = t ? t.content : '';
    } else {
        document.getElementById('tplName').value    = '';
        document.getElementById('tplContent').value = '';
    }
    document.getElementById('tplModal').style.display = 'flex';
}
function closeTplModal() { document.getElementById('tplModal').style.display = 'none'; }
function editTpl(id) { openTplModal(id); }

async function saveTpl() {
    const id      = document.getElementById('tplEditId').value;
    const name    = document.getElementById('tplName').value.trim();
    const content = document.getElementById('tplContent').value.trim();
    if (!name || !content) return showToast('Nama dan isi template wajib diisi', 'error');
    const url    = id ? `/wa/api/templates/${id}` : '/wa/api/templates';
    const method = id ? 'PUT' : 'POST';
    const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify({name, content}) });
    const d   = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) { closeTplModal(); loadTemplates(); }
}

async function deleteTpl(id) {
    if (!confirm('Hapus template ini?')) return;
    const res = await fetch(`/wa/api/templates/${id}`, { method: 'DELETE' });
    const d   = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) loadTemplates();
}

// ──────────────────────────────────────────
// AUTO REPLY
// ──────────────────────────────────────────
let autoReplies = [];

async function loadAutoReplies() {
    const res = await fetch('/wa/api/auto-replies');
    const d   = await res.json();
    autoReplies = d.data || [];
    renderAutoReplies();
}

function renderAutoReplies() {
    const el = document.getElementById('arList');
    if (!autoReplies.length) {
        el.innerHTML = '<div style="padding:30px;text-align:center;color:var(--muted);font-size:13px;"><i class="fas fa-robot" style="font-size:32px;opacity:.2;display:block;margin-bottom:10px"></i>Belum ada aturan auto-reply.</div>';
        return;
    }
    const matchLabel = { contains:'contains', exact:'exact', startswith:'starts with' };
    el.innerHTML = autoReplies.map(r => `
        <div class="tpl-row">
            <label class="toggle-switch" title="${r.is_active ? 'Aktif – klik untuk nonaktifkan' : 'Nonaktif – klik untuk aktifkan'}">
                <input type="checkbox" ${r.is_active ? 'checked' : ''} onchange="toggleAr(${r.id})">
                <span class="toggle-track"></span>
            </label>
            <div class="tpl-body">
                <div class="tpl-name" style="display:flex;align-items:center;gap:8px">
                    <span style="font-family:'Courier New',monospace;background:var(--sub-bg);border:1px solid var(--border);padding:1px 7px;border-radius:5px;font-size:12px">${escHtml(r.keyword)}</span>
                    <span class="match-badge match-${r.match_type}">${matchLabel[r.match_type]||r.match_type}</span>
                </div>
                <div class="tpl-content" style="margin-top:4px">${escHtml(r.reply)}</div>
            </div>
            <div class="tpl-actions">
                <button class="btn btn-sm" style="background:var(--sub-bg);border:1px solid var(--border)" onclick="editAr(${r.id})"><i class="fas fa-edit"></i></button>
                <button class="btn btn-sm" style="background:rgba(239,68,68,.1);color:#EF4444;border:1px solid rgba(239,68,68,.2)" onclick="deleteAr(${r.id})"><i class="fas fa-trash"></i></button>
            </div>
        </div>`).join('');
}

function openArModal(id) {
    document.getElementById('arEditId').value = id || '';
    document.getElementById('arModalTitle').textContent = id ? '✏️ Edit Auto Reply' : '🤖 Tambah Auto Reply';
    if (id) {
        const r = autoReplies.find(x => x.id == id);
        document.getElementById('arKeyword').value   = r ? r.keyword : '';
        document.getElementById('arMatchType').value = r ? r.match_type : 'contains';
        document.getElementById('arReply').value     = r ? r.reply : '';
    } else {
        document.getElementById('arKeyword').value   = '';
        document.getElementById('arMatchType').value = 'contains';
        document.getElementById('arReply').value     = '';
    }
    document.getElementById('arModal').style.display = 'flex';
}
function closeArModal() { document.getElementById('arModal').style.display = 'none'; }
function editAr(id) { openArModal(id); }

async function saveAr() {
    const id         = document.getElementById('arEditId').value;
    const keyword    = document.getElementById('arKeyword').value.trim();
    const match_type = document.getElementById('arMatchType').value;
    const reply      = document.getElementById('arReply').value.trim();
    if (!keyword || !reply) return showToast('Keyword dan balasan wajib diisi', 'error');
    const url    = id ? `/wa/api/auto-replies/${id}` : '/wa/api/auto-replies';
    const method = id ? 'PUT' : 'POST';
    const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify({keyword, match_type, reply}) });
    const d   = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) { closeArModal(); loadAutoReplies(); }
}

async function toggleAr(id) {
    await fetch(`/wa/api/auto-replies/${id}/toggle`, { method: 'POST' });
    loadAutoReplies();
}

async function deleteAr(id) {
    if (!confirm('Hapus aturan auto-reply ini?')) return;
    const res = await fetch(`/wa/api/auto-replies/${id}`, { method: 'DELETE' });
    const d   = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) loadAutoReplies();
}

function escHtml(str) { return (str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
</script>
</body>
</html>
