<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:20px;}
        .stat-card{background:var(--card-bg);border:1px solid var(--border);border-radius:14px;padding:16px;position:relative;overflow:hidden;}
        .stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
        .stat-card.blue::before{background:linear-gradient(90deg,#3B82F6,#60A5FA);}
        .stat-card.green::before{background:linear-gradient(90deg,#10B981,#34D399);}
        .stat-card.amber::before{background:linear-gradient(90deg,#F59E0B,#FCD34D);}
        .stat-card.red::before{background:linear-gradient(90deg,#EF4444,#F87171);}
        .stat-card.purple::before{background:linear-gradient(90deg,#8B5CF6,#A78BFA);}
        .stat-card.orange::before{background:linear-gradient(90deg,#F97316,#FB923C);}
        .stat-label{font-size:11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;}
        .stat-val{font-size:26px;font-weight:800;line-height:1;}
        .stat-sub{font-size:11px;color:var(--muted);margin-top:4px;}

        .chart-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
        .chart-card{background:var(--card-bg);border:1px solid var(--border);border-radius:16px;padding:20px;}
        .chart-title{font-size:14px;font-weight:700;margin:0 0 16px;}
        .chart-wrap{position:relative;height:240px;}

        .tbl-card{background:var(--card-bg);border:1px solid var(--border);border-radius:16px;overflow:hidden;margin-bottom:16px;}
        table{width:100%;border-collapse:collapse;}
        th{background:var(--sub-bg);color:var(--muted);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;padding:10px 14px;text-align:left;}
        td{padding:10px 14px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:middle;}
        tr:last-child td{border-bottom:none;}tr:hover td{background:var(--hover-bg);}

        .progress-bar{height:6px;background:var(--sub-bg);border-radius:3px;overflow:hidden;margin-top:4px;}
        .progress-fill{height:100%;border-radius:3px;transition:width .5s;}
        @media(max-width:900px){.chart-grid{grid-template-columns:1fr;}}
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: 'Laporan Tiket' }) %>
    <div class="content">

        <!-- Header -->
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
            <div>
                <h1 class="page-title" style="margin:0;">📊 Laporan & Statistik Tiket</h1>
                <p style="margin:4px 0 0;font-size:13px;color:var(--muted);">Analisis tiket komplain tahun <%= year %></p>
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
                <a href="/tickets" class="btn" style="background:var(--sub-bg);border:1px solid var(--border);color:var(--text);font-size:12px;">← Daftar Tiket</a>
                <form method="GET" style="display:flex;gap:8px;">
                    <select name="year" class="btn" style="background:var(--sub-bg);border:1px solid var(--border);color:var(--text);cursor:pointer;" onchange="this.form.submit()">
                        <% years.forEach(y => { %>
                        <option value="<%= y.yr %>" <%=y.yr===year?'selected':''%>><%= y.yr %></option>
                        <% }) %>
                        <% if(!years.find(y=>y.yr===new Date().getFullYear())){ %>
                        <option value="<%= new Date().getFullYear() %>" <%=new Date().getFullYear()===year?'selected':''%>><%= new Date().getFullYear() %></option>
                        <% } %>
                    </select>
                </form>
            </div>
        </div>

        <!-- Summary Stats -->
        <div class="stats-row">
            <div class="stat-card blue"><div class="stat-label">Total Tiket</div><div class="stat-val"><%= summary.total||0 %></div></div>
            <div class="stat-card green"><div class="stat-label">✅ Selesai</div><div class="stat-val"><%= summary.closed||0 %></div><div class="stat-sub"><%= summary.total>0?Math.round((summary.closed/summary.total)*100):0 %>% resolve rate</div></div>
            <div class="stat-card amber"><div class="stat-label">🔧 Proses</div><div class="stat-val"><%= summary.inprogress||0 %></div></div>
            <div class="stat-card orange"><div class="stat-label">🟡 Terbuka</div><div class="stat-val"><%= summary.open||0 %></div></div>
            <div class="stat-card red"><div class="stat-label">🚨 Critical</div><div class="stat-val"><%= summary.critical||0 %></div></div>
            <div class="stat-card purple"><div class="stat-label">⏱ Avg. Selesai</div><div class="stat-val" style="font-size:18px;"><%= summary.avg_resolve_hours ? summary.avg_resolve_hours+'j' : '-' %></div></div>
        </div>

        <!-- Charts Row 1 -->
        <div class="chart-grid">
            <!-- Tiket per bulan -->
            <div class="chart-card" style="grid-column:1/-1;">
                <p class="chart-title">📈 Tiket per Bulan — <%= year %></p>
                <div class="chart-wrap" style="height:260px;">
                    <canvas id="monthChart"></canvas>
                </div>
            </div>
        </div>

        <div class="chart-grid">
            <!-- Per Kategori -->
            <div class="chart-card">
                <p class="chart-title">🏷 Distribusi per Kategori</p>
                <div class="chart-wrap">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
            <!-- Per Prioritas -->
            <div class="chart-card">
                <p class="chart-title">⚡ Distribusi per Prioritas</p>
                <div class="chart-wrap">
                    <canvas id="priorityChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Tabel per Teknisi -->
        <div class="tbl-card">
            <div style="padding:16px 18px;border-bottom:1px solid var(--border);font-size:14px;font-weight:700;">👷 Performa per Teknisi — <%= year %></div>
            <table>
                <thead><tr>
                    <th>Teknisi</th><th>Total Tiket</th><th>Selesai</th>
                    <th>Resolve Rate</th><th>Avg. Waktu Selesai</th>
                </tr></thead>
                <tbody>
                <% if(perTech.length > 0){ %>
                <% const maxTotal = Math.max(...perTech.map(t=>t.total)); %>
                <% perTech.forEach(t => {
                    const rate = t.total > 0 ? Math.round((t.closed/t.total)*100) : 0;
                    const rateColor = rate>=80?'#10B981':rate>=60?'#F59E0B':'#EF4444';
                %>
                <tr>
                    <td><span style="font-weight:700;">👷 <%= t.username %></span></td>
                    <td>
                        <div style="font-weight:700;"><%= t.total %></div>
                        <div class="progress-bar"><div class="progress-fill" style="width:<%= Math.round((t.total/maxTotal)*100) %>%;background:#3B82F6;"></div></div>
                    </td>
                    <td style="color:#10B981;font-weight:700;"><%= t.closed %></td>
                    <td>
                        <span style="color:<%= rateColor %>;font-weight:700;"><%= rate %>%</span>
                    </td>
                    <td style="color:var(--muted);"><%= t.avg_hours ? t.avg_hours+' jam' : '-' %></td>
                </tr>
                <% }) %>
                <% } else { %>
                <tr><td colspan="5" style="text-align:center;color:var(--muted);padding:30px;">Belum ada data teknisi</td></tr>
                <% } %>
                </tbody>
            </table>
        </div>

        <!-- Tabel per Kategori -->
        <div class="tbl-card">
            <div style="padding:16px 18px;border-bottom:1px solid var(--border);font-size:14px;font-weight:700;">🏷 Detail per Kategori — <%= year %></div>
            <table>
                <thead><tr><th>Kategori</th><th>Total</th><th>Selesai</th><th>Resolve Rate</th><th>Avg. Waktu Selesai</th></tr></thead>
                <tbody>
                <% if(perCategory.length > 0){ %>
                <% const maxCat = Math.max(...perCategory.map(c=>c.total)); %>
                <% perCategory.forEach(c => {
                    const rate = c.total > 0 ? Math.round((c.closed/c.total)*100) : 0;
                    const catLabel = {gangguan:'📡 Gangguan',no_signal:'📵 No Signal',lambat:'🐌 Lambat',billing:'💳 Billing',pasang_baru:'🆕 Pasang Baru',relokasi:'🚚 Relokasi',transmisi:'📡 Transmisi',kabel_putus:'🔌 Kabel Putus',perangkat_rusak:'⚙️ Perangkat Rusak','lain-lain':'📝 Lain-lain'}[c.category]||(c.category||'-');
                %>
                <tr>
                    <td style="font-weight:600;"><%= catLabel %></td>
                    <td>
                        <div style="font-weight:700;"><%= c.total %></div>
                        <div class="progress-bar"><div class="progress-fill" style="width:<%= Math.round((c.total/maxCat)*100) %>%;background:#8B5CF6;"></div></div>
                    </td>
                    <td style="color:#10B981;font-weight:700;"><%= c.closed %></td>
                    <td><span style="font-weight:700;color:<%= rate>=80?'#10B981':rate>=60?'#F59E0B':'#EF4444' %>;"><%= rate %>%</span></td>
                    <td style="color:var(--muted);"><%= c.avg_hours ? c.avg_hours+' jam' : '-' %></td>
                </tr>
                <% }) %>
                <% } else { %>
                <tr><td colspan="5" style="text-align:center;color:var(--muted);padding:30px;">Belum ada data</td></tr>
                <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<script>
const MONTHS = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agt','Sep','Okt','Nov','Des'];
const isDark  = document.documentElement.classList.contains('dark') || window.matchMedia('(prefers-color-scheme:dark)').matches;
const gridColor = isDark ? 'rgba(255,255,255,.07)' : 'rgba(0,0,0,.07)';
const textColor = isDark ? '#94A3B8' : '#64748B';

Chart.defaults.font.family = "'Outfit', sans-serif";
Chart.defaults.color = textColor;

// ── Data dari server ──
const monthData = <%- JSON.stringify(perMonth) %>;
const catData   = <%- JSON.stringify(perCategory) %>;
const prioData  = <%- JSON.stringify(perPriority) %>;

// Isi 12 bulan
const monthTotals  = Array(12).fill(0);
const monthClosed  = Array(12).fill(0);
const monthOpen    = Array(12).fill(0);
monthData.forEach(m => {
    monthTotals[m.month-1]  = m.total;
    monthClosed[m.month-1]  = m.closed;
    monthOpen[m.month-1]    = m.open;
});

// Chart per bulan
new Chart(document.getElementById('monthChart'), {
    type: 'bar',
    data: {
        labels: MONTHS,
        datasets: [
            { label: 'Total', data: monthTotals, backgroundColor: 'rgba(59,130,246,.7)', borderRadius:6 },
            { label: 'Selesai', data: monthClosed, backgroundColor: 'rgba(16,185,129,.7)', borderRadius:6 },
            { label: 'Belum Selesai', data: monthOpen, backgroundColor: 'rgba(245,158,11,.7)', borderRadius:6 }
        ]
    },
    options: {
        responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{ position:'top' } },
        scales:{
            x:{ grid:{color:gridColor} },
            y:{ beginAtZero:true, grid:{color:gridColor}, ticks:{stepSize:1} }
        }
    }
});

// Chart kategori
const catColors = ['#8B5CF6','#3B82F6','#10B981','#F59E0B','#EF4444','#F97316','#06B6D4','#EC4899','#94A3B8'];
new Chart(document.getElementById('categoryChart'), {
    type: 'doughnut',
    data: {
        labels: catData.map(c => c.category?.replace('_',' ')||'lain'),
        datasets:[{ data: catData.map(c=>c.total), backgroundColor: catColors, borderWidth:2, borderColor:'transparent' }]
    },
    options: {
        responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{ position:'right', labels:{ boxWidth:12, padding:10, font:{size:11} } } }
    }
});

// Chart prioritas
const prioColors = {critical:'#EF4444', high:'#F97316', normal:'#3B82F6', low:'#94A3B8'};
new Chart(document.getElementById('priorityChart'), {
    type: 'doughnut',
    data: {
        labels: prioData.map(p=>p.priority),
        datasets:[{ data: prioData.map(p=>p.total), backgroundColor: prioData.map(p=>prioColors[p.priority]||'#94A3B8'), borderWidth:2, borderColor:'transparent' }]
    },
    options: {
        responsive:true, maintainAspectRatio:false,
        plugins:{ legend:{ position:'right', labels:{ boxWidth:12, padding:10, font:{size:11} } } }
    }
});
</script>
</body>
</html>
