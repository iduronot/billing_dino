<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <%- include('partials/head') %>
    <style>
        /* ── Summary Cards ── */
        .summary-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:14px; margin-bottom:22px; }
        .sum-card { background:var(--card-bg); border:1px solid var(--border); border-radius:16px; padding:18px 20px; position:relative; overflow:hidden; }
        .sum-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; }
        .sum-card.blue::before   { background:linear-gradient(90deg,#3B82F6,#6366F1); }
        .sum-card.green::before  { background:linear-gradient(90deg,#10B981,#34D399); }
        .sum-card.orange::before { background:linear-gradient(90deg,#F59E0B,#FCD34D); }
        .sum-card.red::before    { background:linear-gradient(90deg,#EF4444,#F87171); }
        .sum-label { font-size:11px; color:var(--muted); font-weight:600; text-transform:uppercase; letter-spacing:.5px; margin-bottom:8px; }
        .sum-value { font-size:26px; font-weight:800; line-height:1; }
        .sum-sub   { font-size:11px; color:var(--muted); margin-top:6px; }
        .sum-icon  { position:absolute; right:16px; top:50%; transform:translateY(-50%); font-size:32px; opacity:.08; }

        /* ── Layout ── */
        .inv-layout { display:grid; grid-template-columns:1fr 320px; gap:20px; align-items:start; }
        @media(max-width:900px){ .inv-layout { grid-template-columns:1fr; } }

        /* ── Item Cards ── */
        .inventory-list { display:flex; flex-direction:column; gap:12px; }
        .item-card {
            background:var(--card-bg); border:1px solid var(--border); border-radius:16px;
            padding:18px 20px; transition:all .2s;
        }
        .item-card:hover { border-color:var(--primary); box-shadow:0 4px 20px rgba(59,130,246,.1); }
        .item-card.low  { border-left:3px solid #F59E0B; }
        .item-card.empty{ border-left:3px solid #EF4444; }
        .item-card.ok   { border-left:3px solid #10B981; }

        .item-top { display:flex; align-items:center; gap:14px; margin-bottom:12px; }
        .cat-icon { width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0; }
        .cat-modem   { background:rgba(139,92,246,.12); color:#8B5CF6; }
        .cat-kabel   { background:rgba(16,185,129,.12);  color:#10B981; }
        .cat-sleeve  { background:rgba(245,158,11,.12);  color:#F59E0B; }
        .cat-tools   { background:rgba(239,68,68,.12);   color:#EF4444; }
        .cat-default { background:rgba(96,165,250,.12);  color:#60A5FA; }

        .item-name  { font-size:15px; font-weight:700; margin:0; line-height:1.2; }
        .item-cat   { font-size:11px; color:var(--muted); margin-top:2px; }
        .item-desc  { font-size:12px; color:var(--muted); margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:260px; }

        .item-meta  { margin-left:auto; text-align:right; flex-shrink:0; }
        .item-price { font-size:12px; color:var(--muted); }
        .item-value { font-size:13px; font-weight:700; color:var(--text); }

        /* Stock Bar */
        .stock-row { display:flex; align-items:center; gap:12px; margin-bottom:12px; }
        .stock-bar-wrap { flex:1; height:8px; background:var(--sub-bg); border-radius:99px; overflow:hidden; }
        .stock-bar { height:100%; border-radius:99px; transition:width .4s; }
        .bar-ok     { background:linear-gradient(90deg,#10B981,#34D399); }
        .bar-low    { background:linear-gradient(90deg,#F59E0B,#FCD34D); }
        .bar-empty  { background:linear-gradient(90deg,#EF4444,#F87171); }
        .stock-num  { font-size:20px; font-weight:800; min-width:60px; text-align:right; }
        .stock-unit { font-size:11px; color:var(--muted); font-weight:600; }
        .stock-min  { font-size:11px; color:var(--muted); }

        .status-badge {
            display:inline-flex; align-items:center; gap:5px;
            padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700;
        }
        .badge-ok    { background:rgba(16,185,129,.12); color:#10B981; border:1px solid rgba(16,185,129,.25); }
        .badge-low   { background:rgba(245,158,11,.12); color:#F59E0B; border:1px solid rgba(245,158,11,.25); }
        .badge-empty { background:rgba(239,68,68,.12);  color:#EF4444; border:1px solid rgba(239,68,68,.25); }

        /* Action Buttons */
        .item-actions { display:flex; gap:8px; }
        .btn-in  { background:rgba(16,185,129,.12); color:#10B981; border:1px solid rgba(16,185,129,.3); border-radius:9px; padding:7px 14px; font-size:12px; font-weight:700; cursor:pointer; font-family:'Outfit',sans-serif; display:flex; align-items:center; gap:6px; transition:all .15s; }
        .btn-in:hover  { background:#10B981; color:white; }
        .btn-out { background:rgba(239,68,68,.1);  color:#EF4444; border:1px solid rgba(239,68,68,.25); border-radius:9px; padding:7px 14px; font-size:12px; font-weight:700; cursor:pointer; font-family:'Outfit',sans-serif; display:flex; align-items:center; gap:6px; transition:all .15s; }
        .btn-out:hover { background:#EF4444; color:white; }
        .btn-hist{ background:rgba(96,165,250,.1);  color:#60A5FA; border:1px solid rgba(96,165,250,.25); border-radius:9px; padding:7px 12px; font-size:12px; cursor:pointer; font-family:'Outfit',sans-serif; transition:all .15s; }
        .btn-hist:hover{ background:#60A5FA; color:white; }
        .btn-edit-sm { background:var(--sub-bg); color:var(--muted); border:1px solid var(--border); border-radius:9px; padding:7px 12px; font-size:12px; cursor:pointer; font-family:'Outfit',sans-serif; transition:all .15s; }
        .btn-edit-sm:hover { color:var(--text); border-color:var(--primary); }
        .btn-del-sm  { background:none; color:var(--muted); border:1px solid transparent; border-radius:9px; padding:7px 10px; font-size:12px; cursor:pointer; transition:all .15s; }
        .btn-del-sm:hover  { color:#EF4444; border-color:rgba(239,68,68,.3); }

        /* ── Side Panel: Aktivitas Hari Ini ── */
        .side-panel { background:var(--card-bg); border:1px solid var(--border); border-radius:16px; padding:18px; position:sticky; top:80px; }
        .side-title { font-size:13px; font-weight:700; margin:0 0 14px; display:flex; align-items:center; gap:8px; }
        .mut-item { display:flex; align-items:flex-start; gap:10px; padding:9px 0; border-bottom:1px solid var(--border); }
        .mut-item:last-child { border-bottom:none; }
        .mut-dot { width:28px; height:28px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:12px; flex-shrink:0; margin-top:1px; }
        .dot-in  { background:rgba(16,185,129,.15); color:#10B981; }
        .dot-out { background:rgba(239,68,68,.12);  color:#EF4444; }
        .mut-name { font-size:12px; font-weight:600; line-height:1.3; }
        .mut-note { font-size:11px; color:var(--muted); margin-top:1px; }
        .mut-qty  { margin-left:auto; font-size:13px; font-weight:800; flex-shrink:0; }
        .mut-time { font-size:10px; color:var(--muted); margin-top:2px; }

        /* ── Modals ── */
        .overlay { position:fixed; inset:0; background:var(--overlay-bg); backdrop-filter:blur(6px); display:none; align-items:center; justify-content:center; z-index:9999; padding:16px; }
        .modal { background:var(--modal-bg); border:1px solid var(--border); border-radius:20px; width:100%; max-width:480px; padding:28px; max-height:90vh; overflow-y:auto; }
        .modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; }
        .modal-title { font-size:18px; font-weight:700; margin:0; }
        .close-btn { background:none; border:none; color:var(--muted); font-size:24px; cursor:pointer; }
        .form-group { margin-bottom:14px; }
        .form-group label { display:block; margin-bottom:6px; font-size:12px; color:var(--muted); font-weight:600; text-transform:uppercase; letter-spacing:.4px; }
        .form-row2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
        .toast { position:fixed; bottom:24px; right:24px; background:var(--modal-bg); color:var(--text); border:1px solid var(--border); border-radius:12px; padding:14px 20px; z-index:99999; display:none; font-size:14px; box-shadow:0 8px 32px rgba(0,0,0,.5); max-width:320px; }
        .toast.show { display:block; }

        /* Teknisi picker */
        .tech-picker { display:flex; flex-direction:column; gap:4px; max-height:180px; overflow-y:auto; border:1px solid var(--border); border-radius:12px; padding:6px; background:var(--sub-bg); }
        .tech-check  { display:flex; align-items:center; gap:10px; padding:8px 10px; border-radius:9px; cursor:pointer; transition:background .15s; user-select:none; }
        .tech-check:hover { background:var(--card-bg); }
        .tech-check.selected { background:rgba(99,102,241,.08); }
        .tech-check input[type=checkbox] { display:none; }
        .tech-avatar { width:32px; height:32px; border-radius:50%; background:rgba(99,102,241,.15); color:#818CF8; font-size:13px; font-weight:800; display:flex; align-items:center; justify-content:center; flex-shrink:0; border:2px solid transparent; transition:border .15s; }
        .tech-check.selected .tech-avatar { border-color:#818CF8; background:rgba(99,102,241,.2); }
        .tech-name-text { font-size:13px; font-weight:600; color:var(--text); flex:1; }
        .tech-check-icon { width:18px; height:18px; border-radius:50%; border:2px solid var(--border); display:flex; align-items:center; justify-content:center; transition:all .15s; flex-shrink:0; }
        .tech-check.selected .tech-check-icon { background:#818CF8; border-color:#818CF8; }
        .tech-check.selected .tech-check-icon::after { content:'✓'; color:white; font-size:10px; font-weight:800; }
        .tech-badge { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; background:rgba(99,102,241,.12); color:#818CF8; border:1px solid rgba(99,102,241,.2); }

        /* Riwayat modal */
        .hist-item { display:flex; align-items:flex-start; gap:10px; padding:10px 0; border-bottom:1px solid var(--border); }
        .hist-item:last-child { border-bottom:none; }

        /* Empty state */
        .empty-state { text-align:center; padding:60px 20px; color:var(--muted); }
        .empty-icon  { font-size:40px; opacity:.25; margin-bottom:12px; }
    </style>
</head>
<body>
<%- include('partials/sidebar') %>
<main class="main">
    <%- include('partials/topbar', { title: 'Inventaris Gudang' }) %>
    <div class="content">

        <!-- Header -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-wrap:wrap; gap:12px;">
            <div>
                <h1 class="page-title" style="margin:0 0 4px;">📦 Inventaris Gudang</h1>
                <p style="color:var(--muted); font-size:13px; margin:0;">Monitor stok, mutasi barang, dan nilai aset gudang ISP</p>
            </div>
            <button class="btn btn-primary" onclick="showAddModal()">
                <i class="fas fa-plus"></i> Tambah Barang
            </button>
        </div>

        <!-- Summary Cards -->
        <div class="summary-grid">
            <div class="sum-card blue">
                <div class="sum-label">Total Jenis Barang</div>
                <div class="sum-value"><%= stats.total_items || 0 %></div>
                <div class="sum-sub">jenis item tercatat</div>
                <i class="fas fa-boxes sum-icon"></i>
            </div>
            <div class="sum-card green">
                <div class="sum-label">Nilai Stok Gudang</div>
                <div class="sum-value" style="font-size:18px;">Rp <%= Math.floor(stats.total_value||0).toLocaleString('id-ID') %></div>
                <div class="sum-sub">estimasi total aset</div>
                <i class="fas fa-coins sum-icon"></i>
            </div>
            <div class="sum-card orange">
                <div class="sum-label">Stok Hampir Habis</div>
                <div class="sum-value" style="color:<%= (stats.low_stock_count||0)>0?'#F59E0B':'inherit' %>"><%= stats.low_stock_count || 0 %></div>
                <div class="sum-sub">di bawah batas minimum</div>
                <i class="fas fa-exclamation-triangle sum-icon"></i>
            </div>
            <div class="sum-card red">
                <div class="sum-label">Stok Kosong</div>
                <div class="sum-value" style="color:<%= (stats.empty_count||0)>0?'#EF4444':'inherit' %>"><%= stats.empty_count || 0 %></div>
                <div class="sum-sub">barang habis, perlu restok</div>
                <i class="fas fa-battery-empty sum-icon"></i>
            </div>
        </div>

        <!-- Main Layout -->
        <div class="inv-layout">

            <!-- Item List -->
            <div class="inventory-list">
            <% if (items.length > 0) { %>
                <% items.forEach(item => {
                    const pct = item.min_stock > 0 ? Math.min(100, Math.round(item.stock / (item.min_stock * 2) * 100)) : (item.stock > 0 ? 100 : 0);
                    const state = item.stock === 0 ? 'empty' : (item.min_stock > 0 && item.stock < item.min_stock ? 'low' : 'ok');
                    const barClass = state === 'ok' ? 'bar-ok' : state === 'low' ? 'bar-low' : 'bar-empty';
                    const badgeClass = state === 'ok' ? 'badge-ok' : state === 'low' ? 'badge-low' : 'badge-empty';
                    const badgeLabel = state === 'ok' ? '✓ Tersedia' : state === 'low' ? '⚠ Hampir Habis' : '✕ Kosong';
                    let iconClass = 'fas fa-box'; let catCss = 'cat-default';
                    if(item.category==='Modem'||item.category==='ONT'){ iconClass='fas fa-router'; catCss='cat-modem'; }
                    else if(item.category==='Kabel'){ iconClass='fas fa-network-wired'; catCss='cat-kabel'; }
                    else if(item.category==='Protect Sleeve'){ iconClass='fas fa-grip-lines'; catCss='cat-sleeve'; }
                    else if(item.category==='Tools'||item.category==='Peralatan'){ iconClass='fas fa-tools'; catCss='cat-tools'; }
                %>
                <div class="item-card <%= state %>">
                    <div class="item-top">
                        <div class="cat-icon <%= catCss %>"><i class="<%= iconClass %>"></i></div>
                        <div style="flex:1; min-width:0;">
                            <div class="item-name"><%= item.name %></div>
                            <div class="item-cat"><%= item.category || 'Lain-lain' %></div>
                            <% if(item.description) { %><div class="item-desc"><%= item.description %></div><% } %>
                        </div>
                        <div class="item-meta">
                            <% if(item.price > 0) { %>
                            <div class="item-price">Harga satuan</div>
                            <div class="item-value">Rp <%= Math.floor(item.price).toLocaleString('id-ID') %></div>
                            <div style="font-size:10px; color:var(--muted); margin-top:2px;">
                                Nilai: Rp <%= Math.floor((item.price * item.stock)||0).toLocaleString('id-ID') %>
                            </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Stock Bar -->
                    <div class="stock-row">
                        <div style="flex:1;">
                            <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                                <span class="status-badge <%= badgeClass %>"><%= badgeLabel %></span>
                                <% if(item.min_stock > 0) { %>
                                <span class="stock-min">Min: <%= item.min_stock %> <%= item.unit %></span>
                                <% } %>
                            </div>
                            <div class="stock-bar-wrap">
                                <div class="stock-bar <%= barClass %>" style="width:<%= Math.max(2, pct) %>%"></div>
                            </div>
                        </div>
                        <div style="text-align:right; flex-shrink:0;">
                            <div class="stock-num" style="color:<%= state==='ok'?'var(--text)':state==='low'?'#F59E0B':'#EF4444' %>"><%= item.stock %></div>
                            <div class="stock-unit"><%= item.unit %></div>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="item-actions">
                        <button class="btn-in" onclick="openMutasi(<%= item.id %>,'<%= item.name.replace(/'/g,"\\'") %>','<%= item.unit %>','in')">
                            <i class="fas fa-plus"></i> Barang Masuk
                        </button>
                        <button class="btn-out" onclick="openMutasi(<%= item.id %>,'<%= item.name.replace(/'/g,"\\'") %>','<%= item.unit %>','out')" <%= item.stock===0?'disabled style="opacity:.4;cursor:not-allowed"':'' %>>
                            <i class="fas fa-minus"></i> Barang Keluar
                        </button>
                        <button class="btn-hist" onclick="openRiwayat(<%= item.id %>,'<%= item.name.replace(/'/g,"\\'") %>')" title="Riwayat mutasi">
                            <i class="fas fa-history"></i>
                        </button>
                        <button class="btn-edit-sm" onclick='showEditModal(<%- JSON.stringify(item) %>)' title="Edit">
                            <i class="fas fa-pen"></i>
                        </button>
                        <button class="btn-del-sm" onclick="deleteItem(<%= item.id %>)" title="Hapus">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>
                </div>
                <% }); %>
            <% } else { %>
                <div class="empty-state">
                    <div class="empty-icon"><i class="fas fa-box-open"></i></div>
                    <div style="font-weight:700; font-size:16px; margin-bottom:6px;">Belum ada barang</div>
                    <div style="font-size:13px;">Klik "Tambah Barang" untuk mulai mencatat stok gudang</div>
                </div>
            <% } %>
            </div>

            <!-- Side Panel: Aktivitas Hari Ini -->
            <div class="side-panel">
                <div class="side-title">
                    <span style="background:rgba(59,130,246,.15);color:var(--primary);width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:12px;"><i class="fas fa-bolt"></i></span>
                    Aktivitas Hari Ini
                    <span style="margin-left:auto;background:var(--sub-bg);border:1px solid var(--border);border-radius:20px;padding:2px 8px;font-size:11px;color:var(--muted);">
                        <%= todayMutations.length %> transaksi
                    </span>
                </div>
                <% if(todayMutations.length > 0) { %>
                    <% todayMutations.forEach(m => { %>
                    <div class="mut-item">
                        <div class="mut-dot <%= m.type==='in'?'dot-in':'dot-out' %>">
                            <i class="fas fa-<%= m.type==='in'?'arrow-down':'arrow-up' %>"></i>
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div class="mut-name"><%= m.item_name %></div>
                            <div class="mut-note"><%= m.note || (m.type==='in'?'Barang masuk':'Barang keluar') %></div>
                            <% if(m.type==='out' && m.technicians && m.technicians.length > 0) { %>
                            <div style="margin-top:3px; display:flex; flex-wrap:wrap; gap:3px;">
                                <% m.technicians.forEach(t => { %><span class="tech-badge">👷 <%= t %></span><% }); %>
                            </div>
                            <% } %>
                            <div class="mut-time"><%= new Date(m.created_at).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) %> · <%= m.user_name %></div>
                        </div>
                        <div class="mut-qty" style="color:<%= m.type==='in'?'#10B981':'#EF4444' %>">
                            <%= m.type==='in'?'+':'-' %><%= m.quantity %> <span style="font-size:10px;font-weight:500;color:var(--muted);"><%= m.unit %></span>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <div style="text-align:center;padding:30px 0;color:var(--muted);font-size:13px;">
                        <i class="fas fa-clock" style="font-size:24px;opacity:.3;display:block;margin-bottom:8px;"></i>
                        Belum ada aktivitas hari ini
                    </div>
                <% } %>
            </div>

        </div>
    </div>
</main>

<!-- Modal: Tambah / Edit Barang -->
<div class="overlay" id="itemModal" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2 class="modal-title" id="modalTitle">Tambah Barang</h2>
            <button class="close-btn" onclick="document.getElementById('itemModal').style.display='none'">×</button>
        </div>
        <form id="itemForm">
            <input type="hidden" id="itemId">
            <div class="form-group">
                <label>Nama Barang *</label>
                <input type="text" id="itemName" class="form-control" required placeholder="Contoh: ONT Huawei HG8310M">
            </div>
            <div class="form-row2">
                <div class="form-group">
                    <label>Kategori</label>
                    <select id="itemCategory" class="form-control">
                        <option value="Modem">Modem / ONT</option>
                        <option value="Kabel">Kabel</option>
                        <option value="Protect Sleeve">Protect Sleeve</option>
                        <option value="Tools">Peralatan / Tools</option>
                        <option value="Splitter">Splitter</option>
                        <option value="Konektor">Konektor</option>
                        <option value="Lain-lain">Lain-lain</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Satuan</label>
                    <input type="text" id="itemUnit" class="form-control" value="pcs" placeholder="pcs / meter / roll">
                </div>
            </div>
            <div class="form-row2">
                <div class="form-group">
                    <label>Stok Awal</label>
                    <input type="number" id="itemStock" class="form-control" value="0" min="0">
                </div>
                <div class="form-group">
                    <label>Stok Minimum Alert</label>
                    <input type="number" id="itemMinStock" class="form-control" value="5" min="0" placeholder="0 = nonaktif">
                </div>
            </div>
            <div class="form-group">
                <label>Harga Beli Satuan (Rp)</label>
                <input type="number" id="itemPrice" class="form-control" value="0" min="0" placeholder="0 jika tidak diketahui">
            </div>
            <div class="form-group">
                <label>Keterangan</label>
                <textarea id="itemDesc" class="form-control" rows="2" placeholder="Spesifikasi, merk, atau catatan lain"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:13px;margin-top:4px;font-size:15px;">
                <i class="fas fa-save"></i> Simpan Barang
            </button>
        </form>
    </div>
</div>

<!-- Data teknisi (server-side) -->
<textarea id="techData" style="display:none"><%- JSON.stringify(technicians) %></textarea>

<!-- Modal: Mutasi Stok -->
<div class="overlay" id="mutasiModal" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal" style="max-width:420px;" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2 class="modal-title" id="mutasiTitle">Barang Masuk</h2>
            <button class="close-btn" onclick="document.getElementById('mutasiModal').style.display='none'">×</button>
        </div>
        <div id="mutasiItemName" style="background:var(--sub-bg);border:1px solid var(--border);border-radius:10px;padding:10px 14px;margin-bottom:18px;font-weight:600;font-size:14px;"></div>
        <input type="hidden" id="mutasiId">
        <input type="hidden" id="mutasiType">
        <div class="form-group">
            <label>Jumlah <span id="mutasiUnitLabel"></span></label>
            <input type="number" id="mutasiQty" class="form-control" min="1" value="1" style="font-size:24px;font-weight:700;text-align:center;">
        </div>
        <!-- Teknisi picker — hanya tampil untuk barang keluar -->
        <div class="form-group" id="techPickerGroup" style="display:none;">
            <label>Teknisi yang Mengambil <span style="color:#EF4444">*</span></label>
            <div class="tech-picker" id="techPicker"></div>
            <div id="techSelected" style="display:none; margin-top:8px; display:flex; flex-wrap:wrap; gap:4px;"></div>
        </div>
        <div class="form-group">
            <label>Keterangan (opsional)</label>
            <input type="text" id="mutasiNote" class="form-control" placeholder="Contoh: Instalasi pelanggan Budi / Beli dari Toko ABC">
        </div>
        <button class="btn btn-primary" id="mutasiSubmitBtn" onclick="submitMutasi()" style="width:100%;justify-content:center;padding:13px;font-size:15px;">
            <i class="fas fa-check"></i> Konfirmasi
        </button>
    </div>
</div>

<!-- Modal: Riwayat Mutasi -->
<div class="overlay" id="riwayatModal" onclick="if(event.target===this)this.style.display='none'">
    <div class="modal" style="max-width:520px;" onclick="event.stopPropagation()">
        <div class="modal-header">
            <h2 class="modal-title" id="riwayatTitle">Riwayat Mutasi</h2>
            <button class="close-btn" onclick="document.getElementById('riwayatModal').style.display='none'">×</button>
        </div>
        <div id="riwayatContent" style="max-height:420px;overflow-y:auto;">
            <div style="text-align:center;padding:30px;color:var(--muted)"><i class="fas fa-spinner fa-spin"></i></div>
        </div>
    </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ── Add / Edit Modal ──
function showAddModal() {
    document.getElementById('modalTitle').textContent = 'Tambah Barang';
    document.getElementById('itemForm').reset();
    document.getElementById('itemId').value = '';
    document.getElementById('itemStock').value = 0;
    document.getElementById('itemMinStock').value = 5;
    document.getElementById('itemPrice').value = 0;
    document.getElementById('itemModal').style.display = 'flex';
}

function showEditModal(item) {
    document.getElementById('modalTitle').textContent = 'Edit Barang';
    document.getElementById('itemId').value       = item.id;
    document.getElementById('itemName').value     = item.name;
    document.getElementById('itemCategory').value = item.category || 'Lain-lain';
    document.getElementById('itemStock').value    = item.stock;
    document.getElementById('itemUnit').value     = item.unit;
    document.getElementById('itemMinStock').value = item.min_stock || 0;
    document.getElementById('itemPrice').value    = item.price || 0;
    document.getElementById('itemDesc').value     = item.description || '';
    document.getElementById('itemModal').style.display = 'flex';
}

document.getElementById('itemForm').onsubmit = async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Menyimpan...';
    const body = {
        id: document.getElementById('itemId').value,
        name: document.getElementById('itemName').value,
        category: document.getElementById('itemCategory').value,
        stock: document.getElementById('itemStock').value,
        unit: document.getElementById('itemUnit').value,
        min_stock: document.getElementById('itemMinStock').value,
        price: document.getElementById('itemPrice').value,
        description: document.getElementById('itemDesc').value
    };
    const res = await fetch('/inventory/api/save', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
    const d = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) setTimeout(() => location.reload(), 800);
    else { btn.disabled = false; btn.innerHTML = '<i class="fas fa-save"></i> Simpan Barang'; }
};

// ── Teknisi data ──
const TECHNICIANS = JSON.parse(document.getElementById('techData').value || '[]');

function initials(name) {
    return name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
}

function buildTechPicker() {
    const picker = document.getElementById('techPicker');
    if (TECHNICIANS.length === 0) {
        picker.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:10px;text-align:center;">Belum ada data teknisi</div>';
        return;
    }
    picker.innerHTML = TECHNICIANS.map(t => `
        <div class="tech-check" data-id="${t.id}" data-name="${t.username}" onclick="toggleTech(this)">
            <input type="checkbox" value="${t.id}" data-name="${t.username}">
            <div class="tech-avatar">${initials(t.username)}</div>
            <span class="tech-name-text">${t.username}</span>
            <div class="tech-check-icon"></div>
        </div>`).join('');
    updateTechBadges();
}

function toggleTech(el) {
    el.classList.toggle('selected');
    el.querySelector('input[type=checkbox]').checked = el.classList.contains('selected');
    updateTechBadges();
}

function updateTechBadges() {
    const selected = [...document.querySelectorAll('#techPicker .tech-check.selected')];
    const wrap = document.getElementById('techSelected');
    if (selected.length === 0) { wrap.style.display = 'none'; wrap.innerHTML = ''; return; }
    wrap.style.display = 'flex';
    wrap.innerHTML = selected.map(el => `<span class="tech-badge">${initials(el.dataset.name)} ${el.dataset.name}</span>`).join('');
}

function getSelectedTechIds() {
    return [...document.querySelectorAll('#techPicker .tech-check.selected')].map(el => el.dataset.id);
}

// ── Mutasi Stok ──
function openMutasi(id, name, unit, type) {
    document.getElementById('mutasiId').value   = id;
    document.getElementById('mutasiType').value = type;
    document.getElementById('mutasiQty').value  = 1;
    document.getElementById('mutasiNote').value = '';
    document.getElementById('mutasiItemName').textContent = name;
    document.getElementById('mutasiUnitLabel').textContent = '(' + unit + ')';

    const isIn = type === 'in';
    document.getElementById('mutasiTitle').textContent = isIn ? '📥 Barang Masuk' : '📤 Barang Keluar';
    const btn = document.getElementById('mutasiSubmitBtn');
    btn.disabled = false;
    btn.style.background = isIn ? 'linear-gradient(135deg,#10B981,#059669)' : 'linear-gradient(135deg,#EF4444,#DC2626)';
    btn.innerHTML = isIn ? '<i class="fas fa-arrow-down"></i> Catat Masuk' : '<i class="fas fa-arrow-up"></i> Catat Keluar';

    // Tampilkan teknisi picker hanya untuk keluar
    const group = document.getElementById('techPickerGroup');
    group.style.display = isIn ? 'none' : 'block';
    group.style.outline = '';
    if (!isIn) buildTechPicker();

    document.getElementById('mutasiModal').style.display = 'flex';
    setTimeout(() => document.getElementById('mutasiQty').focus(), 100);
}

async function submitMutasi() {
    const qty = parseInt(document.getElementById('mutasiQty').value);
    if (!qty || qty < 1) return showToast('Jumlah harus lebih dari 0', 'error');

    const type = document.getElementById('mutasiType').value;
    const techIds = getSelectedTechIds();
    if (type === 'out' && techIds.length === 0) {
        showToast('Pilih minimal satu teknisi untuk barang keluar', 'error');
        document.getElementById('techPickerGroup').style.outline = '2px solid #EF4444';
        setTimeout(() => document.getElementById('techPickerGroup').style.outline = '', 1500);
        return;
    }

    const btn = document.getElementById('mutasiSubmitBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Menyimpan...';

    const body = {
        inventory_id: document.getElementById('mutasiId').value,
        type,
        quantity: qty,
        note: document.getElementById('mutasiNote').value,
        technician_ids: techIds
    };
    const res = await fetch('/inventory/api/mutasi', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
    const d = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) { document.getElementById('mutasiModal').style.display = 'none'; setTimeout(() => location.reload(), 900); }
    else { btn.disabled = false; btn.innerHTML = '<i class="fas fa-check"></i> Konfirmasi'; }
}

// Enter key on qty input triggers submit
document.getElementById('mutasiQty').addEventListener('keydown', e => { if (e.key === 'Enter') submitMutasi(); });

// ── Riwayat Mutasi ──
async function openRiwayat(id, name) {
    document.getElementById('riwayatTitle').textContent = '📋 Riwayat — ' + name;
    document.getElementById('riwayatContent').innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)"><i class="fas fa-spinner fa-spin"></i> Memuat...</div>';
    document.getElementById('riwayatModal').style.display = 'flex';

    const res = await fetch('/inventory/api/mutasi/' + id);
    const d = await res.json();
    if (!d.success || d.data.length === 0) {
        document.getElementById('riwayatContent').innerHTML = '<div style="text-align:center;padding:40px;color:var(--muted);font-size:13px;"><i class="fas fa-history" style="font-size:28px;opacity:.25;display:block;margin-bottom:10px;"></i>Belum ada riwayat mutasi</div>';
        return;
    }
    document.getElementById('riwayatContent').innerHTML = d.data.map(m => {
        const techHtml = (m.type === 'out' && m.technicians && m.technicians.length > 0)
            ? `<div style="margin-top:4px;display:flex;flex-wrap:wrap;gap:3px;">${m.technicians.map(t=>`<span class="tech-badge">👷 ${t}</span>`).join('')}</div>`
            : '';
        return `
        <div class="hist-item">
            <div style="width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;margin-top:2px;
                background:${m.type==='in'?'rgba(16,185,129,.12)':'rgba(239,68,68,.1)'};
                color:${m.type==='in'?'#10B981':'#EF4444'};">
                <i class="fas fa-arrow-${m.type==='in'?'down':'up'}"></i>
            </div>
            <div style="flex:1;min-width:0;">
                <div style="font-size:13px;font-weight:600;">${m.type==='in'?'Barang Masuk':'Barang Keluar'}</div>
                <div style="font-size:11px;color:var(--muted);">${m.note||'-'} · ${m.user_name||'Admin'}</div>
                ${techHtml}
            </div>
            <div style="text-align:right;flex-shrink:0;">
                <div style="font-size:15px;font-weight:800;color:${m.type==='in'?'#10B981':'#EF4444'};">
                    ${m.type==='in'?'+':'-'}${m.quantity}
                </div>
                <div style="font-size:10px;color:var(--muted);">
                    ${new Date(m.created_at).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'})}
                    ${new Date(m.created_at).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'})}
                </div>
            </div>
        </div>`;
    }).join('');
}

// ── Delete ──
async function deleteItem(id) {
    if (!confirm('Hapus barang ini beserta seluruh riwayat mutasinya?')) return;
    const res = await fetch('/inventory/api/' + id, { method:'DELETE' });
    const d = await res.json();
    showToast(d.message, d.success ? 'success' : 'error');
    if (d.success) setTimeout(() => location.reload(), 800);
}

// ── Toast ──
function showToast(msg, type) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.style.borderColor = type === 'success' ? 'rgba(16,185,129,.4)' : 'rgba(239,68,68,.4)';
    t.style.color = type === 'success' ? '#10B981' : '#EF4444';
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3500);
}
</script>
</body>
</html>
